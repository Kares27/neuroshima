{
    "id": "neuroshima",
    "title": "Neuroshima 1.5",
    "description": "System do gry fabularnej Neuroshima 1.5.",
    "version": "1.0.0.7",
    "compatibility": {
        "minimum": "13",
        "verified": "13"
    },
    "authors": [
        {
            "name": "Kares"
        }
    ],
    "esmodules": [
        "system.js"
    ],
    "socket": true,
    "styles": [
        "css/base.css",
        "css/actor.css",
        "css/items.css",
        "css/melee.css",
        "css/item-piles.css"
    ],
    "packs": [
        {
        "name": "Items",
        "label": "Items",
        "system": "neuroshima",
        "path": "packs/items",
        "type": "Item",
        "flags": {},
        "ownership": {
            "PLAYER": "OBSERVER",
            "ASSISTANT": "OWNER"
      }
    },
    {
        "name": "Neuroshima 1.5 Makra",
        "label": "Przydatne Makra",
        "system": "neuroshima",
        "path": "packs/macros",
        "type": "Macro",
        "flags": {},
        "ownership": {
            "ASSISTANT": "OWNER"
      }
    }
    ],
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json"
        },
        {
            "lang": "pl",
            "name": "Polski",
            "path": "lang/pl.json"
        }
    ],
    "documentTypes": {
        "RegionBehavior": {
            "radiationZone": {}
        }
    },
    "flags": {
        "hotReload": {
        "paths": ["templates", "styles", "lang", "scripts"]
        }
    },
    "url": "https://github.com/Kares27/neuroshima",
    "manifest": "https://github.com/Kares27/neuroshima/releases/latest/download/system.json",
    "download": "https://github.com/Kares27/neuroshima/releases/latest/download/neuroshima.zip",
	"background": "systems/neuroshima/assets/NeuroshimaWallpaper.jpg",
    "relationships": {
    "requires": [
            {
            "id": "socketlib",
            "type": "module",
            "manifest": "https://github.com/farling42/foundryvtt-socketlib/releases/latest/download/module.json"
            }
        ]
    }
}
