<div class="neuroshima roll-dialog grenade-roll-dialog">

    <div class="rd-top-split">
        <div class="rd-inputs-col">
            <div class="form-group">
                <label>{{localize "NEUROSHIMA.Roll.Modifier"}} (%)</label>
                <input type="number" name="modifier" value="{{modifier}}" placeholder="0"/>
            </div>
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useArmorPenalty" {{checked applyArmorPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Armor"}} (%)</label>
                </div>
                <input type="number" name="armorPenalty" value="{{#if applyArmorPenalty}}{{armorPenalty}}{{else}}0{{/if}}" placeholder="0" disabled/>
            </div>
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useWoundPenalty" {{checked applyWoundPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Wounds"}} (%)</label>
                </div>
                <input type="number" name="woundPenalty" value="{{#if applyWoundPenalty}}{{woundPenalty}}{{else}}0{{/if}}" placeholder="0" disabled/>
            </div>
            {{#if showDiseasePenalty}}
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useDiseasePenalty" {{checked applyDiseasePenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Disease"}} (%)</label>
                </div>
                <input type="number" name="diseasePenalty" value="{{#if applyDiseasePenalty}}{{diseasePenalty}}{{else}}0{{/if}}" placeholder="0" disabled/>
            </div>
            {{/if}}
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.SkillBonus'}}">{{localize "NEUROSHIMA.Roll.SkillBonusAbbr"}}</label>
                <input type="number" name="skillBonus" value="{{skillBonus}}" placeholder="0"/>
            </div>
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.AttributeBonus'}}">{{localize "NEUROSHIMA.Roll.AttributeBonusAbbr"}}</label>
                <input type="number" name="attributeBonus" value="{{attributeBonus}}" placeholder="0"/>
            </div>
            <div class="form-group">
                <label>{{localize "NEUROSHIMA.Grenade.Distance"}} (m)</label>
                <input type="number" name="distance" value="{{distance}}" min="0" step="0.1" placeholder="0"/>
            </div>
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.DistancePenaltyFull'}}">{{localize "NEUROSHIMA.Roll.DistancePenalty"}} (%)</label>
                <input type="number" name="distancePenalty" value="{{distancePenalty}}" placeholder="0"/>
            </div>
        </div>

        <div class="rd-modifiers-col">
            <div class="rd-modifiers-panel">
                <h4 class="dialog-modifiers-header">{{localize "NEUROSHIMA.Roll.DialogModifiers"}}</h4>
                <ul class="dm-modifier-list">
                    {{#each dialogModifiers}}
                    <li class="dm-modifier-item {{#if canToggle}}dm-toggleable{{/if}} {{#if activated}}dm-active{{/if}}"
                        data-action="clickModifier"
                        data-dm-index="{{@index}}"
                        data-dm-effect-id="{{_effectId}}"
                        {{#if description}}data-tooltip="{{description}}" data-tooltip-direction="RIGHT"{{/if}}>
                        <span class="dm-bullet">•</span><a>{{label}}</a>
                    </li>
                    {{else}}
                    <li class="dm-modifier-empty">—</li>
                    {{/each}}
                </ul>
            </div>
        </div>
    </div>

    <div class="rd-dropdowns-row">
        <div class="form-group">
            <label>{{localize "NEUROSHIMA.Roll.Difficulty"}}</label>
            <select name="baseDifficulty">
                {{#each difficulties}}
                <option value="{{@key}}" {{#if (eq @key ../baseDifficulty)}}selected{{/if}}>
                    {{localize label}}
                </option>
                {{/each}}
            </select>
        </div>
    </div>

    <div class="rd-rollmode-row">
        <div class="form-group">
            <label>{{localize "NEUROSHIMA.Roll.RollMode"}}</label>
            <select name="rollMode" class="rd-rollmode-select">
                {{selectOptions rollModes selected=rollMode localize=true}}
            </select>
        </div>
    </div>

    <div class="summary-section">
        <h3>{{localize "NEUROSHIMA.Roll.Summary"}}</h3>
        <table class="summary-table">
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.TotalModifier"}}</td>
                <td class="total-modifier">0%</td>
            </tr>
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.FinalDifficulty"}}</td>
                <td class="final-difficulty">-</td>
            </tr>
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.Target"}}</td>
                <td class="final-target">-</td>
            </tr>
        </table>
    </div>

    <footer class="form-footer">
        <button type="button" data-action="roll" autofocus="">
            <i class="fas fa-check"></i>
            <span>{{localize "NEUROSHIMA.Actions.Roll"}}</span>
        </button>
        <button type="button" data-action="cancel">
            <i class="fas fa-times"></i>
            <span>{{localize "NEUROSHIMA.Actions.Cancel"}}</span>
        </button>
    </footer>

</div>
