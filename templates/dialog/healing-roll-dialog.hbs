<div class="neuroshima roll-dialog weapon-roll-dialog-content">

    <div class="rd-top-split">
        <div class="rd-inputs-col">
            <div class="form-group">
                <label>{{localize "NEUROSHIMA.Roll.Modifier"}} (%)</label>
                <input type="number" name="modifier" value="{{modifier}}" placeholder="0"/>
            </div>
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useArmorPenalty" {{checked useArmorPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Armor"}} (%)</label>
                </div>
                <input type="number" name="armorPenalty" value="{{armorPenalty}}" placeholder="0" disabled/>
            </div>
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useWoundPenalty" {{checked useWoundPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Wounds"}} (%)</label>
                </div>
                <input type="number" name="woundPenalty" value="{{woundPenalty}}" placeholder="0" disabled/>
            </div>
            {{#if showDiseasePenalty}}
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useDiseasePenalty" {{checked useDiseasePenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Disease"}} (%)</label>
                </div>
                <input type="number" name="diseasePenalty" value="{{diseasePenalty}}" placeholder="0" disabled/>
            </div>
            {{/if}}
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.SkillBonus'}}">{{localize "NEUROSHIMA.Roll.SkillBonusAbbr"}}</label>
                <input type="number" name="skillBonus" value="{{skillBonus}}" placeholder="0"/>
            </div>
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.AttributeBonus'}}">{{localize "NEUROSHIMA.Roll.AttributeBonusAbbr"}}</label>
                <input type="number" name="attributeBonus" value="{{attributeBonus}}" placeholder="0"/>
            </div>
        </div>

        <div class="rd-modifiers-col">
            <div class="rd-modifiers-panel">
                <h4 class="dialog-modifiers-header">{{localize "NEUROSHIMA.Roll.DialogModifiers"}}</h4>
                <ul class="dm-modifier-list">
                    {{#each dialogModifiers}}
                    <li class="dm-modifier-item {{#if canToggle}}dm-toggleable{{/if}} {{#if activated}}dm-active{{/if}}"
                        data-action="clickModifier"
                        data-dm-index="{{@index}}"
                        data-dm-effect-id="{{_effectId}}"
                        {{#if description}}data-tooltip="{{description}}" data-tooltip-direction="RIGHT"{{/if}}>
                        <span class="dm-bullet">•</span><a>{{label}}</a>
                    </li>
                    {{else}}
                    <li class="dm-modifier-empty">—</li>
                    {{/each}}
                </ul>
            </div>
        </div>
    </div>

    <div class="rd-dropdowns-row">
        <div class="form-group vertical">
            <label>{{localize "NEUROSHIMA.HealingRequest.Method"}}</label>
            <select name="healingMethod">
                <option value="firstAid" {{#if (eq healingMethod "firstAid")}}selected{{/if}}>{{localize "NEUROSHIMA.Skills.firstAid"}}</option>
                <option value="woundTreatment" {{#unless (eq healingMethod "firstAid")}}selected{{/unless}}>{{localize "NEUROSHIMA.Skills.woundTreatment"}}</option>
            </select>
        </div>
        <div class="form-group vertical">
            <label>{{localize "NEUROSHIMA.Roll.Attribute"}}</label>
            <select name="attribute">
                {{#each attributeList}}
                <option value="{{@key}}" {{#if (eq @key ../currentAttribute)}}selected{{/if}}>
                    {{localize label}}
                </option>
                {{/each}}
            </select>
        </div>
    </div>

    {{#if woundGroups}}
    <div class="wounds-summary-section">
        <div class="wounds-header">
            <h3>{{localize "NEUROSHIMA.PatientCard.Wounds"}} ({{totalWounds}})</h3>
        </div>
        <table class="wounds-config-table">
            <thead>
                <tr>
                    <th>{{localize "NEUROSHIMA.Damage.Type"}}</th>
                    <th>{{localize "NEUROSHIMA.Roll.Difficulty"}}</th>
                    <th>{{localize "NEUROSHIMA.HealingRequest.HealingPercent"}}</th>
                    <th>{{localize "NEUROSHIMA.Roll.Modifier"}} %</th>
                </tr>
            </thead>
            <tbody>
                {{#if (gt woundGroupCount 1)}}
                <tr class="wound-all-row">
                    <td class="wound-type-cell"><em>{{localize "NEUROSHIMA.HealingRequest.AllTypes"}}</em></td>
                    <td class="wound-difficulty-select">—</td>
                    <td class="wound-healing-percent">—</td>
                    <td>
                        <input type="number"
                               class="wound-modifier wound-modifier-all"
                               placeholder="0"
                               min="-100"
                               max="100"/>
                    </td>
                </tr>
                {{/if}}
                {{#each woundGroups}}
                <tr data-damage-type="{{this.damageType}}" class="wound-group-row">
                    <td class="wound-type-cell" title="{{localize (concat 'NEUROSHIMA.Damage.Full.' this.damageType)}}">
                        <strong>{{this.count}}×{{this.damageType}}</strong>
                    </td>
                    <td class="wound-difficulty-select">
                        <select name="difficulty-{{this.damageType}}" class="difficulty-select" data-damage-type="{{this.damageType}}">
                            {{#each ../difficulties}}
                            <option value="{{@key}}" {{#if (eq @key ../this.difficulty)}}selected{{/if}}>
                                {{localize label}}
                            </option>
                            {{/each}}
                        </select>
                    </td>
                    <td class="wound-healing-percent" data-damage-type="{{this.damageType}}">
                        {{#if (gte this.healingPercent 0)}}+{{/if}}{{this.healingPercent}}%
                    </td>
                    <td class="wound-modifier-cell" {{#if this.healingTooltip}}data-tooltip="{{this.healingTooltip}}"{{/if}}>
                        <input type="number"
                               name="woundModifier-{{this.damageType}}"
                               class="wound-modifier"
                               value="{{this.woundModifier}}"
                               min="-100"
                               max="100"
                               placeholder="0"
                               data-damage-type="{{this.damageType}}"/>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{/if}}

    <div class="summary-section">
        <h3>{{localize "NEUROSHIMA.Roll.Summary"}}</h3>
        <table class="summary-table">
            <tr>
                <td>{{localize "NEUROSHIMA.HealingRequest.DifficultyModifier"}}</td>
                <td class="difficulty-modifier">+0%</td>
            </tr>
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.Difficulty"}}</td>
                <td class="final-difficulty">—</td>
            </tr>
        </table>
    </div>

    <footer class="form-footer">
        <button type="button" data-action="roll" autofocus="">
            <i class="fas fa-check"></i>
            <span>{{localize "NEUROSHIMA.Actions.Roll"}}</span>
        </button>
        <button type="button" data-action="cancel">
            <i class="fas fa-times"></i>
            <span>{{localize "NEUROSHIMA.Actions.Cancel"}}</span>
        </button>
    </footer>
</div>
