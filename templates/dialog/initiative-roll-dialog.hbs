<div class="neuroshima roll-dialog initiative-roll-dialog">
    <div class="dialog-columns">
        <div class="column left">
            <div class="form-group vertical">
                <label>{{localize "NEUROSHIMA.Roll.Difficulty"}}</label>
                <select name="difficulty">
                    {{#each difficulties}}
                    <option value="{{@key}}" {{#if (eq @key ../currentDifficulty)}}selected{{/if}}>
                        {{localize label}}
                    </option>
                    {{/each}}
                </select>
            </div>

            <div class="form-group vertical">
                <label>{{localize "NEUROSHIMA.Roll.Attribute"}}</label>
                <select name="attribute">
                    {{#each attributes}}
                    <option value="{{@key}}" {{#if (eq @key ../currentAttribute)}}selected{{/if}}>
                        {{localize label}}
                    </option>
                    {{/each}}
                </select>
            </div>
            
            <div class="form-group vertical">
                <label>{{localize "NEUROSHIMA.Tabs.Skills"}}</label>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <input type="checkbox" name="useSkill" {{checked useSkill}} style="width: auto; margin: 0;"/>
                    <select name="skill" {{#unless useSkill}}disabled{{/unless}} style="flex: 1;">
                        <option value="">{{localize "NEUROSHIMA.Roll.NoSkill"}}</option>
                        {{#each skills}}
                        <option value="{{key}}" {{#if (eq key ../currentSkill)}}selected{{/if}}>
                            {{label}} ({{value}})
                        </option>
                        {{/each}}
                    </select>
                </div>
            </div>
        </div>
        
        <div class="column right">
            <div class="form-group">
                <label>{{localize "NEUROSHIMA.Roll.Modifier"}} (%)</label>
                <input type="number" name="modifier" value="{{modifier}}" placeholder="0"/>
            </div>
            
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useWoundPenalty" {{checked useWoundPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Wounds"}} (%)</label>
                </div>
                <input type="number" name="woundPenalty" value="{{woundPenalty}}" placeholder="0" disabled/>
            </div>
            
            <div class="form-group">
                <div class="checkbox-wrapper">
                    <input type="checkbox" name="useArmorPenalty" {{checked useArmorPenalty}}/>
                    <label>{{localize "NEUROSHIMA.Roll.Armor"}} (%)</label>
                </div>
                <input type="number" name="armorPenalty" value="{{armorPenalty}}" placeholder="0" disabled/>
            </div>
        </div>
    </div>

    <div class="dialog-columns bonuses-row">
        <div class="column left">
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.SkillBonus'}}">{{localize "NEUROSHIMA.Roll.SkillBonusAbbr"}}</label>
                <input type="number" name="skillBonus" value="0" placeholder="0" {{#unless useSkill}}disabled{{/unless}}/>
            </div>
        </div>
        <div class="column right">
            <div class="form-group">
                <label title="{{localize 'NEUROSHIMA.Roll.AttributeBonus'}}">{{localize "NEUROSHIMA.Roll.AttributeBonusAbbr"}}</label>
                <input type="number" name="attributeBonus" value="0" placeholder="0"/>
            </div>
        </div>
    </div>

    {{#if isMelee}}
    <div class="maneuver-section">
        <div class="form-group vertical">
            <label>{{localize "NEUROSHIMA.Roll.Maneuvers.Label"}}</label>
            <div class="maneuver-inputs" style="display: flex; gap: 10px; align-items: center;">
                <select name="maneuver" style="flex: 2;">
                    <option value="none">{{localize "NEUROSHIMA.Roll.Maneuvers.None"}}</option>
                    <option value="charge">{{localize "NEUROSHIMA.Roll.Maneuvers.Charge"}}</option>
                </select>
                <div class="charge-level-wrapper" style="flex: 1; display: flex; align-items: center; gap: 5px;" hidden>
                    <label>Bon.</label>
                    <select name="chargeLevel">
                        <option value="1">+1</option>
                        <option value="2" selected>+2</option>
                        <option value="3">+3</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
    {{/if}}

    <div class="summary-section">
        <h3>{{localize "NEUROSHIMA.Roll.Summary"}}</h3>
        <table class="summary-table">
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.TotalModifier"}}</td>
                <td class="total-modifier">0%</td>
            </tr>
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.Target"}}</td>
                <td class="final-target">-</td>
            </tr>
            <tr>
                <td>{{localize "NEUROSHIMA.Roll.FinalDifficulty"}}</td>
                <td class="shifted-difficulty">-</td>
            </tr>
        </table>
    </div>

    <div class="roll-mode-row">
        <div class="form-group vertical">
            <label>{{localize "NEUROSHIMA.Roll.RollMode"}}</label>
            <select name="rollMode">
                {{selectOptions rollModes selected=rollMode localize=true}}
            </select>
        </div>
    </div>

    <footer class="form-footer">
        <button type="submit" data-action="roll" class="" autofocus="">
            <i class="fas fa-check"></i>
            <span>{{localize "NEUROSHIMA.Actions.Roll"}}</span>
        </button>
        <button type="button" data-action="cancel" class="">
            <i class="fas fa-times"></i>
            <span>{{localize "NEUROSHIMA.Actions.Cancel"}}</span>
        </button>
    </footer>
</div>
