<section class="tab-body" data-tab="mods" data-group="primary">

    <div class="combat-section">
        <div class="section-header">
            <div class="header-title">
                <i class="fas fa-tools"></i>
                <span>{{localize "NEUROSHIMA.Vehicle.Modifications"}}</span>
            </div>
            <div class="header-actions">
                {{#if owner}}
                <a class="item-control" data-action="createItem" data-type="vehicle-mod"
                    title="{{localize 'DOCUMENT.Create'}}">
                    <i class="fas fa-plus"></i>
                </a>
                {{/if}}
            </div>
        </div>

        {{#if mods.length}}
        <div class="vehicle-mods-list">
            {{#each mods as |mod|}}
            <div class="vehicle-mod-row item" data-item-id="{{mod.id}}" data-uuid="{{mod.uuid}}" draggable="true">
                <div class="mod-icon">
                    <img src="{{mod.img}}" alt="{{mod.name}}" width="32" height="32">
                </div>
                <div class="mod-info">
                    <span class="mod-name clickable" data-action="editItem" data-item-id="{{mod.id}}">{{mod.name}}</span>
                    <span class="mod-category">{{mod.categoryLabel}}</span>
                </div>
                <div class="mod-difficulty">
                    <span class="mod-difficulty-label" title="{{localize 'NEUROSHIMA.VehicleMod.InstallDifficulty'}}">{{mod.difficultyLabel}}</span>
                </div>
                <div class="item-controls">
                    <a class="item-control" data-action="editItem" data-item-id="{{mod.id}}"
                        title="{{localize 'NEUROSHIMA.Sheet.Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem" data-item-id="{{mod.id}}"
                        title="{{localize 'DOCUMENT.Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-list">{{localize "NEUROSHIMA.Vehicle.NoModifications"}}</p>
        {{/if}}
    </div>

</section>
