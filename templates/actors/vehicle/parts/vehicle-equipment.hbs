                       title="{{ms.effectName}}">
                        <i class="fas fa-play"></i> {{ms.label}}
                    </a>
                    {{/each}}
                </div>
                {{/if}}
                {{/with}}
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

</section>
