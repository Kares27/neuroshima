<section class="tab vehicle-equipment {{tabs.equipment.cssClass}}" data-group="primary" data-tab="equipment" data-application-part="equipment">
    <div class="vehicle-section">
        <div class="section-header">
            <h3>{{localize "NEUROSHIMA.Inventory.Gear"}}</h3>
            <a data-action="createItem" data-type="gear" title="{{localize 'NEUROSHIMA.Actions.CreateItem'}}">
                <i class="fas fa-plus"></i>
            </a>
        </div>
        {{#if gear.length}}
        <ul class="item-list">
            {{#each gear}}
            <li class="item" data-item-id="{{this.id}}">
                <span class="item-name">{{this.name}}</span>
                <span class="item-controls">
                    <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                    <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                </span>
            </li>
            {{/each}}
        </ul>
        {{else}}
        <p class="empty-list">{{localize "NEUROSHIMA.Vehicle.NoGear"}}</p>
        {{/if}}
    </div>
</section>
