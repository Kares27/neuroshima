<section class="tab home-base-facilities {{tabs.facilities.cssClass}}" data-group="primary" data-tab="facilities" data-application-part="facilities">

    <div class="section-header inv-section-header">
        <span>{{localize "NEUROSHIMA.HomeBase.Tabs.Facilities"}}</span>
        <div class="item-controls">
            <a class="item-control" data-action="createItem" data-type="facilities" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
        </div>
    </div>

    <div class="inventory-list">
        <div class="inventory-items">
            {{#each facilitiesItems as |item|}}
            <div class="item-wrap" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}">
                <div class="item draggable flexrow" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                    <div class="item-name flex3">
                        <div class="item-image" style="background-image: url('{{item.img}}')" data-action="toggleSummary"></div>
                        <span class="name clickable" data-action="toggleSummary">{{item.name}}</span>
                    </div>
                    {{#if item.system.facilityType}}
                    <div class="item-stat text-center" style="flex:1.5;">
                        <span>{{item.system.facilityType}}</span>
                    </div>
                    {{/if}}
                    <div class="item-stat text-center clickable" style="flex:0.5;" title="{{localize 'NEUROSHIMA.HomeBase.FacilityLevel'}}" data-action="adjustLevel" data-item-id="{{item.id}}">
                        <span>{{localize "NEUROSHIMA.HomeBase.FacilityLevelAbbr"}} {{item.system.level}}</span>
                    </div>
                    <div class="item-stat text-center" style="flex:0.6;" title="{{localize 'NEUROSHIMA.HomeBase.Facilities.IsBuilt'}}">
                        <a class="item-control toggle-equipped" data-action="toggleIsBuilt" data-item-id="{{item.id}}">
                            <i class="{{#if item.system.isBuilt}}fas fa-check-circle{{else}}far fa-circle{{/if}}"></i>
                        </a>
                    </div>
                    <div class="item-controls">
                        <a class="item-control item-ctx-btn" data-action="itemContextMenu" title="{{localize 'NEUROSHIMA.ContextMenu.Options'}}"><i class="fa-solid fa-ellipsis-vertical"></i></a>
                    </div>
                </div>
                {{#with (lookup ../itemManualScripts item.id) as |scripts|}}
                {{#if scripts}}
                <div class="sheet-effect-buttons">
                    {{#each scripts as |ms|}}
                    <button class="manual-script-btn" data-action="invokeItemScript"
                           data-item-id="{{ms.itemId}}" data-effect-id="{{ms.effectId}}"
                           data-script-index="{{ms.scriptIndex}}"
                           title="{{ms.effectName}}" type="button">
                        <i class="fas fa-play"></i> {{ms.label}}
                    </button>
                    {{/each}}
                </div>
                {{/if}}
                {{/with}}
                <div class="item-summary collapsed">
                    <div class="item-stats-summary">
                        <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Stats"}}</div>
                        {{#if item.system.capacity}}<span class="stat-summary-chip"><span class="stat-chip-label">{{localize "NEUROSHIMA.HomeBase.FacilityCapacity"}}</span><span class="stat-chip-value">{{item.system.capacity}}</span></span>{{/if}}
                        {{#if item.system.maintenanceCost}}<span class="stat-summary-chip"><span class="stat-chip-label">{{localize "NEUROSHIMA.HomeBase.FacilityMaintenance"}}</span><span class="stat-chip-value">{{item.system.maintenanceCost}}</span></span>{{/if}}
                    </div>
                    <div class="item-resources-wrapper">
                        <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Resources"}}</div>
                        <div class="item-resources-summary">{{#each item.system.resources}}{{#if this.showInSummary}}<span class="resource-summary-chip"><span class="resource-chip-label">{{this.label}}</span><span class="resource-chip-value">{{this.value}}{{#if this.max}} / {{this.max}}{{/if}}</span></span>{{/if}}{{/each}}</div>
                    </div>
                    <div class="item-description-wrapper">
                        <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Description"}}</div>
                        <div class="item-description">{{{item.system.description}}}</div>
                    </div>
                </div>
            </div>
            {{else}}
            <p class="crew-empty">{{localize "NEUROSHIMA.HomeBase.NoFacilities"}}</p>
            {{/each}}
        </div>
    </div>

</section>
