<section class="tab combat {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat" data-application-part="combat">

    {{!-- ===== Melee Opposed Pending Cards ===== --}}
    {{#each combat.meleePendings as |pending|}}
        {{#if pending.matchesDefender}}
        <div class="melee-pending-attacker-card clickable" data-action="respondToOpposed" data-pending-id="{{pending.id}}" title="{{localize 'NEUROSHIMA.MeleeOpposed.Join'}}">
            <div class="pending-card-header">
                <div class="pending-header-main">
                    <i class="fas fa-hand-fist animate-fist"></i>
                    <span>{{localize "NEUROSHIMA.MeleeOpposed.PendingAttacker"}}</span>
                </div>
                <a class="pending-dismiss-btn" data-action="dismissOpposed" data-pending-id="{{pending.id}}" title="{{localize 'NEUROSHIMA.Actions.Dismiss'}}">
                    <i class="fas fa-times"></i>
                </a>
            </div>
            <div class="pending-card-content">
                <div class="attacker-row">
                    <div class="attacker-identity">
                        <span class="attacker-label">{{localize "NEUROSHIMA.MeleeDuel.Attacker"}}:</span>
                        <span class="attacker-name">{{pending.attackerName}}</span>
                    </div>
                </div>
                {{#if pending.mode}}
                <p class="pending-instruction">{{localize "NEUROSHIMA.MeleeOpposedChat.InstructionDefender"}}</p>
                {{else}}
                <p class="pending-instruction">{{localize "NEUROSHIMA.MeleeOpposed.InstructionDefender"}}</p>
                {{/if}}
            </div>
        </div>
        {{/if}}
    {{/each}}

    {{!-- ===== Two-column: Natural Armor | Beast Actions + Maneuvers ===== --}}
    <div class="creature-combat-columns">

        {{!-- LEFT: Combined armor — natural values + equipped items per location --}}
        <div class="creature-combat-col">
            <div class="section-header">
                <i class="fas fa-shield-alt"></i>
                <span class="header-label">{{localize "NEUROSHIMA.Creature.NaturalArmor.Title"}}</span>
                <div class="armor-penalty-total">
                    <span>{{localize "NEUROSHIMA.Armor.TotalPenalty"}}: <strong>{{combat.totalArmorPenalty}}%</strong></span>
                </div>
            </div>

            <div class="armor-anatomical-grid creature-armor-grid">
                {{#each armorLocations}}
                <div class="armor-location-box armor-{{this.key}} has-items">

                    {{!-- Header: location name + AP sum if any equipped armor --}}
                    <div class="location-header">
                        <span class="location-name">{{this.label}}</span>
                        {{#if (gt this.totalEffectiveAP 0)}}
                        <span class="location-ap-sum" data-tooltip="{{this.tooltip}}">{{this.totalEffectiveAP}}</span>
                        {{/if}}
                    </div>

                    {{!-- Column labels as sub-header --}}
                    <div class="nat-armor-col-headers">
                        <span title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.Reduction'}}">{{localize "NEUROSHIMA.Creature.NaturalArmor.ReductionAbbr"}}</span>
                        <span title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.HitPenalty'}}">{{localize "NEUROSHIMA.Creature.NaturalArmor.HitPenaltyAbbr"}}</span>
                        <span class="nat-armor-col-weakpoint-spacer"></span>
                    </div>

                    {{!-- Inputs row --}}
                    <div class="nat-armor-body">
                        <input type="number"
                            name="system.naturalArmor.{{this.key}}.reduction"
                            value="{{this.reduction}}"
                            min="0" step="0.5"
                            class="nat-armor-reduction-input"
                            title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.Reduction'}}"/>

                        <input type="number"
                            name="system.naturalArmor.{{this.key}}.hitPenalty"
                            value="{{this.hitPenalty}}"
                            min="0" max="100"
                            class="nat-armor-penalty-input"
                            title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.HitPenalty'}}"/>

                        <label class="nat-armor-weakpoint-toggle"
                            title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.WeakPoint'}}">
                            <input type="checkbox"
                                name="system.naturalArmor.{{this.key}}.weakPoint"
                                {{#if this.weakPoint}}checked{{/if}}/>
                            <img src="systems/neuroshima/assets/img/hazard-sign.svg" class="nat-armor-weakpoint-icon" alt="!"/>
                        </label>
                    </div>

                    {{!-- Equipped armor items for this location --}}
                    {{#if this.items.length}}
                    <div class="armor-column-headers">
                        <span class="armor-header-icon"></span>
                        <span class="armor-header-name">{{localize "Name"}}</span>
                        <span class="armor-header-dur">{{localize "NEUROSHIMA.Items.Fields.DurabilityAbbr"}}</span>
                        <span class="armor-header-ap">AP</span>
                    </div>
                    <div class="location-armor-list">
                        {{#each this.items as |armor|}}
                        <div class="armor-item-row item" data-item-id="{{armor.id}}" draggable="true">
                            <img src="{{armor.img}}" class="armor-icon-tiny" alt="{{armor.name}}">
                            <span class="armor-name-tiny clickable" data-action="editItem">{{armor.name}}</span>
                            <span class="armor-durability clickable {{#if (lt armor.currentDurability armor.durability)}}is-damaged{{/if}}"
                                  data-action="modifyDurability"
                                  data-item-id="{{armor.id}}"
                                  title="LPM: {{localize "NEUROSHIMA.Actions.Repair"}} | PPM: {{localize "NEUROSHIMA.Actions.Damage"}}">
                                {{armor.currentDurability}}
                            </span>
                            <span class="armor-ap-value clickable {{#if (lt armor.currentRating armor.rating)}}is-damaged{{/if}}"
                                  data-action="modifyAP"
                                  data-item-id="{{armor.id}}"
                                  data-location="{{../key}}"
                                  title="LPM: {{localize "NEUROSHIMA.Actions.Repair"}} | PPM: {{localize "NEUROSHIMA.Actions.Damage"}}">
                                {{armor.currentRating}}
                            </span>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}

                </div>
                {{/each}}
            </div>
        </div>

        {{!-- RIGHT: Beast Actions + Beast Maneuvers stacked --}}
        <div class="creature-combat-col">

            {{!-- Beast Actions --}}
            <div class="section-header">
                <i class="fas fa-paw"></i>
                <span class="header-label">{{localize "NEUROSHIMA.BeastAction.Label"}}</span>
                <div class="header-controls">
                    <a class="item-control" data-action="createItem" data-type="beast-action"
                        title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
                </div>
            </div>

            <ul class="item-list creature-actions-list">
                {{#each inventory.beastActions}}
                {{#if this.system.weaponType}}
                <li class="item item-weapon-action" data-item-id="{{this.id}}">
                    <img class="item-img" src="{{this.img}}" title="{{this.name}}" width="16" height="16"/>
                    <span class="item-name">{{this.name}}</span>
                    <span class="beast-action-meta">
                        <span class="action-type-badge action-type-attack">
                            {{localize "NEUROSHIMA.Items.Fields.WeaponSubtype"}}
                        </span>
                    </span>
                    <span class="item-controls">
                        <a data-action="rollWeapon" data-item-id="{{this.id}}" title="{{localize 'NEUROSHIMA.Actions.Roll'}}"><i class="fas fa-dice"></i></a>
                        <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                    </span>
                </li>
                {{else}}
                <li class="item" data-item-id="{{this.id}}">
                    <span class="item-name">{{this.name}}</span>
                    <span class="beast-action-meta">
                        <span class="action-type-badge action-type-{{this.system.actionType}}">
                            {{lookup ../beastActionTypes this.system.actionType}}
                        </span>
                        <span class="action-cost" title="{{#if (eq this.system.costType 'success')}}{{localize 'NEUROSHIMA.BeastAction.SuccessCost'}}{{else}}{{localize 'NEUROSHIMA.BeastAction.SegmentCost'}}{{/if}}">
                            {{#if (eq this.system.costType "success")}}{{this.system.successCost}}s+{{else}}{{this.system.segmentCost}}s{{/if}}
                        </span>
                    </span>
                    <span class="item-controls">
                        <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                        <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                    </span>
                </li>
                {{/if}}
                {{else}}
                <li class="item-list-empty">{{localize "NEUROSHIMA.BeastAction.None"}}</li>
                {{/each}}
            </ul>

            {{!-- Beast Maneuvers --}}
            <div class="section-header" style="margin-top: 10px;">
                <i class="fas fa-route"></i>
                <span class="header-label">{{localize "NEUROSHIMA.BeastManeuver.Label"}}</span>
                <div class="header-controls">
                    <a class="item-control" data-action="createItem" data-type="beast-maneuver"
                        title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
                </div>
            </div>

            <ul class="item-list creature-maneuvers-list">
                {{#each inventory.beastManeuvers}}
                <li class="item" data-item-id="{{this.id}}">
                    <span class="item-name">{{this.name}}</span>
                    <span class="beast-action-meta">
                        <span class="action-type-badge maneuver-type-{{this.system.maneuverType}}">
                            {{lookup ../beastManeuverTypes this.system.maneuverType}}
                        </span>
                        <span class="action-cost" title="{{localize 'NEUROSHIMA.BeastManeuver.Difficulty'}}">
                            {{this.system.difficulty}}★
                        </span>
                    </span>
                    <span class="item-controls">
                        <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                        <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                    </span>
                </li>
                {{else}}
                <li class="item-list-empty">{{localize "NEUROSHIMA.BeastManeuver.None"}}</li>
                {{/each}}
            </ul>

        </div>
    </div>

    {{!-- ===== Wounds — full table matching actor-sheet style ===== --}}
    <section class="combat-section wounds-section creature-wounds-section">
        <div class="section-header">
            <div class="header-title">
                <i class="fas fa-crutch"></i>
                <span>{{localize "NEUROSHIMA.Items.Type.Wound"}}</span>
            </div>

            <div class="wound-stats-total">
                <span class="hp-sum" title="{{localize 'NEUROSHIMA.Wound.TotalDamage'}}">
                    <i class="fas fa-heart"></i> {{combat.totalDamagePoints}} / {{combat.maxHP}}
                </span>
                <span class="penalty-sum" title="{{localize 'NEUROSHIMA.Wound.TotalPenalty'}}">
                    <i class="fas fa-exclamation-triangle"></i> {{combat.totalWoundPenalty}}%
                </span>
            </div>

            <div class="header-actions">
                {{#if owner}}
                <a class="item-control" data-action="rest" title="{{localize 'NEUROSHIMA.Actions.Rest'}}">
                    <i class="fas fa-bed"></i>
                </a>
                {{#if @root.game.user.isGM}}
                <a class="item-control" data-action="configureHP" title="{{localize 'NEUROSHIMA.Actions.ConfigureHP'}}">
                    <i class="fas fa-cog"></i>
                </a>
                {{/if}}
                <a class="item-control" data-action="createItem" data-type="wound" title="{{localize 'DOCUMENT.Create'}}">
                    <i class="fas fa-plus"></i>
                </a>
                {{/if}}
            </div>
        </div>

        <div class="combat-table wounds-table">
            <div class="table-header">
                <div class="col-name">{{localize "Name"}}</div>
                <div class="col-location">{{localize "NEUROSHIMA.Items.Fields.Location"}}</div>
                <div class="col-type">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</div>
                <div class="col-penalty">{{localize "NEUROSHIMA.Items.Fields.Penalty"}}</div>
                <div class="col-controls"></div>
            </div>
            {{#each combat.wounds}}
            <div class="table-row item" data-item-id="{{this.id}}" data-uuid="{{this.uuid}}" draggable="true">
                <div class="col-name item-name clickable" data-action="editItem">
                    <img src="{{this.img}}" title="{{this.name}}" width="24" height="24"/>
                    <span>{{this.name}}</span>
                </div>
                <div class="col-location">
                    <select name="items.{{this.id}}.system.location">
                        {{selectOptions ../config.locations selected=this.system.location localize=true}}
                    </select>
                </div>
                <div class="col-type">
                    <select name="items.{{this.id}}.system.damageType">
                        {{selectOptions ../config.damageTypes selected=this.system.damageType localize=true}}
                    </select>
                </div>
                <div class="col-penalty">
                    <input type="number" name="items.{{this.id}}.system.penalty"
                        value="{{this.system.penalty}}" data-dtype="Number" min="0"/>
                </div>
                <div class="col-controls">
                    <a class="item-control {{#if this.system.isHealing}}active{{/if}}" data-action="toggleHealing"
                        title="{{localize 'NEUROSHIMA.Actions.Healing'}}"><i class="fas fa-medkit"></i></a>
                    <a class="item-control" data-action="editItem"
                        title="{{localize 'NEUROSHIMA.Sheet.Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem"
                        title="{{localize 'DOCUMENT.Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{else}}
            <div class="item-list-empty">{{localize "NEUROSHIMA.Wounds.None"}}</div>
            {{/each}}
        </div>
    </section>

</section>
