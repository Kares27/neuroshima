<div class="sheet-main-wrapper actor-sheet-content" data-application-part="main">
    <div data-application-part="header"></div>
    <div data-application-part="tabs"></div>

    <section class="sheet-body">

        {{!-- ===== ATTRIBUTES TAB ===== --}}
        <section class="tab attributes {{tabs.attributes.cssClass}}" data-group="primary" data-tab="attributes">
            <div class="attributes-table">
                <table>
                    <thead>
                        <tr>
                            <th class="label-column"></th>
                            {{#each attributeList as |attr key|}}
                            <th title="{{localize attr.label}}" class="attribute-header-cell clickable"
                                data-action="rollAttribute" data-attribute="{{key}}">
                                <div class="attribute-abbr">{{localize attr.abbr}}</div>
                            </th>
                            {{/each}}
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="attribute-row">
                            <td class="label-column"><strong>{{localize "NEUROSHIMA.Attributes.Base"}}</strong></td>
                            {{#each attributeList as |attr key|}}
                            <td>
                                <input type="number" name="system.attributes.{{key}}"
                                    value="{{lookup ../system.attributes key}}" min="0" max="40"/>
                            </td>
                            {{/each}}
                        </tr>
                        <tr class="attribute-row">
                            <td class="label-column"><strong>{{localize "NEUROSHIMA.Attributes.Modifier"}}</strong></td>
                            {{#each attributeList as |attr key|}}
                            <td>
                                <input type="number" name="system.modifiers.{{key}}"
                                    value="{{lookup ../system.modifiers key}}"/>
                            </td>
                            {{/each}}
                        </tr>
                        <tr class="toggle-row-wrapper">
                            <td colspan="6" class="toggle-cell">
                                <button type="button" class="toggle-difficulties-btn" data-action="toggleDifficulties">
                                    <i class="fas {{#if difficultiesCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
                                    <span>
                                        {{#if difficultiesCollapsed}}
                                            {{localize "NEUROSHIMA.Difficulty.ShowMore"}}
                                        {{else}}
                                            {{localize "NEUROSHIMA.Difficulty.ShowLess"}}
                                        {{/if}}
                                    </span>
                                </button>
                            </td>
                        </tr>
                        {{#unless difficultiesCollapsed}}
                        {{#each difficulties as |diff diffKey|}}
                        <tr class="difficulty-row">
                            <td class="label-column">{{localize diff.label}} ({{#if (gt diff.mod 0)}}+{{/if}}{{diff.mod}})</td>
                            {{#each ../attributeList as |attr attrKey|}}
                            <td class="text-center">
                                {{lookup (lookup ../../system.thresholds attrKey) diffKey}}
                            </td>
                            {{/each}}
                        </tr>
                        {{/each}}
                        {{/unless}}
                    </tbody>
                </table>
            </div>
        </section>

        {{!-- ===== COMBAT TAB ===== --}}
        <section class="tab combat {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat">

            {{!-- Two-column layout: Natural Armor | Beast Actions --}}
            <div class="creature-combat-columns">

                {{!-- LEFT: Natural Armor --}}
                <div class="creature-combat-col">
                    <div class="section-header">
                        <i class="fas fa-shield-alt"></i>
                        <span class="header-label">{{localize "NEUROSHIMA.Creature.NaturalArmor.Title"}}</span>
                    </div>
                    <table class="natural-armor-table">
                        <thead>
                            <tr>
                                <th>{{localize "NEUROSHIMA.Creature.NaturalArmor.Location"}}</th>
                                <th title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.Reduction'}}">{{localize "NEUROSHIMA.Creature.NaturalArmor.ReductionAbbr"}}</th>
                                <th title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.HitPenalty'}}">{{localize "NEUROSHIMA.Creature.NaturalArmor.HitPenaltyAbbr"}}</th>
                                <th title="{{localize 'NEUROSHIMA.Creature.NaturalArmor.WeakPoint'}}">{{localize "NEUROSHIMA.Creature.NaturalArmor.WeakPointAbbr"}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each naturalArmorParts}}
                            <tr>
                                <td class="location-label">{{this.label}}</td>
                                <td>
                                    <input type="number" name="system.naturalArmor.{{this.key}}.reduction"
                                        value="{{this.reduction}}" min="0" step="0.5" class="nat-armor-input"/>
                                </td>
                                <td>
                                    <input type="number" name="system.naturalArmor.{{this.key}}.hitPenalty"
                                        value="{{this.hitPenalty}}" min="0" class="nat-armor-input"/>
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" name="system.naturalArmor.{{this.key}}.weakPoint"
                                        {{#if this.weakPoint}}checked{{/if}}/>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                {{!-- RIGHT: Beast Actions + Weapons --}}
                <div class="creature-combat-col">
                    {{!-- Beast Actions --}}
                    <div class="section-header">
                        <i class="fas fa-paw"></i>
                        <span class="header-label">{{localize "NEUROSHIMA.BeastAction.Label"}}</span>
                        <a class="item-control" data-action="createItem" data-type="beast-action"
                            title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
                    </div>
                    <ul class="item-list creature-actions-list">
                        {{#each inventory.beastActions}}
                        <li class="item" data-item-id="{{this.id}}">
                            <span class="item-name">{{this.name}}</span>
                            <span class="beast-action-meta">
                                <span class="action-type-badge action-type-{{this.system.actionType}}">
                                    {{lookup ../beastActionTypes this.system.actionType}}
                                </span>
                                <span class="action-cost" title="{{localize 'NEUROSHIMA.BeastAction.SegmentCost'}}">
                                    {{this.system.segmentCost}}s
                                </span>
                            </span>
                            <span class="item-controls">
                                <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                            </span>
                        </li>
                        {{/each}}
                    </ul>

                    {{!-- Weapons --}}
                    <div class="section-header" style="margin-top: 8px;">
                        <i class="fas fa-fist-raised"></i>
                        <span class="header-label">{{localize "NEUROSHIMA.Inventory.Weapons"}}</span>
                        <div class="header-controls">
                            <a class="item-control" data-action="rollMeleeInitiative"
                                title="{{localize 'NEUROSHIMA.Combat.RollInitiative'}}">
                                <i class="fas fa-dice"></i>
                            </a>
                            <a class="item-control" data-action="createItem" data-type="weapon"
                                title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
                        </div>
                    </div>
                    <ul class="item-list">
                        {{#each inventory.weaponsMelee}}
                        <li class="item" data-item-id="{{this.id}}">
                            <img src="{{this.img}}" width="20" height="20"/>
                            <span class="item-name">{{this.name}}</span>
                            <span class="item-controls">
                                <a data-action="rollWeapon" data-item-id="{{this.id}}"><i class="fas fa-dice-d20"></i></a>
                                <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                            </span>
                        </li>
                        {{/each}}
                    </ul>
                </div>
            </div>

            {{!-- Wounds — below both columns --}}
            <div class="creature-wounds-section">
                <div class="section-header">
                    <i class="fas fa-crutch"></i>
                    <span>{{localize "NEUROSHIMA.Items.Type.Wound"}}</span>
                    <a class="item-control" data-action="createItem" data-type="wound"
                        title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
                </div>
                <ul class="item-list">
                    {{#each inventory.wounds}}
                    <li class="item" data-item-id="{{this.id}}">
                        <span class="item-name">{{this.name}}</span>
                        <span class="wound-meta">
                            <span class="wound-type-badge">{{this.system.damageType}}</span>
                            <span class="wound-penalty">-{{this.system.penalty}}%</span>
                            <span class="wound-location">{{localize (lookup (lookup ../config.bodyLocations this.system.location) "label")}}</span>
                        </span>
                        <span class="item-controls">
                            <a data-action="editItem"   data-item-id="{{this.id}}"><i class="fas fa-edit"></i></a>
                            <a data-action="deleteItem" data-item-id="{{this.id}}"><i class="fas fa-trash"></i></a>
                        </span>
                    </li>
                    {{else}}
                    <li class="item-list-empty">{{localize "NEUROSHIMA.Wounds.None"}}</li>
                    {{/each}}
                </ul>
            </div>
        </section>

        {{!-- ===== NOTES TAB ===== --}}
        <section class="tab notes {{tabs.notes.cssClass}}" data-group="primary" data-tab="notes">
            <prose-mirror
                name="system.notes"
                value="{{system.notes}}"
                document-uuid="{{actor.uuid}}"
                toggled
                {{#unless editable}}disabled{{/unless}}>
                {{{notes.enriched}}}
            </prose-mirror>
        </section>

    </section>
</div>
