<section class="tab background {{tabs.background.cssClass}}" data-group="primary" data-tab="background" data-application-part="background">

    {{!-- Background slots: Specialization, Origin, Profession --}}
    <div class="background-slots">

        {{!-- Specialization --}}
        <div class="background-slot" data-slot-type="specialization">
            <div class="background-slot-header">
                <span class="background-slot-title">{{localize "NEUROSHIMA.Info.Specialization"}}</span>
                <a class="item-control" data-action="createItem" data-type="specialization" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
            </div>
            {{#if background.specialization}}
            {{#with background.specialization as |item|}}
            <div class="background-item" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                <div class="background-item-icon" style="background-image: url('{{item.img}}')"></div>
                <div class="background-item-body">
                    <div class="background-item-name clickable" data-action="editItem">{{item.name}}</div>
                    {{#if item.activeSpecializations.length}}
                    <div class="background-item-meta background-spec-tags">
                        <i class="fas fa-graduation-cap"></i>
                        {{#each item.activeSpecializations as |specKey|}}
                        <span class="spec-tag">{{localize (concat "NEUROSHIMA.Specializations." specKey)}}</span>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{#if item.system.bonusText}}
                    <div class="background-item-bonus enriched-text">{{{item.bonusEnriched}}}</div>
                    {{/if}}
                </div>
                <div class="background-item-controls">
                    <a class="item-control" data-action="editItem" title="{{localize 'Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem" title="{{localize 'Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/with}}
            {{else}}
            <div class="background-slot-empty">
                <i class="fas fa-user-cog"></i>
                <span>{{localize "NEUROSHIMA.Background.Empty.Specialization"}}</span>
            </div>
            {{/if}}
        </div>

        {{!-- Origin --}}
        <div class="background-slot" data-slot-type="origin">
            <div class="background-slot-header">
                <span class="background-slot-title">{{localize "NEUROSHIMA.Info.Origin"}}</span>
                <a class="item-control" data-action="createItem" data-type="origin" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
            </div>
            {{#if background.origin}}
            {{#with background.origin as |item|}}
            <div class="background-item" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                <div class="background-item-icon" style="background-image: url('{{item.img}}')"></div>
                <div class="background-item-body">
                    <div class="background-item-name clickable" data-action="editItem">{{item.name}}</div>
                    {{#if item.system.faction}}
                    <div class="background-item-meta">
                        <i class="fas fa-flag"></i> {{item.system.faction}}
                    </div>
                    {{/if}}
                    {{#if item.system.bonusText}}
                    <div class="background-item-bonus enriched-text">{{{item.bonusEnriched}}}</div>
                    {{/if}}
                </div>
                <div class="background-item-controls">
                    <a class="item-control" data-action="editItem" title="{{localize 'Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem" title="{{localize 'Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/with}}
            {{else}}
            <div class="background-slot-empty">
                <i class="fas fa-map-marker-alt"></i>
                <span>{{localize "NEUROSHIMA.Background.Empty.Origin"}}</span>
            </div>
            {{/if}}
        </div>

        {{!-- Profession --}}
        <div class="background-slot" data-slot-type="profession">
            <div class="background-slot-header">
                <span class="background-slot-title">{{localize "NEUROSHIMA.Info.Profession"}}</span>
                <a class="item-control" data-action="createItem" data-type="profession" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
            </div>
            {{#if background.profession}}
            {{#with background.profession as |item|}}
            <div class="background-item" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                <div class="background-item-icon" style="background-image: url('{{item.img}}')"></div>
                <div class="background-item-body">
                    <div class="background-item-name clickable" data-action="editItem">{{item.name}}</div>
                    {{#if item.system.startingSkills}}
                    <div class="background-item-meta">
                        <i class="fas fa-tools"></i> {{item.system.startingSkills}}
                    </div>
                    {{/if}}
                    {{#if item.system.bonusText}}
                    <div class="background-item-bonus enriched-text">{{{item.bonusEnriched}}}</div>
                    {{/if}}
                </div>
                <div class="background-item-controls">
                    <a class="item-control" data-action="editItem" title="{{localize 'Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem" title="{{localize 'Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/with}}
            {{else}}
            <div class="background-slot-empty">
                <i class="fas fa-briefcase"></i>
                <span>{{localize "NEUROSHIMA.Background.Empty.Profession"}}</span>
            </div>
            {{/if}}
        </div>

    </div>

    {{!-- Additional background items (duplicates / extras) --}}
    {{#if background.extras.length}}
    <section class="inventory-section" style="margin-top:1rem;">
        <div class="section-header">
            <span>{{localize "NEUROSHIMA.Background.Extras"}}</span>
        </div>
        <div class="inventory-items">
            {{#each background.extras as |item|}}
            <div class="item flexrow" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                <div class="item-name flex5">
                    <div class="item-image" style="background-image: url('{{item.img}}')"></div>
                    <span class="name clickable" data-action="editItem">{{item.name}}</span>
                    <span class="item-type-badge">{{localize (concat "NEUROSHIMA.Items.Type." item.typeCap)}}</span>
                </div>
                <div class="item-controls flex1">
                    <a class="item-control" data-action="editItem" title="{{localize 'Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control" data-action="deleteItem" title="{{localize 'Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

</section>
