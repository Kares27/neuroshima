<section class="tab inventory {{tabs.inventory.cssClass}}" data-group="primary" data-tab="inventory" data-application-part="inventory">
    
    {{!-- Encumbrance Bar --}}
    {{#if enableEncumbrance}}
    <div class="encumbrance-bar-container">
        <div class="encumbrance-label">
            <i class="fas fa-weight-hanging" style="color: {{system.encumbrance.color}};"></i>
            <span>{{localize "NEUROSHIMA.Encumbrance"}}: {{system.encumbrance.value}} / {{system.encumbrance.max}} kg</span>
        </div>
        <div class="encumbrance-bar">
            <div class="encumbrance-fill" style="width: {{system.encumbrance.pct}}%; background: {{system.encumbrance.color}};"></div>
            <div class="enc-marker enc-marker--yellow" style="left: 50%;" title="50% — żółty"></div>
            <div class="enc-marker enc-marker--orange" style="left: 75%;" title="75% — pomarańczowy"></div>
            <div class="enc-marker enc-marker--danger" style="left: 90%;" title="90% — czerwony"></div>
        </div>
    </div>
    {{/if}}

    {{!-- Money / Waluta --}}
    {{#if inventory.money.length}}
    <section class="inventory-section">
        <div class="section-header money-section-header">
            <div class="money-header-left">
                <button class="money-consolidate-btn" data-action="consolidateMoney" type="button" title="{{localize 'NEUROSHIMA.Money.Consolidate'}}">
                    <i class="fas fa-coins"></i>
                </button>
                <span>{{localize "NEUROSHIMA.Items.Type.Money"}} ({{localize "NEUROSHIMA.Money.Total"}}: {{moneyData.totalBaseUnitsFormatted}} Gamble)</span>
            </div>
            <div class="item-stat quantity text-center">{{localize "NEUROSHIMA.Items.Fields.Quantity"}}</div>
            {{#if enableEncumbrance}}
            <div class="item-stat weight text-center">{{localize "NEUROSHIMA.Items.Fields.Weight"}}</div>
            {{/if}}
            <div class="item-controls">
                <a class="item-control" data-action="createItem" data-type="money" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
            </div>
        </div>
        <div class="inventory-list money-list">
            <div class="inventory-items">
                {{#each inventory.money as |item|}}
                <div class="item-wrap" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}">
                    <div class="item draggable flexrow" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                        <div class="item-name flex3">
                            <div class="item-image" style="background-image: url('{{item.img}}')" data-action="toggleSummary"></div>
                            <span class="name clickable" data-action="toggleSummary">{{item.name}}</span>
                        </div>
                        <div class="item-stat quantity quantity-controls">
                            <span class="quantity-value clickable" data-action="adjustQuantity" data-context-menu title="{{item.system.quantity}}">{{item.system.quantity}}</span>
                        </div>
                        {{#if ../enableEncumbrance}}
                        <div class="item-stat weight weight-controls text-center">
                            <span class="weight-value">{{item.system.totalWeight}}</span>
                        </div>
                        {{/if}}
                        <div class="item-controls">
                            <a class="item-control item-ctx-btn" data-action="itemContextMenu" title="{{localize 'NEUROSHIMA.ContextMenu.Options'}}"><i class="fa-solid fa-ellipsis-vertical"></i></a>
                        </div>
                    </div>
                    <div class="item-summary collapsed">
                        <div class="item-stats-summary">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Stats"}}</div>
                            <span class="stat-summary-chip"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.CoinValue"}}</span><span class="stat-chip-value">{{item.system.coinValue}}</span></span>
                        </div>
                        <div class="item-description-wrapper">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Description"}}</div>
                            <div class="item-description">{{{item.system.description}}}</div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

    {{!-- Ranged Weapons --}}
    {{#if inventory.weaponsRanged.length}}
    <section class="inventory-section">
        <div class="section-header inv-section-header">
            <span>{{localize "NEUROSHIMA.Items.Type.WeaponRanged"}}</span>
            <div class="item-stat equipped text-center">{{localize "NEUROSHIMA.Items.Fields.EquippedAbbr"}}</div>
            <div class="item-stat quantity text-center">{{localize "NEUROSHIMA.Items.Fields.Quantity"}}</div>
            {{#if enableEncumbrance}}
            <div class="item-stat weight text-center">{{localize "NEUROSHIMA.Items.Fields.Weight"}}</div>
            {{/if}}
            <div class="item-controls">
                <a class="item-control" data-action="createItem" data-type="weapon" data-weapon-type="ranged" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
            </div>
        </div>
        <div class="inventory-list ranged-list">
            <div class="inventory-items">
                {{#each inventory.weaponsRanged as |item|}}
                <div class="item-wrap" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}">
                    <div class="item draggable flexrow" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                        <div class="item-name flex3">
                            <div class="item-image" style="background-image: url('{{item.img}}')" data-action="toggleSummary"></div>
                            <span class="name clickable" data-action="toggleSummary">{{item.name}}</span>
                        </div>
                        <div class="item-stat equipped text-center">
                            <a class="item-control toggle-equipped" data-action="toggleEquipped" title="{{localize 'NEUROSHIMA.Items.Fields.Equipped'}}">
                                <i class="{{#if item.system.equipped}}fas fa-check-circle{{else}}far fa-circle{{/if}}"></i>
                            </a>
                        </div>
                        <div class="item-stat quantity quantity-controls">
                            <span class="quantity-value clickable" data-action="adjustQuantity" data-context-menu title="{{item.system.quantity}}">{{item.system.quantity}}</span>
                        </div>
                        {{#if ../enableEncumbrance}}
                        <div class="item-stat weight weight-controls text-center">
                            <span class="weight-value" title="{{item.system.totalWeight}}">{{item.system.totalWeight}}</span>
                        </div>
                        {{/if}}
                        <div class="item-controls">
                            <a class="item-control item-ctx-btn" data-action="itemContextMenu" title="{{localize 'NEUROSHIMA.ContextMenu.Options'}}"><i class="fa-solid fa-ellipsis-vertical"></i></a>
                        </div>
                    </div>
                    {{#with (lookup ../itemManualScripts item.id) as |scripts|}}
                    {{#if scripts}}
                    <div class="sheet-effect-buttons">
                        {{#each scripts as |ms|}}
                        <button class="manual-script-btn" data-action="invokeItemScript"
                               data-item-id="{{ms.itemId}}" data-effect-id="{{ms.effectId}}"
                               data-script-index="{{ms.scriptIndex}}"
                               title="{{ms.effectName}}" type="button">
                            <i class="fas fa-play"></i> {{ms.label}}
                        </button>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{/with}}
                    <div class="item-summary collapsed">
                        <div class="item-stats-summary">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Stats"}}</div>
                            {{#if item.system.damage}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'damage' 'overrideDamage')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'damage' 'overrideDamage'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</span><span class="stat-chip-value">{{item.system.damage}}</span></span>{{/if}}
                            {{#if item.system.caliber}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'modCaliber' 'overrideCaliber')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'modCaliber' 'overrideCaliber'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.Caliber"}}</span><span class="stat-chip-value">{{item.system.caliber}}</span></span>{{/if}}
                            {{#if item.system.fireRate}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaFireRate' 'overrideFireRate')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaFireRate' 'overrideFireRate'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.FireRateAbbr"}}</span><span class="stat-chip-value">{{item.system.fireRate}}</span></span>{{/if}}
                            {{#if item.system.piercing}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaPiercing' 'overridePiercing')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaPiercing' 'overridePiercing'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.PiercingAbbr"}}</span><span class="stat-chip-value">{{item.system.piercing}}</span></span>{{/if}}
                            <span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaJamming' 'overrideJamming')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaJamming' 'overrideJamming'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.JammingAbbr"}}</span><span class="stat-chip-value">{{item.system.jamming}}</span></span>
                            {{#if item.system.capacity}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaCapacity' 'overrideCapacity')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaCapacity' 'overrideCapacity'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.Capacity"}}</span><span class="stat-chip-value">{{item.system.capacity}}</span></span>{{/if}}
                        </div>
                        <div class="item-resources-wrapper">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Resources"}}</div>
                            <div class="item-resources-summary">{{#each item.system.resources}}{{#if this.showInSummary}}<span class="resource-summary-chip"><span class="resource-chip-label">{{this.label}}</span><span class="resource-chip-value">{{this.value}}{{#if this.max}} / {{this.max}}{{/if}}</span></span>{{/if}}{{/each}}</div>
                        </div>
                        {{#if (hasAttachedMods item.system.mods)}}
                        <div class="item-mods-wrapper">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Mods"}}</div>
                            <div class="item-mods-summary">
                                {{#each (attachedMods item.system.mods) as |mod|}}
                                <span class="mod-name-chip" data-tooltip="{{mod.effectText}}">{{mod.name}}</span>
                                {{/each}}
                            </div>
                        </div>
                        {{/if}}
                        <div class="item-description-wrapper">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Description"}}</div>
                            <div class="item-description">{{{item.system.description}}}</div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

