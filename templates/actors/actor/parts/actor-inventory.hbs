                        </button>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{/with}}
                    <div class="item-summary collapsed">
                        <div class="item-stats-summary">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Stats"}}</div>
                            <span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'damageMelee1' 'overrideDamageMelee1')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'damageMelee1' 'overrideDamageMelee1'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</span><span class="stat-chip-value">{{item.system.damageMelee1}}/{{item.system.damageMelee2}}/{{item.system.damageMelee3}}</span></span>
                            {{#if item.system.attackBonus}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaAttackBonus' 'overrideAttackBonus')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaAttackBonus' 'overrideAttackBonus'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.AttackBonusAbbr"}}</span><span class="stat-chip-value">{{item.system.attackBonus}}</span></span>{{/if}}
                            {{#if item.system.defenseBonus}}<span class="stat-summary-chip{{#if (nsModTooltip item.system.mods 'deltaDefenseBonus' 'overrideDefenseBonus')}} stat-chip-modified{{/if}}" data-tooltip="{{nsModTooltip item.system.mods 'deltaDefenseBonus' 'overrideDefenseBonus'}}"><span class="stat-chip-label">{{localize "NEUROSHIMA.Items.Fields.DefenseBonusAbbr"}}</span><span class="stat-chip-value">{{item.system.defenseBonus}}</span></span>{{/if}}
                        </div>
                        <div class="item-resources-wrapper">
                            <div class="summary-section-header">{{localize "NEUROSHIMA.Summary.Resources"}}</div>
                            <div class="item-resources-summary">{{#each item.system.resources}}{{#if this.showInSummary}}<span class="resource-summary-chip"><span class="resource-chip-label">{{this.label}}</span><span class="resource-chip-value">{{this.value}}{{#if this.max}} / {{this.max}}{{/if}}</span></span>{{/if}}{{/each}}</div>
                        </div>
