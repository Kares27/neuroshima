                        </div>
                    </div>
                    {{#with (lookup ../itemManualScripts item.id) as |scripts|}}
                    {{#if scripts}}
                    <div class="sheet-effect-buttons">
                        {{#each scripts as |ms|}}
                        <button class="manual-script-btn" data-action="invokeItemScript"
                               data-item-id="{{ms.itemId}}" data-effect-id="{{ms.effectId}}"
                               data-script-index="{{ms.scriptIndex}}"
                               title="{{ms.effectName}}" type="button">
                            <i class="fas fa-play"></i> {{ms.label}}
                        </button>
                        {{/each}}
                    </div>
                    {{/if}}
                    {{/with}}
