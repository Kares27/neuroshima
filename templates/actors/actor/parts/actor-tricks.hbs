<section class="tab tricks {{tabs.tricks.cssClass}}" data-group="primary" data-tab="tricks" data-application-part="tricks">
    <section class="inventory-section">
        <div class="section-header">
            <span>{{localize "NEUROSHIMA.Tabs.Tricks"}}</span>
            <a class="item-control" data-action="createItem" data-type="trick" title="{{localize 'DOCUMENT.Create'}}"><i class="fas fa-plus"></i></a>
        </div>
        <div class="inventory-list trick-list">
            <div class="inventory-list-header flexrow">
                <div class="item-name flex5">{{localize "Name"}}</div>
                <div class="item-controls flex1"></div>
            </div>
            <div class="inventory-items">
                {{#each tricks as |item|}}
                <div class="item flexrow" data-item-id="{{item.id}}" data-uuid="{{item.uuid}}" draggable="true">
                    <div class="item-name flex5">
                        <div class="item-image" style="background-image: url('{{item.img}}')"></div>
                        <span class="name">{{item.name}}</span>
                    </div>
                    <div class="item-controls flex1">
                        <a class="item-control" data-action="editItem" title="{{localize 'Edit'}}"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem" title="{{localize 'Delete'}}"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                {{#with (lookup ../itemManualScripts item.id) as |scripts|}}
                {{#if scripts}}
                <div class="item-script-row" data-item-id="{{item.id}}">
                    {{#each scripts as |ms|}}
                    <a class="manual-script-btn" data-action="invokeItemScript"
                       data-item-id="{{ms.itemId}}" data-effect-id="{{ms.effectId}}"
                       data-script-index="{{ms.scriptIndex}}"
                       title="{{ms.effectName}}">
                        <i class="fas fa-play"></i> {{ms.label}}
                    </a>
                    {{/each}}
                </div>
                {{/if}}
                {{/with}}
                {{/each}}
            </div>
        </div>
    </section>
</section>
