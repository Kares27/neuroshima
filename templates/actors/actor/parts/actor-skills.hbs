<section class="tab skills {{tabs.attributes.cssClass}}" data-group="primary" data-tab="attributes" data-application-part="skills">
    <div class="skill-table" id="skills-{{actor.id}}" data-scrollable>
        <div class="skills-container">
            {{#each skillGroups as |attribute attrKey|}}
            <div class="attribute-skill-group" data-attribute="{{attrKey}}">
                <div class="attr-abbr-column clickable" data-action="rollAttribute" data-attribute="{{attrKey}}" title="{{localize "NEUROSHIMA.Actions.Roll"}}">
                    <div class="attr-abbr-wrapper">
                        <strong>{{localize attribute.abbr}}</strong>
                    </div>
                </div>
                
                <div class="specializations-column">
                    {{#each attribute.specializations as |spec specKey|}}
                    <div class="specialization-row {{#if spec.owned}}owned{{/if}}">
                        <div class="spec-name-cell">
                            <label class="spec-toggle">
                                <input type="checkbox" name="system.specializations.{{specKey}}" {{checked spec.owned}} hidden disabled>
                                <span class="spec-name">{{localize spec.label}}</span>
                            </label>
                        </div>

                        <div class="skills-horizontal-grid">
                            {{#each spec.skills as |skill|}}
                            <div class="skill-item" data-action="rollSkill" data-skill="{{skill.key}}" title="{{localize "NEUROSHIMA.Actions.Roll"}}: {{localize skill.label}}">
                                <div class="skill-input-wrapper">
                                    <input type="number"
                                           name="system.skills.{{skill.key}}.value"
                                           value="{{skill.value}}"
                                           min="0" max="20"
                                           class="skill-input">
                                    <input type="number"
                                           value="{{skill.total}}"
                                           class="skill-input skill-total-input"
                                           disabled
                                           {{#if skill.bonusTooltip}}data-tooltip="{{skill.bonusTooltip}}"{{/if}}>
                                </div>
                                {{#if skill.isKnowledge}}
                                    <div class="skill-knowledge-wrapper">
                                        <span class="skill-knowledge-label">{{#if skill.customLabel}}{{skill.customLabel}}{{else}}{{localize skill.label}}{{/if}}</span>
                                        <input type="text"
                                               name="system.skills.{{skill.key}}.label"
                                               value="{{skill.customLabel}}"
                                               placeholder="{{localize skill.label}}"
                                               class="skill-label-input">
                                        <a class="skill-knowledge-edit-btn" data-action="toggleKnowledgeEdit" data-skill="{{skill.key}}"><i class="fas fa-pen"></i></a>
                                    </div>
                                {{else}}
                                    <span class="skill-name">{{localize skill.label}}</span>
                                {{/if}}
                            </div>
                            {{/each}}
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>
