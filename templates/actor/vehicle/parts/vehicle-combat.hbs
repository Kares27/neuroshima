<section class="tab vehicle-combat-tab {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat" data-application-part="combat">
    <div class="vehicle-combat-scroll">
        <div class="vehicle-combat-top">

            {{!-- Armor Section --}}
            <section class="combat-section vehicle-armor-section">
                <div class="section-header">
                    <div class="header-title">
                        <i class="fas fa-shield-alt"></i>
                        <span>{{localize "NEUROSHIMA.Vehicle.Armor.Title"}}</span>
                    </div>
                </div>

                <div class="vehicle-armor-grid">
                    {{!-- Front --}}
                    <div class="vehicle-armor-location location-front {{#unless (index armorGrid 0).hasArmor}}empty{{/unless}}">
                        <div class="location-header">
                            <span class="location-name">{{localize "NEUROSHIMA.Vehicle.Location.Front"}}</span>
                            {{#if owner}}
                            <label class="nat-armor-weakpoint-toggle" title="{{localize 'NEUROSHIMA.WeakPoint'}}">
                                <input type="checkbox" name="system.weakPoints.front" {{#if system.weakPoints.front}}checked{{/if}}>
                                <i class="fas fa-exclamation-triangle weakpoint-icon"></i>
                            </label>
                            {{/if}}
                        </div>
                        <div class="location-armor-value">
                            {{#if (index armorGrid 0).hasArmor}}
                            <span class="armor-rating">{{(index armorGrid 0).armor}}</span>
                            {{else}}
                            <span class="armor-empty">{{localize "NEUROSHIMA.Armor.None"}}</span>
                            {{/if}}
                        </div>
                    </div>

                    {{!-- Right Side --}}
                    <div class="vehicle-armor-location location-right {{#unless (index armorGrid 3).hasArmor}}empty{{/unless}}">
                        <div class="location-header">
                            <span class="location-name">{{localize "NEUROSHIMA.Vehicle.Location.RightSide"}}</span>
                            {{#if owner}}
                            <label class="nat-armor-weakpoint-toggle" title="{{localize 'NEUROSHIMA.WeakPoint'}}">
                                <input type="checkbox" name="system.weakPoints.rightSide" {{#if system.weakPoints.rightSide}}checked{{/if}}>
                                <i class="fas fa-exclamation-triangle weakpoint-icon"></i>
                            </label>
                            {{/if}}
                        </div>
                        <div class="location-armor-value">
                            {{#if (index armorGrid 3).hasArmor}}
                            <span class="armor-rating">{{(index armorGrid 3).armor}}</span>
                            {{else}}
                            <span class="armor-empty">{{localize "NEUROSHIMA.Armor.None"}}</span>
                            {{/if}}
                        </div>
                    </div>

                    {{!-- Left Side --}}
                    <div class="vehicle-armor-location location-left {{#unless (index armorGrid 2).hasArmor}}empty{{/unless}}">
                        <div class="location-header">
                            <span class="location-name">{{localize "NEUROSHIMA.Vehicle.Location.LeftSide"}}</span>
                            {{#if owner}}
                            <label class="nat-armor-weakpoint-toggle" title="{{localize 'NEUROSHIMA.WeakPoint'}}">
                                <input type="checkbox" name="system.weakPoints.leftSide" {{#if system.weakPoints.leftSide}}checked{{/if}}>
                                <i class="fas fa-exclamation-triangle weakpoint-icon"></i>
                            </label>
                            {{/if}}
                        </div>
                        <div class="location-armor-value">
                            {{#if (index armorGrid 2).hasArmor}}
                            <span class="armor-rating">{{(index armorGrid 2).armor}}</span>
                            {{else}}
                            <span class="armor-empty">{{localize "NEUROSHIMA.Armor.None"}}</span>
                            {{/if}}
                        </div>
                    </div>

                    {{!-- Back --}}
                    <div class="vehicle-armor-location location-back {{#unless (index armorGrid 1).hasArmor}}empty{{/unless}}">
                        <div class="location-header">
                            <span class="location-name">{{localize "NEUROSHIMA.Vehicle.Location.Back"}}</span>
                            {{#if owner}}
                            <label class="nat-armor-weakpoint-toggle" title="{{localize 'NEUROSHIMA.WeakPoint'}}">
                                <input type="checkbox" name="system.weakPoints.back" {{#if system.weakPoints.back}}checked{{/if}}>
                                <i class="fas fa-exclamation-triangle weakpoint-icon"></i>
                            </label>
                            {{/if}}
                        </div>
                        <div class="location-armor-value">
                            {{#if (index armorGrid 1).hasArmor}}
                            <span class="armor-rating">{{(index armorGrid 1).armor}}</span>
                            {{else}}
                            <span class="armor-empty">{{localize "NEUROSHIMA.Armor.None"}}</span>
                            {{/if}}
                        </div>
                    </div>

                    {{!-- Bottom (spans 2 cols) --}}
                    <div class="vehicle-armor-location location-bottom span-full {{#unless (index armorGrid 4).hasArmor}}empty{{/unless}}">
                        <div class="location-header">
                            <span class="location-name">{{localize "NEUROSHIMA.Vehicle.Location.Bottom"}}</span>
                            {{#if owner}}
                            <label class="nat-armor-weakpoint-toggle" title="{{localize 'NEUROSHIMA.WeakPoint'}}">
                                <input type="checkbox" name="system.weakPoints.bottom" {{#if system.weakPoints.bottom}}checked{{/if}}>
                                <i class="fas fa-exclamation-triangle weakpoint-icon"></i>
                            </label>
                            {{/if}}
                        </div>
                        <div class="location-armor-value">
                            {{#if (index armorGrid 4).hasArmor}}
                            <span class="armor-rating">{{(index armorGrid 4).armor}}</span>
                            {{else}}
                            <span class="armor-empty">{{localize "NEUROSHIMA.Armor.None"}}</span>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </section>

            {{!-- Weapons Section --}}
            <section class="combat-section vehicle-weapons-section">
                <div class="section-header">
                    <div class="header-title">
                        <i class="fas fa-crosshairs"></i>
                        <span>{{localize "NEUROSHIMA.Vehicle.Weapons.Title"}}</span>
                    </div>
                    <div class="header-actions">
                        {{#if owner}}
                        <a class="item-control" data-action="createItem" data-type="weapon" title="{{localize 'DOCUMENT.Create'}}">
                            <i class="fas fa-plus"></i>
                        </a>
                        {{/if}}
                    </div>
                </div>

                {{#if weapons.length}}
                <div class="vehicle-weapons-list">
                    {{#each weapons}}
                    <div class="item vehicle-weapon-row {{#if equipped}}mounted{{/if}}" data-item-id="{{id}}" data-uuid="{{uuid}}">
                        <div class="weapon-mount">
                            {{#if ../owner}}
                            <a data-action="toggleEquipped" data-item-id="{{id}}" title="{{localize 'NEUROSHIMA.Vehicle.Weapons.Mounted'}}">
                                <i class="fas {{#if equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
                            </a>
                            {{/if}}
                        </div>
                        <img src="{{img}}" alt="{{name}}" width="28" height="28">
                        <span class="weapon-name clickable" data-action="editItem" data-item-id="{{id}}">{{name}}</span>
                        <div class="weapon-stats">
                            <span title="{{localize 'NEUROSHIMA.Items.Fields.Damage'}}">{{system.damage}}</span>
                        </div>
                        {{#if ../owner}}
                        <div class="item-controls">
                            {{#if equipped}}
                            <a class="item-control" data-action="rollWeapon" data-item-id="{{id}}" title="{{localize 'NEUROSHIMA.Actions.Roll'}}">
                                <i class="fas fa-dice"></i>
                            </a>
                            {{/if}}
                            <a class="item-control" data-action="editItem" data-item-id="{{id}}" title="{{localize 'NEUROSHIMA.Sheet.Edit'}}">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a class="item-control" data-action="deleteItem" data-item-id="{{id}}" title="{{localize 'DOCUMENT.Delete'}}">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <p class="empty-list">{{localize "NEUROSHIMA.Vehicle.Weapons.Empty"}}</p>
                {{/if}}
            </section>
        </div>

        {{!-- Damage Section --}}
        <section class="combat-section vehicle-damage-section">
            <div class="section-header">
                <div class="header-title">
                    <i class="fas fa-car-crash"></i>
                    <span>{{localize "NEUROSHIMA.Vehicle.Damage.Title"}}</span>
                </div>
                <div class="vehicle-efficiency-summary">
                    <span title="{{localize 'NEUROSHIMA.Vehicle.Efficiency'}}">
                        <i class="fas fa-tachometer-alt"></i> {{remainingEfficiency}} / {{system.efficiency.max}}
                    </span>
                    {{#if (gt totalAgilityPenalty 0)}}
                    <span class="agility-penalty-badge" title="{{localize 'NEUROSHIMA.Vehicle.AgilityPenaltyTotal'}}">
                        <i class="fas fa-exclamation-circle"></i> -{{totalAgilityPenalty}}%
                    </span>
                    {{/if}}
                </div>
                <div class="header-actions">
                    {{#if owner}}
                    <a class="item-control" data-action="createItem" data-type="vehicle-damage" title="{{localize 'DOCUMENT.Create'}}">
                        <i class="fas fa-plus"></i>
                    </a>
                    {{/if}}
                </div>
            </div>

            {{#if vehicleDamages.length}}
            <div class="combat-table vehicle-damage-table">
                <div class="table-header">
                    <div class="col-name">{{localize "Name"}}</div>
                    <div class="col-location">{{localize "NEUROSHIMA.Items.Fields.Location"}}</div>
                    <div class="col-type">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</div>
                    <div class="col-penalty">{{localize "NEUROSHIMA.Vehicle.Damage.EffLoss"}}</div>
                    <div class="col-controls"></div>
                </div>
                {{#each vehicleDamages}}
                <div class="table-row item {{#unless system.isActive}}inactive{{/unless}}" data-item-id="{{id}}" data-uuid="{{uuid}}" draggable="true">
                    <div class="col-name item-name clickable" data-action="editItem">
                        <img src="{{img}}" title="{{name}}" width="24" height="24"/>
                        <span>{{name}}</span>
                    </div>
                    <div class="col-location">
                        <select name="items.{{id}}.system.location">
                            {{selectOptions ../vehicleLocations selected=system.location localize=true}}
                        </select>
                    </div>
                    <div class="col-type">
                        <select name="items.{{id}}.system.damageType">
                            {{selectOptions ../vehicleDamageTypes selected=system.damageType localize=true}}
                        </select>
                    </div>
                    <div class="col-penalty">
                        <span class="eff-loss" title="{{localize 'NEUROSHIMA.Vehicle.Damage.EffLoss'}}">-{{system.efficiencyLoss}}</span>
                        {{#if system.agilityPenalty}}
                        <span class="agility-pen" title="{{localize 'NEUROSHIMA.Vehicle.AgilityPenalty'}}">/ -{{system.agilityPenalty}}%</span>
                        {{/if}}
                    </div>
                    <div class="col-controls">
                        <a class="item-control {{#unless system.isActive}}inactive{{/unless}}" data-action="toggleDamageActive" title="{{localize 'NEUROSHIMA.Items.Fields.IsActive'}}">
                            <i class="fas {{#if system.isActive}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i>
                        </a>
                        <a class="item-control" data-action="editItem" title="{{localize 'NEUROSHIMA.Sheet.Edit'}}">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a class="item-control" data-action="deleteItem" title="{{localize 'DOCUMENT.Delete'}}">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <p class="empty-list">{{localize "NEUROSHIMA.Vehicle.Damage.Empty"}}</p>
            {{/if}}
        </section>
    </div>
</section>
