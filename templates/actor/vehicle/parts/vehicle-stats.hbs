<section class="tab vehicle-stats {{tabs.stats.cssClass}}" data-group="primary" data-tab="stats" data-application-part="stats">
    <div class="vehicle-stats-grid">

        <div class="vehicle-stat-section">
            <div class="section-label">{{localize "NEUROSHIMA.Vehicle.Performance"}}</div>
            <div class="vehicle-perf-grid">
                <div class="form-group row-group">
                    <label title="{{localize 'NEUROSHIMA.Vehicle.MaxSpeed'}}">{{localize "NEUROSHIMA.Vehicle.MaxSpeedAbbr"}}</label>
                    <input type="number" name="system.maxSpeed" value="{{system.maxSpeed}}" min="0">
                    <span class="unit">km/h</span>
                </div>
                <div class="form-group row-group">
                    <label title="{{localize 'NEUROSHIMA.Vehicle.Acceleration'}}">{{localize "NEUROSHIMA.Vehicle.AccelerationAbbr"}}</label>
                    <input type="number" name="system.acceleration" value="{{system.acceleration}}" min="0">
                </div>
                <div class="form-group row-group">
                    <label title="{{localize 'NEUROSHIMA.Vehicle.Brakes'}}">{{localize "NEUROSHIMA.Vehicle.BrakesAbbr"}}</label>
                    <input type="number" name="system.brakes" value="{{system.brakes}}" min="0">
                </div>
            </div>
        </div>

    </div>
</section>
