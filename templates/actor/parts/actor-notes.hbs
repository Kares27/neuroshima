<div class="notes-tab">
  <h3>Notatki</h3>
  
  <div class="biography-section">
    <h4>Biografia postaci</h4>
    <textarea name="system.biography" rows="15" placeholder="Opisz historię i osobowość swojej postaci...">{{system.biography}}</textarea>
  </div>
  
  <div class="general-notes">
    <h4>Ogólne notatki</h4>
