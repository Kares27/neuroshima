          <div class="header-equipped">Ekw.</div>
          <div class="header-quantity">Ilość</div>
          <div class="header-weight">Waga</div>
          <div class="header-controls">
            <a class="item-control item-create" title="Dodaj pancerz" data-type="armor">
              <i class="fas fa-plus"></i>
            </a>
            <a class="section-collapse-toggle" data-section="armor" title="Zwiń/Rozwiń">
              <i class="fas fa-chevron-down"></i>
