            </div>
            <h4 class="item-name">{{item.name}}</h4>
            <div class="item-quantity" data-item-id="{{item._id}}" data-action="modify-quantity" title="LPM: +1 | PPM: -1 | Ctrl+LPM: +10 | Ctrl+PPM: -10">{{item.system.quantity}}szt</div>
            <div class="item-weight">{{item.system.weight}}kg</div>
            <div class="item-controls">
