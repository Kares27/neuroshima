            <div class="item-image">
              <img src="{{item.img}}" title="{{item.name}}" width="32" height="32"/>
            </div>
            <h4 class="item-name">{{item.name}}</h4>
            <div class="item-equipped">
              <i class="{{#if item.system.equipable}}fas fa-dot-circle{{else}}far fa-circle{{/if}}" data-item-id="{{item._id}}" data-action="toggle-equipped" title="{{#if item.system.equipable}}Założony{{else}}Nie założony{{/if}}"></i>
            </div>
            <div class="item-quantity" data-item-id="{{item._id}}" data-action="modify-quantity" title="LPM: +1 | PPM: -1 | Ctrl+LPM: +10 | Ctrl+PPM: -10">{{item.system.quantity}}szt</div>
            <div class="item-weight">{{item.system.weight}}kg</div>
            <div class="item-controls">
              <a class="item-control item-edit" title="Edytuj"><i class="fas fa-edit"></i></a>
              <a class="item-control item-delete" title="Usuń"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ol>
        
        <div class="items-list-collapsed" style="display: none;">
          {{#each armor as |item id|}}
