<div class="equipment-tab">
  <div class="equipment-sections">
    
    {{!-- Weapons Section --}}
    <div class="equipment-section" data-section="weapons">
      <div class="section-content" data-section-content="weapons">
        <div class="items-header">
          <div class="header-icon"></div>
          <div class="header-name">Broń</div>
          <div class="header-equipped">Ekw.</div>
          <div class="header-quantity">Ilość</div>
          <div class="header-weight">Waga</div>
          <div class="header-controls">
            <a class="item-control item-create-weapon" title="Dodaj broń">
              <i class="fas fa-plus"></i>
            </a>
            <a class="section-collapse-toggle" data-section="weapons" title="Zwiń/Rozwiń">
              <i class="fas fa-chevron-down"></i>
            </a>
          </div>
        </div>
        
        <ol class="items-list">
          {{#each weapons as |item id|}}
            <li class="item" data-item-id="{{item._id}}">
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="32" height="32"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-equipped">
                <i class="{{#if item.system.equipable}}fas fa-dot-circle{{else}}far fa-circle{{/if}}" data-item-id="{{item._id}}" data-action="toggle-equipped" title="{{#if item.system.equipable}}Wyekwipowany{{else}}Nie wyekwipowany{{/if}}"></i>
              </div>
              <div class="item-quantity" data-item-id="{{item._id}}" data-action="modify-quantity" title="LPM: +1 | PPM: -1 | Ctrl+LPM: +10 | Ctrl+PPM: -10">{{item.system.quantity}}szt</div>
              <div class="item-weight">{{item.system.weight}}kg</div>
              <div class="item-controls">
                <a class="item-control item-edit" title="Edytuj"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="Usuń"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
        
        <div class="items-list-collapsed" style="display: none;">
          {{#each weapons as |item id|}}
            <div class="item-icon-collapsed" data-item-id="{{item._id}}" title="{{item.name}}">
              <img src="{{item.img}}" width="32" height="32"/>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{!-- Armor Section --}}
    <div class="equipment-section" data-section="armor">
      <div class="section-content" data-section-content="armor">
