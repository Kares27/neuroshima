<div class="melee-view-container">
    {{#each activeMeleeDuels as |duel|}}
    <div class="active-melee-panel full-view" data-action="open-melee" data-duel-id="{{duel.id}}">
        <div class="melee-header">
            <i class="fas fa-swords"></i> {{localize "NEUROSHIMA.MeleeDuel.Active"}}
        </div>
        <div class="melee-participants">
            <div class="participant attacker">
                <img src="{{duel.attacker.img}}" title="{{duel.attacker.name}}">
                <span>{{duel.attacker.name}}</span>
            </div>
            <div class="vs">VS</div>
            <div class="participant defender">
                <img src="{{duel.defender.img}}" title="{{duel.defender.name}}">
                <span>{{duel.defender.name}}</span>
            </div>
        </div>
        <div class="melee-status">
            {{localize "NEUROSHIMA.MeleeDuel.ClickToOpen"}}
        </div>
    </div>
    {{/each}}

    {{#each pendingMeleeDuels as |pending|}}
    <div class="pending-melee-panel full-view" data-pending-id="{{pending.id}}">
        <div class="melee-header">
            <i class="fas fa-hourglass-half"></i> {{localize "NEUROSHIMA.MeleeDuel.Pending"}}
            <div class="pending-controls">
                <a class="action-btn dismiss" data-action="dismiss-melee" data-pending-id="{{pending.id}}" title="{{localize 'NEUROSHIMA.Actions.Dismiss'}}">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </div>
        <div class="melee-participants">
            <span>{{pending.attackerName}}</span>
            <i class="fas fa-arrow-right"></i>
            <span>{{pending.defenderName}}</span>
        </div>
        <div class="melee-instruction">
            {{localize "NEUROSHIMA.MeleeDuel.WaitingForDefender"}}
        </div>
        {{#if (or @root.user.isGM (eq @root.user.character.id pending.defenderId))}}
        <button type="button" class="join-melee-btn" data-action="join-melee" data-pending-id="{{pending.id}}">
            <i class="fas fa-check"></i> {{localize "NEUROSHIMA.MeleeOpposed.Join"}}
        </button>
        {{/if}}
    </div>
    {{/each}}

    {{#if (and (not activeMeleeDuels.length) (not pendingMeleeDuels.length))}}
    <div class="no-melee-active">
        <i class="fas fa-info-circle"></i>
        <p>{{localize "NEUROSHIMA.MeleeDuel.NoActiveFights"}}</p>
        <small>{{localize "NEUROSHIMA.MeleeDuel.StartInstruction"}}</small>
    </div>
    {{/if}}
</div>
