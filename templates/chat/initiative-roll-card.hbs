<div class="neuroshima roll-card {{rollMode}} initiative-card {{#if isTooltip}}tooltip-mode{{/if}}">
    <header class="roll-header">
        <div class="actor-image-container" 
            {{#if (and showTooltip (not isTooltip))}}
            data-tooltip="{{neuroshimaRollTooltip this}}"
            data-tooltip-direction="LEFT"
            {{/if}}>
            <img src="{{actorImg}}" width="32" height="32" />
        </div>
        <div class="header-details">
            {{#if isDebug}}<span class="debug-tag">[DEBUG]</span> {{/if}}
            {{#if isReroll}}<span class="reroll-tag">[{{localize "NEUROSHIMA.Roll.Reroll"}}]</span> {{/if}}
            <span class="initiative-tag">{{localize "NEUROSHIMA.MeleeOpposed.InitiativeTest"}}</span>
        </div>
    </header>
    <hr class="dotted-hr">

    <div class="dice-results-grid">
        {{#each modifiedResults}}
            <div class="die-result {{#if this.ignored}}ignored{{/if}}">
                <span class="die-label">D{{add @index 1}} = </span>
                <div class="die-square-container">
                    <span class="die-square original {{#if this.isNat1}}nat-1{{/if}} {{#if this.isNat20}}nat-20{{/if}}">
                        {{this.original}}
                    </span>
                    {{#if (gt ../skill 0)}}
                        <i class="fas fa-long-arrow-alt-right"></i> 
                        <span class="die-square modified {{#if this.isSuccess}}success{{else}}failure{{/if}}">
                            {{this.modified}}
                        </span>
                    {{/if}}
                </div>
            </div>
        {{/each}}
    </div>

    <hr class="dotted-hr">
    <footer class="roll-outcome">
        <div class="outcome-item">
            <span class="outcome-label">{{localize "NEUROSHIMA.Roll.SuccessPoints"}}:</span>
            <span class="outcome-value success">{{successPoints}}</span>
        </div>
    </footer>

    {{#if meleeTargets.length}}
    <hr class="dotted-hr">
    <div class="melee-targets-section">
        <div class="targets-header">{{localize "NEUROSHIMA.MeleeOpposed.Participants"}}:</div>
        <div class="targets-list">
            {{#each meleeTargets}}
            <div class="target-item" data-actor-id="{{this.id}}">
                <img src="{{this.img}}" width="24" height="24" />
                <span>{{this.name}}</span>
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}
</div>