<div class="neuroshima-roll melee-weapon-roll">
  <span class="melee-info-wrapper">
    <i class="fas fa-info-circle melee-info-icon"></i>
    <div class="melee-info-tooltip">
      {{tooltipContent}}
    </div>
  </span>
  
  <div class="roll-header">
    <h3>{{difficultyName}} test na {{weaponName}} - {{actionTypeText}}</h3>
    <div class="roll-subtitle">{{skillName}} ({{attributeName}})</div>
  </div>
  
  <div class="roll-details">
    <div class="dice-container">
      {{{diceDisplay}}}
    </div>
    
    <div class="roll-result {{hitClass}}">
      <div class="result-text">{{hitText}}</div>
      {{#if bulletsHit}}
        {{#if (gt bulletsHit 0)}}
          <div class="result-successes">Trafienia: {{bulletsHit}}/{{bulletsFired}} kul ({{successPoints}} PS)</div>
        {{else}}
          <div class="result-successes">Sukcesy: {{successes}}/{{totalDice}}</div>
        {{/if}}
      {{else}}
        <div class="result-successes">Sukcesy: {{successes}}/{{totalDice}}</div>
      {{/if}}
      {{#if hitLocation}}
        <div class="result-location">Lokacja: {{hitLocation.name}}</div>
      {{/if}}
      {{#if damageType}}
        <div class="result-damage">Obrażenia: {{damageTypeName}}{{#if (gt bulletsHit 1)}} (×{{bulletsHit}}){{/if}}</div>
      {{/if}}
    </div>
  </div>
  
  {{#if damageType}}
  <div class="damage-application-section" data-damage-section="true">
    <div class="damage-application-header">
      <div class="header-content">
        <h4><i class="fas fa-crosshairs"></i> Aplikuj Obrażenie</h4>
      </div>
      {{#if isGM}}
      <button class="damage-collapse-toggle" data-toggle="damage-application" title="Zwiń/Rozwiń">
        <i class="fas fa-chevron-up"></i>
      </button>
      {{/if}}
    </div>
    
    <div class="damage-application-content-wrapper">
    <div class="damage-application-tabs">
      <button class="damage-tab-button active" data-tab="targeted">
        <i class="fas fa-bullseye"></i> Targeted
      </button>
      <button class="damage-tab-button" data-tab="selected">
        <i class="fas fa-hand-pointer"></i> Selected
      </button>
    </div>
    
    <div class="damage-application-content">
      <!-- Targeted Tab -->
      <div class="damage-tab-content active" data-tab-content="targeted">
        {{#if targetedActor}}
          <div class="target-info">
            <img src="{{targetedActor.img}}" alt="{{targetedActor.name}}" class="target-avatar"/>
            <div class="target-name">{{targetedActor.name}}</div>
          </div>
        {{else}}
          <div class="no-target-message">
            <i class="fas fa-exclamation-triangle"></i>
            <p>Brak targetowanego celu w momencie ataku</p>
          </div>
        {{/if}}
      </div>
      
      <!-- Selected Tab -->
      <div class="damage-tab-content" data-tab-content="selected">
        <div class="selected-targets-list">
          <!-- Dynamically populated via JavaScript with selected tokens -->
          <div class="no-target-message">
            <i class="fas fa-exclamation-triangle"></i>
            <p>Brak wyselekcjonowanych tokenów na planszy</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="damage-application-actions">
      <button class="apply-damage-button" 
              data-attacker-id="{{attackerId}}"
              data-weapon-name="{{weaponName}}"
              data-damage-type="{{damageType}}"
              data-location="{{location}}"
              data-hit-count="{{hitCount}}"
              data-penetration="{{penetration}}"
              data-targeted-actor-id="{{targetedActorId}}">
        <i class="fas fa-plus-circle"></i> Aplikuj Obrażenie
      </button>
      <div class="apply-damage-message" style="display: none;"></div>
    </div>
    </div>
  </div>
  {{/if}}
</div>