<div class="neuroshima beast-engage-target-card">

  <header class="engage-target-header">
    <img src="{{attackerImg}}" width="36" height="36" alt="">
    <div class="engage-target-title">
      <span class="attacker-name">{{attackerName}}</span>
      <span class="engage-label">{{localize "NEUROSHIMA.BeastAction.EngageTarget.Title"}}</span>
    </div>
  </header>

  <hr class="dotted-hr">

  <p class="engage-target-hint">{{localize "NEUROSHIMA.BeastAction.EngageTarget.Hint"}}</p>

  <footer class="engage-target-actions">
    <button type="button" class="btn btn-primary" data-action="engageBeastTarget">
      <i class="fas fa-crosshairs"></i> {{localize "NEUROSHIMA.BeastAction.EngageTarget.Button"}}
    </button>
  </footer>

</div>
