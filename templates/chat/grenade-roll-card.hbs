<div class="neuroshima roll-card grenade-roll-card"
    data-actor-id="{{actorId}}"
    data-weapon-id="{{weaponId}}">

    <header class="roll-header">
        <div class="actor-image-container"
            data-tooltip="{{neuroshimaRollTooltip this}}"
            data-tooltip-direction="LEFT">
            <img src="{{actorImg}}" width="32" height="32" />
        </div>
        <div class="header-details">
            <div class="weapon-title">{{label}}</div>
            <div class="test-info">
                {{localize difficultyLabel}}
                {{localize "NEUROSHIMA.Roll.ClosedTest"}}
                {{localize "NEUROSHIMA.Roll.On"}} {{localize "NEUROSHIMA.Grenade.ThrowRoll"}}
            </div>
        </div>
    </header>

    <hr class="dotted-hr">

    <div class="dice-results-grid">
        {{#each modifiedResults}}
            <div class="die-result {{#if this.ignored}}ignored{{/if}}">
                <span class="die-label">D{{add @index 1}} = </span>
                <div class="die-square-container">
                    <span class="die-square original {{#if this.isNat1}}nat-1{{/if}} {{#if this.isNat20}}nat-20{{/if}}">
                        {{this.original}}
                    </span>
                    {{#if (gt ../skill 0)}}
                        <i class="fas fa-long-arrow-alt-right"></i>
                        <span class="die-square modified {{#if this.isSuccess}}success{{else}}failure{{/if}}">
                            {{this.modified}}
                        </span>
                    {{/if}}
                </div>
            </div>
        {{/each}}
    </div>

    <hr class="dotted-hr">

    {{#unless isSuccess}}
    <div class="grenade-deviation-result">
        <div class="detail-item"
            data-tooltip="{{localize 'NEUROSHIMA.Grenade.DeviationTooltip'}}"
            data-tooltip-direction="UP">
            <span class="label">{{localize "NEUROSHIMA.Grenade.Deviation"}}:</span>
            <span class="value"><strong>{{deviationMetres}}m</strong></span>
        </div>
    </div>
    {{/unless}}

    {{#if templateRadius}}
    <div class="grenade-place-template-row">
        <button class="grenade-place-template-btn" data-action="placeGrenadeTemplate"
                data-radius="{{templateRadius}}"
                data-actor-id="{{actorId}}"
                data-tooltip="{{localize 'NEUROSHIMA.Grenade.PlaceTemplateTooltip'}}"
                data-tooltip-direction="UP">
            <i class="fas fa-bullseye"></i>
            {{localize "NEUROSHIMA.Grenade.PlaceTemplate"}}
        </button>
    </div>
    {{/if}}

    <footer class="roll-outcome {{#if isSuccess}}success{{else}}failure{{/if}}">
        <div class="outcome-item roll-status">
            <span class="label">{{localize "NEUROSHIMA.Roll.SuccessPointsAbbr"}}:</span>
            <span class="value"><strong>{{successCount}}</strong></span>
        </div>
        <div class="outcome-item">
            <span class="value {{#if isSuccess}}success{{else}}failure{{/if}}">
                <strong>{{#if isCritSuccess}}{{localize "NEUROSHIMA.Roll.CritSuccess"}}{{else if isSuccess}}{{localize "NEUROSHIMA.Roll.Success"}}{{else if isCritFailure}}{{localize "NEUROSHIMA.Roll.CritFailure"}}{{else}}{{localize "NEUROSHIMA.Roll.Failure"}}{{/if}}</strong>
            </span>
        </div>
    </footer>

    {{#if blastResults}}
    <div class="grenade-blast-inline-section apply-damage-section">
        <div class="damage-application-header collapsible-toggle">
            <span>{{localize "NEUROSHIMA.Roll.ApplyDamage"}} ({{blastResults.length}})</span>
            <i class="fas fa-chevron-down"></i>
        </div>
        <div class="damage-application-content grenade-blast-inline-content" style="display: none;">
            <div class="grenade-blast-table-wrapper">
                <table class="grenade-blast-targets-table">
                    <thead>
                        <tr>
                            <th>{{localize "NEUROSHIMA.Grenade.BlastTarget"}}</th>
                            <th>m.</th>
                            <th>{{localize "NEUROSHIMA.Grenade.BlastDamageAbbr"}}</th>
                            <th>{{localize "NEUROSHIMA.Roll.Location"}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each blastResults}}
                        <tr>
                            <td>{{this.tokenName}}</td>
                            <td>{{this.distanceM}}</td>
                            <td>
                                {{#if (and this.damage (ne this.damage "none"))}}
                                <strong>{{damageLabel this.damage}}</strong>
                                {{#if this.knockdown}}<span class="grenade-knockdown-tag" data-tooltip="{{localize 'NEUROSHIMA.Grenade.Zone.KnockdownTooltip'}}" data-tooltip-direction="UP">⊕</span>{{/if}}
                                {{else}}-{{/if}}
                            </td>
                            <td>
                                {{#if this.locationKey}}
                                <span data-tooltip="{{locationFull this.locationKey}}" data-tooltip-direction="UP">{{locationAbbrev this.locationKey}}</span>
                                {{else}}-{{/if}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            <div class="damage-actions">
                <button class="apply-damage-button {{#if damageApplied}}applied{{/if}}" data-action="applyGrenadeDamage" {{#if damageApplied}}disabled{{/if}}>
                    <i class="fas fa-hand-holding-medical"></i>
                    {{#if damageApplied}}✓ {{localize "NEUROSHIMA.Grenade.BlastDamageApplied"}}{{else}}{{localize "NEUROSHIMA.Actions.Damage"}}{{/if}}
                </button>
            </div>
        </div>
    </div>
    {{/if}}

</div>
