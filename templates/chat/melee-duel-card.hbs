<div class="melee-duel-card neuroshima">

  <div class="mdc-header">
    <div class="mdc-fighter{{#if isOwnerAttacker}} mdc-fighter--init{{/if}}">
      <img src="{{attackerImg}}" width="40" height="40" alt="{{attackerName}}">
      <span class="mdc-name">{{attackerName}}</span>
    </div>
    <div class="mdc-vs">
      {{#if canSwapInit}}
      <button type="button" class="mdc-vs-swords" data-action="duelSwapInit" title="{{localize 'NEUROSHIMA.MeleeDuel.DuelSwapInitiative'}}">
        <i class="fas fa-swords"></i>
      </button>
      {{else}}
      <i class="fas fa-swords"></i>
      {{/if}}
    </div>
    <div class="mdc-fighter{{#unless isOwnerAttacker}} mdc-fighter--init{{/unless}}">
      <img src="{{defenderImg}}" width="40" height="40" alt="{{defenderName}}">
      <span class="mdc-name">{{defenderName}}</span>
    </div>
  </div>

  <div class="duel-segments-row">
    {{#each segmentDots}}
    <div class="duel-seg-dot {{dotClass}}">{{segNum}}</div>
    {{/each}}
  </div>

  <div class="mdc-phase-banner">{{phaseBanner}}</div>

  <div class="duel-pools">
    <div class="duel-pool">
      <div class="duel-pool-label">{{attackerName}}</div>
      <div class="duel-pool-chips">
        {{#each attackDiceChips}}
          {{#unless isHidden}}
          {{#if isUsed}}
            <span class="die-chip die-chip-mvc is-used {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isCommitted}}
            <span class="die-chip die-chip-mvc mvc-die-selected {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isClickable}}
            <button type="button"
              class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}"
              data-pool="attacker"
              data-die-idx="{{idx}}">{{value}}</button>
          {{else}}
            <span class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}" style="opacity:0.4">{{value}}</span>
          {{/if}}
          {{/unless}}
        {{/each}}
      </div>
    </div>
    <div class="duel-pool">
      <div class="duel-pool-label">{{defenderName}}</div>
      <div class="duel-pool-chips">
        {{#each defenseDiceChips}}
          {{#unless isHidden}}
          {{#if isUsed}}
            <span class="die-chip die-chip-mvc is-used {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isCommitted}}
            <span class="die-chip die-chip-mvc mvc-die-selected {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isClickable}}
            <button type="button"
              class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}"
              data-pool="defender"
              data-die-idx="{{idx}}">{{value}}</button>
          {{else}}
            <span class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}" style="opacity:0.4">{{value}}</span>
          {{/if}}
          {{/unless}}
        {{/each}}
      </div>
    </div>
  </div>

  {{#if isOwnerTurn}}
  <div class="mdc-controls" data-melee-owner="{{ownerActorUuid}}">
    {{#if damageTiers}}
    <div class="mdc-damage-tiers">
      <span>1→<strong>{{damageTiers.d}}</strong></span>
      <span>2→<strong>{{damageTiers.l}}</strong></span>
      <span>3→<strong>{{damageTiers.k}}</strong></span>
    </div>
    {{/if}}
    <div class="mdc-action-list">
      {{#if ownerBeastActions}}
        <div class="mdc-beast-queue-section">
          <div class="mdc-beast-budget-row">
            <i class="fas fa-paw"></i>
            <span class="mdc-beast-budget-remaining">0</span>/<span class="mdc-beast-budget-total">0</span>✦
          </div>
          {{#each ownerBeastActions}}
          <div class="mdc-beast-action-entry" data-action-id="{{id}}" data-cost="{{successCost}}">
            <button type="button" class="mdc-beast-pick-btn" data-action-id="{{id}}" data-cost="{{successCost}}" disabled>
              <span class="mac-icon"><img src="{{img}}" style="width:22px;height:22px;border-radius:3px;object-fit:cover" alt=""></span>
              <span class="mac-body">
                <span class="mac-label">{{name}}</span>
                <span class="mac-hint"><span class="mbc-cost-badge">{{successCost}}✦</span>{{#if damage}}<span class="mbc-dmg-badge"> → {{damage}}</span>{{/if}}</span>
              </span>
            </button>
            <span class="mdc-beast-qty-badge" data-action-id="{{id}}" style="display:none">
              <span class="mdc-beast-qty-val" data-action-id="{{id}}">0</span>×
              <button type="button" class="mdc-beast-undo-btn" data-action-id="{{id}}">↩</button>
            </span>
          </div>
          {{/each}}
          <button type="button" class="mdc-beast-confirm-btn is-disabled" data-pool="{{ownerPool}}" disabled>
            <span class="mac-icon"><i class="fas fa-check"></i></span>
            <span class="mac-body">
              <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionAttack"}}</span>
            </span>
          </button>
        </div>
        <button type="button" class="mdc-action-choice is-disabled"
            data-action-type="exit" data-pool="{{ownerPool}}"
            data-exact-dice="1" disabled>
          <span class="mac-icon"><i class="fas fa-door-open"></i></span>
          <span class="mac-body">
            <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionExit"}}</span>
            <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintExit"}}</span>
          </span>
        </button>
        <button type="button" class="mdc-action-choice is-disabled"
            data-action-type="nonCombat" data-pool="{{ownerPool}}"
            data-min-dice="1" data-max-dice="3" data-need-success="true" disabled>
          <span class="mac-icon"><i class="fas fa-comment-alt"></i></span>
          <span class="mac-body">
            <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionNonCombat"}}</span>
            <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintNonCombat"}}</span>
          </span>
        </button>
      {{else}}
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="attack" data-pool="{{ownerPool}}"
          data-min-dice="1" data-max-dice="3" disabled>
        <span class="mac-icon"><i class="fas fa-swords"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionAttack"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintAttack"}}</span>
        </span>
      </button>
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="exit" data-pool="{{ownerPool}}"
          data-exact-dice="1" disabled>
        <span class="mac-icon"><i class="fas fa-door-open"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionExit"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintExit"}}</span>
        </span>
      </button>
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="nonCombat" data-pool="{{ownerPool}}"
          data-min-dice="1" data-max-dice="3" data-need-success="true" disabled>
        <span class="mac-icon"><i class="fas fa-comment-alt"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelActionNonCombat"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintNonCombat"}}</span>
        </span>
      </button>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{#if isResponderTurn}}
  <div class="mdc-controls" data-melee-owner="{{responderActorUuid}}">
    <div class="mdc-action-list">
      {{#if ownerDeclaredAttack}}
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="defend" data-pool="{{responderPool}}"
          data-exact-dice="{{responderExactDice}}" disabled>
        <span class="mac-icon"><i class="fas fa-shield-alt"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelDefend"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintDefend"}}</span>
        </span>
      </button>
      {{#unless isGradCios}}
      <button type="button" class="mdc-action-choice mdc-action-choice--danger"
          data-action-type="flee" data-pool="{{responderPool}}"
          data-no-dice="true">
        <span class="mac-icon"><i class="fas fa-running"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelFlee"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintFlee"}}</span>
        </span>
      </button>
      {{/unless}}
      {{/if}}
      {{#if ownerDeclaredExit}}
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="blockExit" data-pool="{{responderPool}}"
          data-exact-dice="1" disabled>
        <span class="mac-icon"><i class="fas fa-hand-paper"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelBlockExit"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintBlockExit"}}</span>
        </span>
      </button>
      <button type="button" class="mdc-action-choice mdc-action-choice--passive"
          data-action-type="allowExit" data-pool="{{responderPool}}"
          data-no-dice="true">
        <span class="mac-icon"><i class="fas fa-door-open"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelAllowExit"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintAllowExit"}}</span>
        </span>
      </button>
      {{/if}}
      {{#if ownerDeclaredNonCombat}}
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="seizeInit" data-pool="{{responderPool}}"
          data-exact-dice="{{committedOwnerCount}}" disabled>
        <span class="mac-icon"><i class="fas fa-bolt"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelSeizeInit"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintSeizeInit"}}</span>
        </span>
      </button>
      <button type="button" class="mdc-action-choice is-disabled"
          data-action-type="interrupt" data-pool="{{responderPool}}"
          data-min-dice="1" disabled>
        <span class="mac-icon"><i class="fas fa-times-circle"></i></span>
        <span class="mac-body">
          <span class="mac-label">{{localize "NEUROSHIMA.MeleeDuel.DuelInterrupt"}}</span>
          <span class="mac-hint">{{localize "NEUROSHIMA.MeleeDuel.DuelHintInterrupt"}}</span>
        </span>
      </button>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{#if resolvedSegs.length}}
  <div class="duel-resolved-segments">
    {{#each resolvedSegs}}
    <div class="duel-seg-line">
      <span class="seg-num">S{{segNum}}</span>
      <span class="die-vals">{{attackVal}} vs {{defenseVal}}</span>
      <span class="seg-outcome {{outcome}}">{{outcomeLabel}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if isDone}}
  {{#if hasHits}}
  <div class="apply-damage-section opposed-apply-row" data-gm-only="true">
    <div class="hits-detail">
      {{#each hits}}
      <span class="hit-badge">{{tier}}k: {{damageType}}</span>
      {{/each}}
    </div>
    <button type="button" class="btn btn-primary apply-damage-button apply-opposed-damage-btn" data-action="applyOpposedDamage">
      <i class="fas fa-hand-holding-medical"></i> {{localize "NEUROSHIMA.MeleeDuel.DuelApplyDamage"}}
    </button>
  </div>
  {{/if}}
  {{/if}}

</div>
