<div class="melee-duel-card neuroshima">

  <div class="mdc-header">
    <div class="mdc-fighter{{#if isOwnerAttacker}} mdc-fighter--init{{/if}}">
      <img src="{{attackerImg}}" width="32" height="32" alt="{{attackerName}}">
      <span class="mdc-name">{{attackerName}}</span>
      {{#if isOwnerAttacker}}<i class="fas fa-bolt mdc-init-icon" title="{{localize 'NEUROSHIMA.MeleeDuel.InitiativeOwner'}}"></i>{{/if}}
    </div>
    <div class="mdc-vs"><i class="fas fa-swords"></i></div>
    <div class="mdc-fighter mdc-fighter--right{{#unless isOwnerAttacker}} mdc-fighter--init{{/unless}}">
      {{#unless isOwnerAttacker}}<i class="fas fa-bolt mdc-init-icon" title="{{localize 'NEUROSHIMA.MeleeDuel.InitiativeOwner'}}"></i>{{/unless}}
      <span class="mdc-name">{{defenderName}}</span>
      <img src="{{defenderImg}}" width="32" height="32" alt="{{defenderName}}">
    </div>
  </div>

  <div class="duel-segments-row">
    {{#each segmentDots}}
    <div class="duel-seg-dot {{dotClass}}">{{segNum}}</div>
    {{/each}}
  </div>

  <div class="mdc-phase-banner">{{phaseBanner}}</div>

  <div class="duel-pools">
    <div class="duel-pool">
      <div class="duel-pool-label">{{attackerName}}</div>
      <div class="duel-pool-chips">
        {{#each attackDiceChips}}
          {{#if isUsed}}
            <span class="die-chip die-chip-mvc is-used {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isCommitted}}
            <span class="die-chip die-chip-mvc mvc-die-selected {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isClickable}}
            <button type="button"
              class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}"
              data-pool="attacker"
              data-die-idx="{{idx}}">{{value}}</button>
          {{else}}
            <span class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}" style="opacity:0.4">{{value}}</span>
          {{/if}}
        {{/each}}
      </div>
    </div>
    <div class="duel-pool">
      <div class="duel-pool-label">{{defenderName}}</div>
      <div class="duel-pool-chips">
        {{#each defenseDiceChips}}
          {{#if isUsed}}
            <span class="die-chip die-chip-mvc is-used {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isCommitted}}
            <span class="die-chip die-chip-mvc mvc-die-selected {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}">{{value}}</span>
          {{else if isClickable}}
            <button type="button"
              class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}"
              data-pool="defender"
              data-die-idx="{{idx}}">{{value}}</button>
          {{else}}
            <span class="die-chip die-chip-mvc {{#if isSuccess}}is-success{{else}}is-failure{{/if}}{{#if isNat20}} is-nat20{{/if}}" style="opacity:0.4">{{value}}</span>
          {{/if}}
        {{/each}}
      </div>
    </div>
  </div>

  {{#if isOwnerTurn}}
  <div class="mdc-controls" data-melee-owner="{{ownerActorUuid}}">
    <div class="mdc-hint">
      <i class="fas fa-hand-pointer"></i>
      {{localize "NEUROSHIMA.MeleeDuel.SelectedCount"}}: <strong class="mdc-selected-count">0</strong>
      {{#if damageTiers}}&nbsp;|&nbsp; 1→{{damageTiers.d}} 2→{{damageTiers.l}} 3→{{damageTiers.k}}{{/if}}
    </div>
    <button type="button"
      class="action-btn action-btn--attack is-disabled"
      data-duel-action="confirmBatch"
      data-pool="{{ownerPool}}"
      disabled>
      <i class="fas fa-check"></i> <span class="mdc-confirm-label">{{confirmOwnerLabel}}</span>
    </button>
  </div>
  {{/if}}

  {{#if isResponderTurn}}
  <div class="mdc-controls" data-melee-owner="{{responderActorUuid}}">
    <div class="mdc-hint">
      {{localize "NEUROSHIMA.MeleeDuel.SelectedCount"}}:
      <strong class="mdc-selected-count">0</strong> / <strong>{{committedOwnerCount}}</strong>
    </div>
    <button type="button"
      class="action-btn action-btn--defense is-disabled"
      data-duel-action="confirmBatch"
      data-pool="{{responderPool}}"
      data-needed="{{committedOwnerCount}}"
      disabled>
      <i class="fas fa-shield-alt"></i> {{localize "NEUROSHIMA.MeleeDuel.DuelConfirmDefense"}}
    </button>
  </div>
  {{/if}}

  {{#if resolvedSegs.length}}
  <div class="duel-resolved-segments">
    {{#each resolvedSegs}}
    <div class="duel-seg-line">
      <span class="seg-num">S{{segNum}}</span>
      <span class="die-vals">{{attackVal}} vs {{defenseVal}}</span>
      <span class="seg-outcome {{outcome}}">{{outcomeLabel}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if isDone}}
  {{#if hasHits}}
  <div class="apply-damage-section opposed-apply-row" data-gm-only="true">
    <div class="hits-detail">
      {{#each hits}}
      <span class="hit-badge">{{tier}}k: {{damageType}}</span>
      {{/each}}
    </div>
    <button type="button" class="apply-damage-button apply-opposed-damage-btn" data-action="applyOpposedDamage">
      <i class="fas fa-hand-holding-medical"></i> {{localize "NEUROSHIMA.MeleeDuel.DuelApplyDamage"}}
    </button>
  </div>
  {{/if}}
  {{/if}}

</div>
