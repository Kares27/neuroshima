{{#if missing}}
<div class="bas-missing">
    <p class="notification error">{{localize "NEUROSHIMA.BeastAction.Sheet.ActivityNotFound"}}</p>
</div>
{{else}}
<div class="bas-root">

    {{!-- ===== Sheet Header ===== --}}
    <header class="sheet-header">
        <div class="profile-container">
            <img class="profile-img{{#if editable}} bas-icon-editable{{/if}}"
                 src="{{#if activity.img}}{{activity.img}}{{else}}icons/svg/combat.svg{{/if}}"
                 data-action="{{#if editable}}pickIcon{{/if}}"
                 title="{{#if editable}}{{localize 'NEUROSHIMA.BeastAction.Sheet.PickIcon'}}{{/if}}"
                 alt=""/>
            <input type="hidden" name="img" value="{{activity.img}}"/>
        </div>
        <div class="header-details">
            <div class="item-subtitle">
                <h4 class="item-type">
                    {{#if isSegmentItem}}{{localize "NEUROSHIMA.BeastSegment.Activities"}}{{else}}{{localize "NEUROSHIMA.BeastAction.Sheet.Title"}}{{/if}}
                </h4>
            </div>
            <div class="item-name-row">
                <h1>
                    <input name="name" type="text" value="{{activity.name}}"
                           placeholder="{{localize 'NEUROSHIMA.BeastAction.ActivityName'}}"
                           {{#unless editable}}disabled{{/unless}}/>
                </h1>
            </div>
        </div>
    </header>

    {{!-- ===== Tab navigation ===== --}}
    <nav class="sheet-tabs tabs" data-group="sheet">
        <a class="item {{tabs.activation.cssClass}}" data-action="tab" data-group="sheet" data-tab="activation">
            <i class="fas fa-bolt"></i> {{localize tabs.activation.label}}
        </a>
        <a class="item {{tabs.description.cssClass}}" data-action="tab" data-group="sheet" data-tab="description">
            <i class="fas fa-scroll"></i> {{localize tabs.description.label}}
        </a>
        <a class="item {{tabs.effects.cssClass}}" data-action="tab" data-group="sheet" data-tab="effects">
            <i class="fas fa-star"></i> {{localize tabs.effects.label}}
            {{#if linkedEffects.length}}<em class="bas-tab-badge">{{linkedEffects.length}}</em>{{/if}}
        </a>
    </nav>

    {{!-- ===== Sheet body ===== --}}
    <section class="sheet-body">

        {{!-- ===== Activation tab ===== --}}
        <section class="tab bas-tab {{tabs.activation.cssClass}}" data-group="sheet" data-tab="activation">

            {{!-- Activation fieldset: typ akcji + koszt --}}
            {{#if isSegmentItem}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastAction.CostTypeLabel"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.TypeLabel"}}</label>
                        <select name="actionType" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions actionTypes selected=activity.actionType localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-cost">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.SegmentCost"}}</label>
                        <input type="number" name="segmentCost" value="{{activity.segmentCost}}"
                               min="1" max="3" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
                {{#if isAttack}}
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.WeaponType"}}</label>
                        <select name="weaponType" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions weaponTypes selected=activity.weaponType localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Attribute"}}</label>
                        <select name="attribute" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions attributes selected=activity.attribute labelAttr="label" localize=true}}
                        </select>
                    </div>
                </div>
                {{/if}}
                <p class="bas-cost-hint">
                    <i class="fas fa-info-circle"></i>
                    {{#if isAttack}}{{localize "NEUROSHIMA.BeastAction.Sheet.HintSegment"}}{{else}}{{localize "NEUROSHIMA.BeastAction.Sheet.HintAction"}}{{/if}}
                </p>
            </fieldset>
            {{else}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastAction.CostTypeLabel"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.TypeLabel"}}</label>
                        <select name="actionType" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions actionTypes selected=activity.actionType localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-cost">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.SuccessCost"}}</label>
                        <input type="number" name="successCost" value="{{activity.successCost}}"
                               min="0" max="3" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
                <p class="bas-cost-hint">
                    <i class="fas fa-info-circle"></i> {{localize "NEUROSHIMA.BeastAction.Sheet.HintSuccess"}}
                </p>
            </fieldset>
            {{/if}}

            {{!-- ===== Melee: pełne statystyki broni białej ===== --}}
            {{#if isMelee}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastSegment.CombatStats"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.AttackBonus'}}">{{localize "NEUROSHIMA.Items.Fields.AttackBonusAbbr"}}</label>
                        <input type="number" name="attackBonus" value="{{activity.attackBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.DefenseBonus'}}">{{localize "NEUROSHIMA.Items.Fields.DefenseBonusAbbr"}}</label>
                        <input type="number" name="defenseBonus" value="{{activity.defenseBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.WeaponModifier'}}">{{localize "NEUROSHIMA.Items.Fields.WeaponModifierAbbr"}}</label>
                        <input type="number" name="weaponModifier" value="{{activity.weaponModifier}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.RequiredBuild"}}</label>
                        <input type="number" name="requiredBuild" value="{{activity.requiredBuild}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</label>
                        <select name="damageCategory" {{#unless editable}}disabled{{/unless}}>
                            {{#each damageCategories as |cat key|}}
                            <option value="{{key}}" {{#if (eq ../activity.damageCategory key)}}selected{{/if}}>{{localize cat.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="bas-row bas-damage-tiers">
                    <div class="bas-field-group bas-tier-col">
                        <label class="bas-label bas-tier-label">1</label>
                        <select name="damage1" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions damageTypes selected=activity.damage1 localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-tier-col">
                        <label class="bas-label bas-tier-label">2</label>
                        <select name="damage2" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions damageTypes selected=activity.damage2 localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-tier-col">
                        <label class="bas-label bas-tier-label">3</label>
                        <select name="damage3" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions damageTypes selected=activity.damage3 localize=true}}
                        </select>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label">PP</label>
                        <input type="number" name="piercing" value="{{activity.piercing}}"
                               min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            {{/if}}

            {{!-- ===== Ranged ===== --}}
            {{#if isRanged}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastSegment.CombatStats"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.WeaponSubtype"}}</label>
                        <select name="rangedSubtype" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions weaponSubtypesRanged selected=activity.rangedSubtype localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.FireRate'}}">{{localize "NEUROSHIMA.Items.Fields.FireRateAbbr"}}</label>
                        <input type="number" name="fireRate" value="{{activity.fireRate}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.AttackBonus'}}">{{localize "NEUROSHIMA.Items.Fields.AttackBonusAbbr"}}</label>
                        <input type="number" name="attackBonus" value="{{activity.attackBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.DefenseBonus'}}">{{localize "NEUROSHIMA.Items.Fields.DefenseBonusAbbr"}}</label>
                        <input type="number" name="defenseBonus" value="{{activity.defenseBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.WeaponModifier'}}">{{localize "NEUROSHIMA.Items.Fields.WeaponModifierAbbr"}}</label>
                        <input type="number" name="weaponModifier" value="{{activity.weaponModifier}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.RequiredBuild"}}</label>
                        <input type="number" name="requiredBuild" value="{{activity.requiredBuild}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</label>
                        <select name="damageCategory" {{#unless editable}}disabled{{/unless}}>
                            {{#each damageCategories as |cat key|}}
                            <option value="{{key}}" {{#if (eq ../activity.damageCategory key)}}selected{{/if}}>{{localize cat.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                        <select name="damage" {{#unless editable}}disabled{{/unless}}>
                            <option value="">—</option>
                            {{selectOptions damageTypes selected=activity.damage localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label">PP</label>
                        <input type="number" name="piercing" value="{{activity.piercing}}"
                               min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.Range"}}</label>
                        <input type="number" name="range" value="{{activity.range}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Jamming"}}</label>
                        <input type="number" name="jamming" value="{{activity.jamming}}"
                               min="1" max="20" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            {{/if}}

            {{!-- ===== Thrown ===== --}}
            {{#if isThrown}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastSegment.CombatStats"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.AttackBonus'}}">{{localize "NEUROSHIMA.Items.Fields.AttackBonusAbbr"}}</label>
                        <input type="number" name="attackBonus" value="{{activity.attackBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.DefenseBonus'}}">{{localize "NEUROSHIMA.Items.Fields.DefenseBonusAbbr"}}</label>
                        <input type="number" name="defenseBonus" value="{{activity.defenseBonus}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label" title="{{localize 'NEUROSHIMA.Items.Fields.WeaponModifier'}}">{{localize "NEUROSHIMA.Items.Fields.WeaponModifierAbbr"}}</label>
                        <input type="number" name="weaponModifier" value="{{activity.weaponModifier}}"
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.RequiredBuild"}}</label>
                        <input type="number" name="requiredBuild" value="{{activity.requiredBuild}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</label>
                        <select name="damageCategory" {{#unless editable}}disabled{{/unless}}>
                            {{#each damageCategories as |cat key|}}
                            <option value="{{key}}" {{#if (eq ../activity.damageCategory key)}}selected{{/if}}>{{localize cat.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                        <select name="damage" {{#unless editable}}disabled{{/unless}}>
                            <option value="">—</option>
                            {{selectOptions damageTypes selected=activity.damage localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label">PP</label>
                        <input type="number" name="piercing" value="{{activity.piercing}}"
                               min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.Range"}}</label>
                        <input type="number" name="range" value="{{activity.range}}"
                               min="0" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            {{/if}}

            {{!-- ===== Grenade ===== --}}
            {{#if isGrenade}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastSegment.CombatStats"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Attribute"}}</label>
                        <select name="attribute" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions attributes selected=activity.attribute labelAttr="label" localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</label>
                        <select name="damageCategory" {{#unless editable}}disabled{{/unless}}>
                            {{#each damageCategories as |cat key|}}
                            <option value="{{key}}" {{#if (eq ../activity.damageCategory key)}}selected{{/if}}>{{localize cat.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Grenade.FreeThrowDistance"}}</label>
                        <input type="number" name="freeThrowDistance" value="{{activity.freeThrowDistance}}"
                               min="1" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                    <div class="bas-field-group" style="flex:0 0 auto; align-items:center; flex-direction:row; gap:6px;">
                        <label class="bas-label" style="margin:0;">{{localize "NEUROSHIMA.Grenade.UseBuildBonus"}}</label>
                        <input type="checkbox" name="useBuildBonus" {{#if activity.useBuildBonus}}checked{{/if}}
                               {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.Grenade.BlastZones"}}</legend>
                {{#if editable}}
                <div class="bas-row" style="justify-content:flex-end; margin-bottom:4px;">
                    <a data-action="addBlastZone" class="bas-btn-small">
                        <i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Grenade.AddZone"}}
                    </a>
                </div>
                {{/if}}
                {{#if activity.blastZones.length}}
                <div class="blast-zone-list">
                    <div class="blast-zone-header flexrow">
                        <span class="blast-zone-col-radius">{{localize "NEUROSHIMA.Grenade.Zone.Radius"}}</span>
                        <span class="blast-zone-col-damage">{{localize "NEUROSHIMA.Grenade.Zone.Damage"}}</span>
                        <span class="blast-zone-col-shrapnel">{{localize "NEUROSHIMA.Grenade.Zone.Shrapnel"}}</span>
                        <span class="blast-zone-col-knockdown">{{localize "NEUROSHIMA.Grenade.Zone.Knockdown"}}</span>
                        <span class="blast-zone-col-actions"></span>
                    </div>
                    {{#each activity.blastZones as |zone|}}
                    <div class="blast-zone-row flexrow" data-zone-index="{{@index}}">
                        <div class="blast-zone-col-radius">
                            <input type="number" name="blastZones.{{@index}}.radius"
                                   value="{{zone.radius}}" min="1" {{#unless ../editable}}disabled{{/unless}}/>
                        </div>
                        <div class="blast-zone-col-damage">
                            <select name="blastZones.{{@index}}.damage" {{#unless ../editable}}disabled{{/unless}}>
                                {{selectOptions ../blastDamageTypes selected=zone.damage localize=true}}
                            </select>
                        </div>
                        <div class="blast-zone-col-shrapnel">
                            <input type="number" name="blastZones.{{@index}}.shrapnel"
                                   value="{{zone.shrapnel}}" min="0" {{#unless ../editable}}disabled{{/unless}}/>
                        </div>
                        <div class="blast-zone-col-knockdown">
                            <input type="checkbox" name="blastZones.{{@index}}.knockdown"
                                   {{#if zone.knockdown}}checked{{/if}} {{#unless ../editable}}disabled{{/unless}}/>
                        </div>
                        <div class="blast-zone-col-actions">
                            {{#if ../editable}}
                            <a data-action="removeBlastZone" data-zone-index="{{@index}}" title="{{localize 'NEUROSHIMA.Grenade.RemoveZone'}}">
                                <i class="fas fa-trash"></i>
                            </a>
                            {{/if}}
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <p class="hint" style="text-align:center; opacity:0.6;">{{localize "NEUROSHIMA.Grenade.NoZones"}}</p>
                {{/if}}
            </fieldset>
            {{/if}}

            {{!-- ===== Damage: beast-action (success-based, single damage) ===== --}}
            {{#unless isSegmentItem}}
            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                        <select name="damage" {{#unless editable}}disabled{{/unless}}>
                            <option value="">—</option>
                            {{selectOptions damageTypes selected=activity.damage localize=true}}
                        </select>
                    </div>
                    <div class="bas-field-group bas-field-narrow">
                        <label class="bas-label">PP</label>
                        <input type="number" name="piercing" value="{{activity.piercing}}"
                               min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                    </div>
                </div>
            </fieldset>
            {{/unless}}

        </section>

        {{!-- ===== Description tab ===== --}}
        <section class="tab bas-tab {{tabs.description.cssClass}}" data-group="sheet" data-tab="description">

            <div class="bas-field-group bas-gmnote-group">
                <label class="bas-label bas-gmnote-label">
                    <i class="fas fa-scroll"></i>
                    {{localize "NEUROSHIMA.BeastActivity.GmNote"}}
                </label>
                <prose-mirror
                    name="gmNote"
                    value="{{activity.gmNote}}"
                    document-uuid="{{item.uuid}}"
                    toggled
                    {{#unless editable}}disabled{{/unless}}>
                    {{{enrichedGmNote}}}
                </prose-mirror>
            </div>

        </section>

        {{!-- ===== Effects tab ===== --}}
        <section class="tab bas-tab {{tabs.effects.cssClass}}" data-group="sheet" data-tab="effects">

            <fieldset class="bas-fieldset">
                <legend>{{localize "NEUROSHIMA.BeastAction.Sheet.RequiredTest"}}</legend>

                <div class="bas-row bas-row-check">
                    <label class="bas-label bas-label-check">
                        <input type="checkbox" name="testRequired" {{#if activity.testRequired}}checked{{/if}}
                               {{#unless editable}}disabled{{/unless}}/>
                        {{localize "NEUROSHIMA.BeastAction.Sheet.TestRequired"}}
                    </label>
                </div>

                {{#if activity.testRequired}}
                <div class="bas-row">
                    <div class="bas-field-group">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.Sheet.TestType"}}</label>
                        <select name="testType" {{#unless editable}}disabled{{/unless}}>
                            <option value="attribute" {{#if (eq activity.testType "attribute")}}selected{{/if}}>
                                {{localize "NEUROSHIMA.BeastAction.Sheet.TestTypeAttribute"}}
                            </option>
                            <option value="skill" {{#if (eq activity.testType "skill")}}selected{{/if}}>
                                {{localize "NEUROSHIMA.BeastAction.Sheet.TestTypeSkill"}}
                            </option>
                        </select>
                    </div>
                </div>
                <div class="bas-row bas-open-test-row">
                    <span class="bas-open-test-label">{{localize "NEUROSHIMA.BeastAction.Sheet.TestIsOpen"}}</span>
                    <div class="bas-open-test-right">
                        <input type="checkbox" name="testIsOpen" {{#if activity.testIsOpen}}checked{{/if}}
                               {{#unless editable}}disabled{{/unless}}/>
                        <span class="bas-open-test-sp-label">SP</span>
                        <input type="number" name="testSuccesses" value="{{activity.testSuccesses}}"
                               min="1" max="10"
                               {{#unless editable}}disabled{{else}}{{#unless activity.testIsOpen}}disabled{{/unless}}{{/unless}}/>
                    </div>
                </div>
                <div class="bas-row">
                    <div class="bas-field-group bas-field-full">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.Sheet.TestKey"}}</label>
                        {{#if (eq activity.testType "attribute")}}
                        <select name="testKey" {{#unless editable}}disabled{{/unless}}>
                            {{selectOptions testAttributes selected=activity.testKey localize=true}}
                        </select>
                        {{else}}
                        <select name="testKey" {{#unless editable}}disabled{{/unless}}>
                            {{#each testSkillGroups}}
                            <optgroup label="{{this.attrLabel}}">
                                {{#each this.skills}}
                                <option value="{{this.key}}" {{#if (eq this.key ../../../activity.testKey)}}selected{{/if}}>{{this.label}}</option>
                                {{/each}}
                            </optgroup>
                            {{/each}}
                        </select>
                        {{/if}}
                    </div>
                </div>
                {{#if (eq activity.testType "skill")}}
                <div class="bas-row">
                    <div class="bas-field-group bas-field-full">
                        <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.Sheet.TestAttributeOverride"}}</label>
                        <select name="testAttributeOverride" {{#unless editable}}disabled{{/unless}}>
                            <option value="" {{#unless activity.testAttributeOverride}}selected{{/unless}}>
                                {{localize "NEUROSHIMA.BeastAction.Sheet.TestAttributeOverrideNone"}}
                            </option>
                            {{selectOptions testAttributes selected=activity.testAttributeOverride localize=true}}
                        </select>
                    </div>
                </div>
                {{/if}}
                {{/if}}
            </fieldset>

            <fieldset class="bas-fieldset">
                <legend>
                    {{#if activity.testRequired}}
                        {{localize "NEUROSHIMA.BeastAction.Sheet.SuccessEffects"}}
                    {{else}}
                        {{localize "NEUROSHIMA.BeastAction.Sheet.LinkedEffects"}}
                    {{/if}}
                    {{#if editable}}
                    <a class="bas-add-btn" data-action="addEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.AddEffect'}}">
                        <i class="fas fa-plus"></i>
                    </a>
                    {{/if}}
                </legend>

                {{#each linkedEffects}}
                <div class="bas-effect-row" data-effect-id="{{this.id}}">
                    <img class="bas-effect-icon" src="{{this.icon}}" alt="" width="18" height="18"/>
                    <span class="bas-effect-name{{#if this.disabled}} bas-disabled{{/if}}">{{this.name}}</span>
                    <span class="bas-effect-duration">{{this.durationLabel}}</span>
                    <span class="bas-effect-controls">
                        <a data-action="editEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.Sheet.Edit'}}"><i class="fas fa-pen"></i></a>
                        {{#if @root.editable}}
                        <a data-action="removeEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.RemoveEffect'}}"><i class="fas fa-unlink"></i></a>
                        {{/if}}
                    </span>
                </div>
                {{else}}
                <p class="bas-empty-hint">{{localize "NEUROSHIMA.BeastAction.Sheet.NoEffects"}}</p>
                {{/each}}

                {{#if editable}}{{#if unlinkedEffects.length}}
                <div class="bas-link-row">
                    <select class="bas-link-select" data-link-select>
                        <option value="">{{localize "NEUROSHIMA.BeastAction.Sheet.SelectEffect"}}</option>
                        {{#each unlinkedEffects}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                    <a class="bas-link-btn" data-action="linkSelectedEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.LinkEffect'}}">
                        <i class="fas fa-link"></i>
                    </a>
                </div>
                {{/if}}{{/if}}
            </fieldset>

            {{#if activity.testRequired}}
            <fieldset class="bas-fieldset bas-fieldset-failure">
                <legend>
                    {{localize "NEUROSHIMA.BeastAction.Sheet.FailureEffects"}}
                    {{#if editable}}
                    <a class="bas-add-btn" data-action="addFailureEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.AddFailureEffect'}}">
                        <i class="fas fa-plus"></i>
                    </a>
                    {{/if}}
                </legend>

                {{#each linkedFailureEffects}}
                <div class="bas-effect-row" data-effect-id="{{this.id}}">
                    <img class="bas-effect-icon" src="{{this.icon}}" alt="" width="18" height="18"/>
                    <span class="bas-effect-name{{#if this.disabled}} bas-disabled{{/if}}">{{this.name}}</span>
                    <span class="bas-effect-duration">{{this.durationLabel}}</span>
                    <span class="bas-effect-controls">
                        <a data-action="editEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.Sheet.Edit'}}"><i class="fas fa-pen"></i></a>
                        {{#if @root.editable}}
                        <a data-action="removeFailureEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.RemoveEffect'}}"><i class="fas fa-unlink"></i></a>
                        {{/if}}
                    </span>
                </div>
                {{else}}
                <p class="bas-empty-hint">{{localize "NEUROSHIMA.BeastAction.Sheet.NoEffects"}}</p>
                {{/each}}

                {{#if editable}}{{#if unlinkedEffects.length}}
                <div class="bas-link-row">
                    <select class="bas-link-select" data-failure-link-select>
                        <option value="">{{localize "NEUROSHIMA.BeastAction.Sheet.SelectEffect"}}</option>
                        {{#each unlinkedEffects}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                    <a class="bas-link-btn" data-action="linkSelectedFailureEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.LinkEffect'}}">
                        <i class="fas fa-link"></i>
                    </a>
                </div>
                {{/if}}{{/if}}
            </fieldset>
            {{/if}}

        </section>

    </section>
</div>
{{/if}}
