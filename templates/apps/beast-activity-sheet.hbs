{{#if missing}}
<div class="bas-missing">
    <p class="notification error">{{localize "NEUROSHIMA.BeastAction.Sheet.ActivityNotFound"}}</p>
</div>
{{else}}
<div class="bas-content">

    {{!-- Tab navigation --}}
    <nav class="bas-tabs tabs" data-group="sheet">
        <a class="bas-tab-btn {{tabs.identity.cssClass}}"   data-action="tab" data-group="sheet" data-tab="identity">
            <i class="fas fa-id-card"></i>
            {{localize tabs.identity.label}}
        </a>
        <a class="bas-tab-btn {{tabs.activation.cssClass}}" data-action="tab" data-group="sheet" data-tab="activation">
            <i class="fas fa-bolt"></i>
            {{localize tabs.activation.label}}
        </a>
        <a class="bas-tab-btn {{tabs.effects.cssClass}}"    data-action="tab" data-group="sheet" data-tab="effects">
            <i class="fas fa-star"></i>
            {{localize tabs.effects.label}}
            {{#if linkedEffects.length}}<em class="bas-tab-badge">{{linkedEffects.length}}</em>{{/if}}
        </a>
    </nav>

    {{!-- ===== Identity ===== --}}
    <section class="tab bas-tab {{tabs.identity.cssClass}}" data-group="sheet" data-tab="identity">

        {{!-- Icon + Name hero row --}}
        <div class="bas-identity-hero">
            <div class="bas-icon-wrap{{#if editable}} bas-icon-editable{{/if}}" data-action="{{#if editable}}pickIcon{{/if}}"
                 title="{{#if editable}}{{localize 'NEUROSHIMA.BeastAction.Sheet.PickIcon'}}{{/if}}">
                <img class="bas-activity-icon" src="{{#if activity.img}}{{activity.img}}{{else}}icons/svg/combat.svg{{/if}}" alt=""/>
                {{#if editable}}<div class="bas-icon-overlay"><i class="fas fa-camera"></i></div>{{/if}}
            </div>
            <div class="bas-hero-fields">
                <input class="bas-name-input" type="text" name="name" value="{{activity.name}}"
                       placeholder="{{localize 'NEUROSHIMA.BeastAction.ActivityName'}}"
                       {{#unless editable}}disabled{{/unless}}/>
                <input type="hidden" name="img" value="{{activity.img}}"/>
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.TypeLabel"}}</label>
                    <input type="text" name="actionType" value="{{activity.actionType}}"
                           placeholder="Atak"
                           {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </div>

        <div class="bas-field-group bas-summary-group">
            <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.Summary"}}</label>
            <input type="text" name="summary" value="{{activity.summary}}"
                   placeholder="{{localize 'NEUROSHIMA.BeastActivity.SummaryPlaceholder'}}"
                   {{#unless editable}}disabled{{/unless}}/>
        </div>

    </section>

    {{!-- ===== Activation ===== --}}
    <section class="tab bas-tab {{tabs.activation.cssClass}}" data-group="sheet" data-tab="activation">

        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.BeastAction.CostTypeLabel"}}</legend>

            {{!-- Cost --}}
            <div class="bas-row">
                {{#if isSegmentItem}}
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.SegmentCost"}}</label>
                    <input type="number" name="segmentCost" value="{{activity.segmentCost}}"
                           min="1" max="3" {{#unless editable}}disabled{{/unless}}/>
                </div>
                {{else}}
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastAction.SuccessCost"}}</label>
                    <input type="number" name="successCost" value="{{activity.successCost}}"
                           min="0" max="3" {{#unless editable}}disabled{{/unless}}/>
                </div>
                {{/if}}
            </div>

            {{!-- Weapon Type + Attribute (segment only) --}}
            {{#if isSegmentItem}}
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.WeaponType"}}</label>
                    <select name="weaponType" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions weaponTypes selected=activity.weaponType localize=true}}
                    </select>
                </div>
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Attribute"}}</label>
                    <select name="attribute" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions attributes selected=activity.attribute labelAttr="label" localize=true}}
                    </select>
                </div>
            </div>
            {{/if}}

            <p class="bas-cost-hint">
                {{#if isSegmentItem}}
                    <i class="fas fa-info-circle"></i> {{localize "NEUROSHIMA.BeastAction.Sheet.HintSegment"}}
                {{else}}
                    <i class="fas fa-info-circle"></i> {{localize "NEUROSHIMA.BeastAction.Sheet.HintSuccess"}}
                {{/if}}
            </p>
        </fieldset>

        {{!-- ===== Damage: Melee (3 tiers) ===== --}}
        {{#if isMelee}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
            <div class="bas-row bas-damage-tiers">
                <div class="bas-field-group bas-tier-col">
                    <label class="bas-label bas-tier-label">1</label>
                    <select name="damage1" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions damageTypes selected=activity.damage1 localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-tier-col">
                    <label class="bas-label bas-tier-label">2</label>
                    <select name="damage2" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions damageTypes selected=activity.damage2 localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-tier-col">
                    <label class="bas-label bas-tier-label">3</label>
                    <select name="damage3" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions damageTypes selected=activity.damage3 localize=true}}
                    </select>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">PP</label>
                    <input type="number" name="piercing" value="{{activity.piercing}}"
                           min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>
        {{/if}}

        {{!-- ===== Damage: Ranged / Thrown / Grenade (single + range + jamming) ===== --}}
        {{#if isRanged}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                    <select name="damage" {{#unless editable}}disabled{{/unless}}>
                        <option value="">—</option>
                        {{selectOptions damageTypes selected=activity.damage localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">PP</label>
                    <input type="number" name="piercing" value="{{activity.piercing}}"
                           min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.Range"}}</label>
                    <input type="number" name="range" value="{{activity.range}}"
                           min="0" {{#unless editable}}disabled{{/unless}}/>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Jamming"}}</label>
                    <input type="number" name="jamming" value="{{activity.jamming}}"
                           min="1" max="20" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>
        {{/if}}

        {{#if isThrown}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                    <select name="damage" {{#unless editable}}disabled{{/unless}}>
                        <option value="">—</option>
                        {{selectOptions damageTypes selected=activity.damage localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">PP</label>
                    <input type="number" name="piercing" value="{{activity.piercing}}"
                           min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.Range"}}</label>
                    <input type="number" name="range" value="{{activity.range}}"
                           min="0" {{#unless editable}}disabled{{/unless}}/>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Jamming"}}</label>
                    <input type="number" name="jamming" value="{{activity.jamming}}"
                           min="1" max="20" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>
        {{/if}}

        {{#if isGrenade}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                    <select name="damage" {{#unless editable}}disabled{{/unless}}>
                        <option value="">—</option>
                        {{selectOptions damageTypes selected=activity.damage localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">PP</label>
                    <input type="number" name="piercing" value="{{activity.piercing}}"
                           min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastSegment.Range"}}</label>
                    <input type="number" name="range" value="{{activity.range}}"
                           min="0" {{#unless editable}}disabled{{/unless}}/>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Jamming"}}</label>
                    <input type="number" name="jamming" value="{{activity.jamming}}"
                           min="1" max="20" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>
        {{/if}}

        {{!-- ===== Damage: beast-action (success-based, single damage) ===== --}}
        {{#unless isSegmentItem}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                    <select name="damage" {{#unless editable}}disabled{{/unless}}>
                        <option value="">—</option>
                        {{selectOptions damageTypes selected=activity.damage localize=true}}
                    </select>
                </div>
                <div class="bas-field-group bas-field-narrow">
                    <label class="bas-label">PP</label>
                    <input type="number" name="piercing" value="{{activity.piercing}}"
                           min="0" max="10" {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>
        {{/unless}}

        {{!-- ===== Targeting ===== --}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.BeastActivity.Targeting"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.TargetModeLabel"}}</label>
                    <select name="targetMode" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions targetModes selected=activity.targetMode localize=true}}
                    </select>
                </div>
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.DefensePolicyLabel"}}</label>
                    <select name="defensePolicy" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions defensePolicies selected=activity.defensePolicy localize=true}}
                    </select>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group bas-field-checkbox">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.RequiresHit"}}</label>
                    <input type="checkbox" name="requiresHit" {{#if activity.requiresHit}}checked{{/if}} {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>

    </section>

    {{!-- ===== Effects ===== --}}
    <section class="tab bas-tab {{tabs.effects.cssClass}}" data-group="sheet" data-tab="effects">

        <fieldset class="bas-fieldset">
            <legend>
                {{localize "NEUROSHIMA.BeastAction.Sheet.LinkedEffects"}}
                {{#if editable}}
                <a class="bas-add-btn" data-action="addEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.AddEffect'}}">
                    <i class="fas fa-plus"></i>
                </a>
                {{/if}}
            </legend>

            {{#each linkedEffects}}
            <div class="bas-effect-row" data-effect-id="{{this.id}}">
                <img class="bas-effect-icon" src="{{this.icon}}" alt="" width="18" height="18"/>
                <span class="bas-effect-name{{#if this.disabled}} bas-disabled{{/if}}">{{this.name}}</span>
                <span class="bas-effect-duration">{{this.durationLabel}}</span>
                <span class="bas-effect-controls">
                    <a data-action="editEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.Sheet.Edit'}}"><i class="fas fa-pen"></i></a>
                    {{#if @root.editable}}
                    <a data-action="removeEffect" data-effect-id="{{this.id}}" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.RemoveEffect'}}"><i class="fas fa-unlink"></i></a>
                    {{/if}}
                </span>
            </div>
            {{else}}
            <p class="bas-empty-hint">{{localize "NEUROSHIMA.BeastAction.Sheet.NoEffects"}}</p>
            {{/each}}

            {{#if editable}}{{#if unlinkedEffects.length}}
            <div class="bas-link-row">
                <select class="bas-link-select" data-link-select>
                    <option value="">{{localize "NEUROSHIMA.BeastAction.Sheet.SelectEffect"}}</option>
                    {{#each unlinkedEffects}}
                    <option value="{{this.id}}">{{this.name}}</option>
                    {{/each}}
                </select>
                <a class="bas-link-btn" data-action="linkSelectedEffect" title="{{localize 'NEUROSHIMA.BeastAction.Sheet.LinkEffect'}}">
                    <i class="fas fa-link"></i>
                </a>
            </div>
            {{/if}}{{/if}}
        </fieldset>

        {{!-- ===== Effect Application Policy ===== --}}
        <fieldset class="bas-fieldset">
            <legend>{{localize "NEUROSHIMA.BeastActivity.EffectPolicy"}}</legend>
            <div class="bas-row">
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.EffectTargetLabel"}}</label>
                    <select name="effectTarget" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions effectTargets selected=activity.effectTarget localize=true}}
                    </select>
                </div>
                <div class="bas-field-group">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.EffectTimingLabel"}}</label>
                    <select name="effectTiming" {{#unless editable}}disabled{{/unless}}>
                        {{selectOptions effectTimings selected=activity.effectTiming localize=true}}
                    </select>
                </div>
            </div>
            <div class="bas-row">
                <div class="bas-field-group bas-field-checkbox">
                    <label class="bas-label">{{localize "NEUROSHIMA.BeastActivity.ApplyEffectsAutomatically"}}</label>
                    <input type="checkbox" name="applyEffectsAutomatically" {{#if activity.applyEffectsAutomatically}}checked{{/if}} {{#unless editable}}disabled{{/unless}}/>
                </div>
            </div>
        </fieldset>

    </section>
</div>
{{/if}}
