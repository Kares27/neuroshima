<footer class="melee-tracker-footer">
    <div class="segment-tracker">
        <div class="segment-info">
            {{localize "NEUROSHIMA.MeleeOpposed.Segment"}} {{currentSegment}} / 3
        </div>

        <div class="action-summary">
            {{#if (eq phase PHASES.INITIATIVE)}}
                <div class="waiting-msg">{{localize "NEUROSHIMA.MeleeOpposed.RollInitiative"}}</div>
                <div class="ready-buttons">
                    <button type="button" class="ready-btn {{#if attacker.initiativeRoll}}active{{/if}}" 
                            data-action="rollInitiative" data-role="attacker" {{#if (or (not isAttacker) attacker.initiativeRoll)}}disabled{{/if}}>
                        {{#if attacker.initiativeRoll}}<i class="fas fa-check"></i> {{attacker.initiativeRoll}} SP{{else}}{{localize "NEUROSHIMA.Actions.Roll"}} ({{attacker.name}}){{/if}}
                    </button>
                    <button type="button" class="ready-btn {{#if defender.initiativeRoll}}active{{/if}}" 
                            data-action="rollInitiative" data-role="defender" {{#if (or (not isDefender) (or (not defender.actorUuid) defender.initiativeRoll))}}disabled{{/if}}>
                        {{#if defender.initiativeRoll}}<i class="fas fa-check"></i> {{defender.initiativeRoll}} SP{{else}}{{localize "NEUROSHIMA.Actions.Roll"}} ({{defender.name}}){{/if}}
                    </button>
                </div>
            {{/if}}

            {{#if (eq phase PHASES.POOL_ROLL)}}
                <div class="waiting-msg">{{localize "NEUROSHIMA.MeleeOpposed.Roll3k20Pool"}}</div>
                <div class="ready-buttons">
                    <button type="button" class="ready-btn {{#if attackerDice}}active{{/if}}" 
                            data-action="rollPool" data-role="attacker" {{#if (or (not isAttacker) attackerDice)}}disabled{{/if}}>
                        {{#if attackerDice}}<i class="fas fa-check"></i> {{attacker.name}}{{else}}{{localize "NEUROSHIMA.Actions.Roll"}} ({{attacker.name}}){{/if}}
                    </button>
                    <button type="button" class="ready-btn {{#if defenderDice}}active{{/if}}" 
                            data-action="rollPool" data-role="defender" {{#if (or (not isDefender) defenderDice)}}disabled{{/if}}>
                        {{#if defenderDice}}<i class="fas fa-check"></i> {{defender.name}}{{else}}{{localize "NEUROSHIMA.Actions.Roll"}} ({{defender.name}}){{/if}}
                    </button>
                </div>
            {{/if}}

            {{#if (eq phase PHASES.MODIFICATION)}}
                <div class="waiting-msg">{{localize "NEUROSHIMA.MeleeOpposed.WaitingForReady"}}</div>
                <div class="ready-buttons">
                    <button type="button" class="ready-btn {{#if attacker.ready}}active{{/if}}" 
                            data-action="toggleReady" data-role="attacker" {{#if (not isAttacker)}}disabled{{/if}}>
                        {{#if attacker.ready}}<i class="fas fa-check"></i>{{/if}} {{attacker.name}} {{localize "NEUROSHIMA.MeleeOpposed.Ready"}}
                    </button>
                    <button type="button" class="ready-btn {{#if defender.ready}}active{{/if}}" 
                            data-action="toggleReady" data-role="defender" {{#if (not isDefender)}}disabled{{/if}}>
                        {{#if defender.ready}}<i class="fas fa-check"></i>{{/if}} {{defender.name}} {{localize "NEUROSHIMA.MeleeOpposed.Ready"}}
                    </button>
                </div>
            {{/if}}

            {{#if (eq phase PHASES.SEGMENTS)}}
                <div class="current-action">
                    {{#if currentAction}}
                        <strong>{{currentAction.sideName}}</strong> {{localize "NEUROSHIMA.MeleeOpposed.Declares"}} 
                        <strong>{{localize (concat "NEUROSHIMA.MeleeOpposed.Actions." (capitalize currentAction.type))}}</strong>
                        ({{currentAction.power}}s)
                    {{else}}
                        {{localize (concat "NEUROSHIMA.MeleeOpposed.TurnOf." (capitalize initiative))}}
                    {{/if}}
                </div>
                
                <div class="action-buttons">
                    {{#if isMyTurn}}
                        {{#if (and (eq initiative 'attacker') isAttacker (not currentAction))}}
                            <button type="button" data-action="declareAction" data-role="attacker" data-type="attack">{{localize "NEUROSHIMA.Actions.Attack"}}</button>
                            <button type="button" data-action="declareAction" data-role="attacker" data-type="pass">{{localize "NEUROSHIMA.Actions.Pass"}}</button>
                        {{/if}}
                        {{#if (and (eq initiative 'defender') isDefender (not currentAction))}}
                            <button type="button" data-action="declareAction" data-role="defender" data-type="attack">{{localize "NEUROSHIMA.Actions.Attack"}}</button>
                            <button type="button" data-action="declareAction" data-role="defender" data-type="pass">{{localize "NEUROSHIMA.Actions.Pass"}}</button>
                        {{/if}}

                        {{#if (and currentAction (not (eq currentAction.side 'attacker')) isAttacker)}}
                            <button type="button" data-action="respondAction" data-response="defend">{{localize "NEUROSHIMA.Actions.Defense"}}</button>
                            <button type="button" data-action="respondAction" data-response="ignore">{{localize "NEUROSHIMA.Actions.Ignore"}}</button>
                        {{/if}}
                        {{#if (and currentAction (not (eq currentAction.side 'defender')) isDefender)}}
                            <button type="button" data-action="respondAction" data-response="defend">{{localize "NEUROSHIMA.Actions.Defense"}}</button>
                            <button type="button" data-action="respondAction" data-response="ignore">{{localize "NEUROSHIMA.Actions.Ignore"}}</button>
                        {{/if}}
                    {{else}}
                        <div class="waiting-turn-msg">
                            {{#if (and (eq phase PHASES.SEGMENTS) currentAction)}}
                                {{localize "NEUROSHIMA.MeleeOpposed.WaitingForDefense"}}
                            {{else}}
                                {{localize "NEUROSHIMA.MeleeOpposed.WaitingForOpponent"}}
                            {{/if}}
                        </div>
                    {{/if}}
                </div>
            {{/if}}

            {{#if (eq phase PHASES.RESOLVED)}}
                <div class="result-msg">{{resultMsg}}</div>
                <button type="button" class="next-turn-btn" data-action="nextTurn">
                    {{localize "NEUROSHIMA.MeleeOpposed.NextTurn"}}
                </button>
            {{/if}}
        </div>
    </div>
</footer>
