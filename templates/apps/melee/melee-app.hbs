<div class="melee-app-shell">
    {{!-- 1. Dynamic Header with Current Prompt --}}
    <header class="melee-header">
        <div class="turn-info">
            <span class="label">Tura {{turnState.turn}}</span>
            <span class="divider">|</span>
            <span class="label">Segment {{turnState.segment}}/3</span>
        </div>
        <div class="phase-prompt">
            {{currentPrompt}}
        </div>
        <div class="app-controls">
            {{#if isGM}}
                <a class="control-btn" data-action="resetTurn" title="Resetuj Turę">
                    <i class="fas fa-undo"></i>
                </a>
                <a class="control-btn danger" data-action="endEncounter" title="Zakończ Starcie">
                    <i class="fas fa-stop"></i>
                </a>
            {{/if}}
            <a class="control-btn" data-action="closeApp" title="Zamknij">
                <i class="fas fa-times"></i>
            </a>
        </div>
    </header>

    {{!-- 2. Teams Grid (Main Content) --}}
    <div class="melee-main-grid">
        {{!-- Team A Column --}}
        <section class="team-column team-a">
            <h3 class="team-title">Drużyna A</h3>
            <div class="participants-list">
                {{#each teamsData.A}}
                    {{> "systems/neuroshima/templates/apps/melee/parts/combatant-card.hbs" participant=this}}
                {{/each}}
            </div>
        </section>

        {{!-- Team B Column --}}
        <section class="team-column team-b">
            <h3 class="team-title">Drużyna B</h3>
            <div class="participants-list">
                {{#each teamsData.B}}
                    {{> "systems/neuroshima/templates/apps/melee/parts/combatant-card.hbs" participant=this}}
                {{/each}}
            </div>
        </section>
    </div>

    {{!-- 3. Bottom Log Section --}}
    <footer class="melee-footer">
        <div class="combat-log">
            {{#each log}}
                <div class="log-entry {{this.type}}">
                    <span class="timestamp">[{{this.time}}]</span>
                    <span class="message">{{this.message}}</span>
                </div>
            {{else}}
                <div class="log-empty">Brak wpisów w dzienniku walki.</div>
            {{/each}}
        </div>
        
        {{#if (and isGM (eq turnState.phase "exchange-ready"))}}
            <div class="gm-resolution-area">
                <button type="button" class="resolve-btn" data-action="resolveExchange">
                    <i class="fas fa-gavel"></i> Rozstrzygnij wymianę
                </button>
            </div>
        {{/if}}
    </footer>
</div>
