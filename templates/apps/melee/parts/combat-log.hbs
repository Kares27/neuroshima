<section class="melee-log-v2">
  <header class="log-header">
    <i class="fas fa-scroll"></i> Dziennik Walki
  </header>
  <div class="log-content">
    {{#each log}}
      <div class="log-line">
        <span class="ts">[{{turn}}.{{segment}}]</span>
        <span class="msg">{{{message}}}</span>
      </div>
    {{else}}
      <div class="log-empty">Brak wpisów.</div>
    {{/each}}
  </div>
</section>