<div class="combatant-row {{#if (eq @root.turnState.selectionTurn participant.id)}}active-turn{{/if}}" data-participant-id="{{participant.id}}">
    <div class="participant-header">
        <img src="{{participant.img}}" class="avatar" title="{{participant.name}}">
        <div class="participant-info">
            <span class="name">{{participant.name}}</span>
            <div class="stats-row">
                <span class="init-tag">Init: {{participant.initiative}}</span>
                {{#if (gt participant.pool.length 0)}}
                    <span class="maneuver-tag">{{participant.maneuver}}</span>
                    <span class="target-tag">Target: {{participant.effectiveTarget}}</span>
                {{/if}}
            </div>
        </div>
        
        {{#if (and participant.isOwner (eq participant.pool.length 0) (eq @root.turnState.phase "awaiting-pool-rolls"))}}
            <button type="button" class="roll-pool-btn" data-action="openPoolDialog" data-id="{{participant.id}}">
                <i class="fas fa-dice-d20"></i> Rzuć 3k20
            </button>
        {{/if}}
    </div>

    {{#if (gt participant.pool.length 0)}}
        <div class="dice-pool">
            {{#each participant.pool}}
                <div class="die {{#if (meleeDieSelected ../participant.selectedDiceIndices @index)}}selected{{/if}} 
                            {{#if (meleeDieUsed ../participant.usedDice @index)}}used{{/if}}
                            {{#if (eq this 1)}}nat-1{{/if}}
                            {{#if (eq this 20)}}nat-20{{/if}}
                            {{#if (le this ../participant.effectiveTarget)}}success{{else}}failure{{/if}}"
                     data-action="selectDie" 
                     data-id="{{../participant.id}}" 
                     data-index="{{@index}}">
                    {{this}}
                </div>
            {{/each}}
        </div>
    {{/if}}

    {{!-- Attack Declaration Controls --}}
    {{#if (and participant.isOwner (eq @root.turnState.phase "exchange-declaration") (eq @root.turnState.selectionTurn participant.id))}}
        <div class="declaration-controls">
            <button type="button" class="attack-btn s1" data-action="declareAttack" data-id="{{participant.id}}" data-dice="1">1s</button>
            <button type="button" class="attack-btn s2" data-action="declareAttack" data-id="{{participant.id}}" data-dice="2">2s</button>
            <button type="button" class="attack-btn s3" data-action="declareAttack" data-id="{{participant.id}}" data-dice="3">3s</button>
        </div>
    {{/if}}

    {{!-- Selection Overlays/Status --}}
    <div class="selection-status">
        {{#if (eq @root.currentExchange.attackerId participant.id)}}
            <span class="role-tag attacker">ATAKUJĄCY</span>
        {{/if}}
        {{#if (eq @root.currentExchange.defenderId participant.id)}}
            <span class="role-tag defender">OBROŃCA</span>
        {{/if}}
    </div>
</div>
