<section class="active-exchange-panel">
  <h3>{{localize "NEUROSHIMA.MeleeDuel.ActiveExchange"}}</h3>
  
  <div class="exchange-grid">
    {{#if attacker}}
      <div class="attacker-side active">
        <div class="role">{{localize "NEUROSHIMA.MeleeDuel.Attacker"}}</div>
        <img src="{{attacker.img}}" width="48" height="48" />
        <div class="name">{{attacker.name}}</div>
        <div class="action">{{localize (concat "NEUROSHIMA.MeleeDuel.Actions." currentExchange.declaredAction)}} ({{currentExchange.declaredDiceCount}}s)</div>
      </div>
    {{else}}
      <div class="attacker-side waiting">
        {{localize "NEUROSHIMA.MeleeDuel.WaitingForAttacker"}}
      </div>
    {{/if}}

    <div class="vs-label">VS</div>

    {{#if defender}}
      <div class="defender-side active">
        <div class="role">{{localize "NEUROSHIMA.MeleeDuel.Defender"}}</div>
        <img src="{{defender.img}}" width="48" height="48" />
        <div class="name">{{defender.name}}</div>
        <div class="response">{{localize "NEUROSHIMA.MeleeDuel.DefendingWith"}} {{currentExchange.defenderSelectedDice.length}} / {{currentExchange.declaredDiceCount}}</div>
      </div>
    {{else}}
      <div class="defender-side waiting">
        {{localize "NEUROSHIMA.MeleeDuel.WaitingForDefender"}}
      </div>
    {{/if}}
  </div>

  {{#if (and isGM (and currentExchange.attackerId currentExchange.defenderId))}}
    {{#if (eq currentExchange.defenderSelectedDice.length currentExchange.declaredDiceCount)}}
      <button type="button" class="resolve-btn pulse" data-action="resolveExchange">
        <i class="fas fa-gavel"></i> {{localize "NEUROSHIMA.Actions.Resolve"}}
      </button>
    {{/if}}
  {{/if}}
</section>
