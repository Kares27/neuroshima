<section class="compact-exchange-status phase-{{turnState.phase}}">
  {{#if currentExchange.attackerId}}
    <div class="exchange-summary">
      <span class="attacker-name">{{attacker.name}}</span>
      <i class="fas fa-swords"></i>
      <span class="defender-name">{{defender.name}}</span>
      <span class="action-tag">({{localize (concat "NEUROSHIMA.MeleeDuel.Actions." currentExchange.declaredAction)}} {{currentExchange.declaredDiceCount}}s)</span>
    </div>
    
    <div class="selection-progress-bar">
      <div class="progress-step {{#if (ge currentExchange.attackerSelectedDice.length currentExchange.declaredDiceCount)}}done{{/if}}">
        {{localize "NEUROSHIMA.MeleeDuel.Attacker"}} ({{currentExchange.attackerSelectedDice.length}}/{{currentExchange.declaredDiceCount}})
      </div>
      <div class="progress-step {{#if (ge currentExchange.defenderSelectedDice.length currentExchange.declaredDiceCount)}}done{{/if}}">
        {{localize "NEUROSHIMA.MeleeDuel.Defender"}} ({{currentExchange.defenderSelectedDice.length}}/{{currentExchange.declaredDiceCount}})
      </div>
    </div>
  {{/if}}

  {{#if (and isGM (eq turnState.phase "exchange-ready"))}}
    <button type="button" class="resolve-btn-mini pulse" data-action="resolveExchange">
      <i class="fas fa-check-double"></i> {{localize "NEUROSHIMA.MeleeDuel.ResolveSegment"}}
    </button>
  {{/if}}
</section>
