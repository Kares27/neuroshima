<section class="active-exchange-panel phase-{{turnState.phase}}">
  <h3>{{localize "NEUROSHIMA.MeleeDuel.ActiveExchange"}}</h3>
  
  <div class="exchange-grid">
    <div class="side attacker {{#if (eq turnState.selectionTurn currentExchange.attackerId)}}is-selecting{{/if}}">
      {{#if attacker}}
        <div class="role">{{localize "NEUROSHIMA.MeleeDuel.Attacker"}}</div>
        <img src="{{attacker.img}}" class="exchange-img" />
        <div class="name">{{attacker.name}}</div>
        <div class="action-status">
          {{localize (concat "NEUROSHIMA.MeleeDuel.Actions." currentExchange.declaredAction)}} ({{currentExchange.declaredDiceCount}}s)
        </div>
        <div class="selection-progress">
          {{localize "NEUROSHIMA.Roll.Dice"}}: {{currentExchange.attackerSelectedDice.length}} / {{currentExchange.declaredDiceCount}}
        </div>
      {{else}}
        <div class="waiting-msg">{{localize "NEUROSHIMA.MeleeDuel.WaitingForAttacker"}}</div>
      {{/if}}
    </div>

    <div class="exchange-divider">
      <div class="vs-label">VS</div>
      <div class="segment-info">{{localize "NEUROSHIMA.Roll.Segment"}} {{turnState.segment}}</div>
    </div>

    <div class="side defender {{#if (eq turnState.selectionTurn currentExchange.defenderId)}}is-selecting{{/if}}">
      {{#if defender}}
        <div class="role">{{localize "NEUROSHIMA.MeleeDuel.Defender"}}</div>
        <img src="{{defender.img}}" class="exchange-img" />
        <div class="name">{{defender.name}}</div>
        <div class="selection-progress">
          {{localize "NEUROSHIMA.MeleeDuel.DefendingWith" weapon=""}}: {{currentExchange.defenderSelectedDice.length}} / {{currentExchange.declaredDiceCount}}
        </div>
      {{else}}
        <div class="waiting-msg">{{localize "NEUROSHIMA.MeleeDuel.WaitingForDefender"}}</div>
      {{/if}}
    </div>
  </div>

  <div class="exchange-actions">
    {{#if (and isGM (eq turnState.phase "exchange-ready"))}}
      <button type="button" class="resolve-btn pulse" data-action="resolveExchange">
        <i class="fas fa-swords"></i> {{localize "NEUROSHIMA.MeleeDuel.ResolveSegment"}}
      </button>
    {{/if}}
  </div>
</section>
