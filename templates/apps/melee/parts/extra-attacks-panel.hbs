<section class="extra-attacks-panel">
  <header class="extra-attacks-panel__header">
    <h3><i class="fas fa-bolt"></i> Grad ciosów (Dodatkowe ataki)</h3>
  </header>

  {{#if extraAttackCards.length}}
    <div class="extra-attacks-panel__list">
      {{#each extraAttackCards}}
        <article class="extra-attack-card {{resultClass}}">
          <div class="extra-attack-card__info">
            <span class="ea-attacker">{{attackerName}}</span>
            <i class="fas fa-long-arrow-right"></i>
            <span class="ea-defender">{{defenderName}}</span>
            <span class="ea-dice">{{attackDiceCount}}s</span>
          </div>

          {{#if resolved}}
            <div class="extra-attack-card__result">
              {{#if result.hit}}
                <span class="hit">TRAFIENIE ({{result.location}})</span>
              {{else}}
                <span class="block">ZABLOKOWANO ({{result.defenseRoll}} vs {{result.attackRoll}})</span>
              {{/if}}
            </div>
          {{else}}
            <div class="extra-attack-card__pending">Oczekuje...</div>
          {{/if}}
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="extra-attacks-empty">Brak dodatkowych ataków w tej turze.</div>
  {{/if}}
</section>