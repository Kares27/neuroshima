<div class="advanced-effect-config">

  {{!-- ── Test Independent (hidden for owningDocument) ── --}}
  {{#unless isDocument}}
  <div class="form-group">
    <label>Test Independent</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.neuroshima.testIndependent" {{#if testIndependent}}checked{{/if}}>
    </div>
    <p class="notes">If checked, this Effect can be applied directly from the owning Actor's sheet, instead of only from a roll or chat</p>
  </div>

  {{!-- ── Avoid Test fieldset ── --}}
  <fieldset>
    <legend>Avoid Test</legend>

    <div class="form-group">
      <label>Avoid Test</label>
      <div class="form-fields">
        <select name="flags.neuroshima.avoidTestType">
          <option value="none"   {{#if (eq avoidTestType "none")}}selected{{/if}}>None</option>
          <option value="script" {{#if (eq avoidTestType "script")}}selected{{/if}}>Script</option>
        </select>
      </div>
      <p class="notes">Define a condition that, if met, prevents the effect from being applied. <strong>Script</strong> lets you write a custom script that returns <strong>true</strong> to prevent the effect.</p>
    </div>

    {{#if (eq avoidTestType "script")}}
    <div class="form-group stacked">
      <label>Avoid Script</label>
      <p class="notes">Receives <code>actor</code> and <code>effect</code>. Return <strong>true</strong> to prevent application.</p>
      <code-mirror name="flags.neuroshima.avoidTestScript" language="javascript" indent="4">{{avoidTestScript}}</code-mirror>
    </div>
    {{/if}}

  </fieldset>
  {{/unless}}

  {{!-- ── Area / Aura fieldset (only for aura/area types) ── --}}
  {{#if isAuraOrArea}}
  <fieldset>
    <legend>Area / Aura</legend>

    {{#if isAura}}
    <div class="form-group">
      <label>Transferred Aura</label>
      <div class="form-fields">
        <input type="checkbox" name="flags.neuroshima.auraTransferred" {{#if auraTransferred}}checked{{/if}}>
      </div>
      <p class="notes">Apply this Aura to a target (or self) instead of constantly to nearby actors in range</p>
    </div>

    <div class="form-group">
      <label>Render Aura</label>
      <div class="form-fields">
        <input type="checkbox" name="flags.neuroshima.auraRender" {{#if auraRender}}checked{{/if}}>
      </div>
      <p class="notes">Render the aura on the Canvas as a visible Measured Template</p>
    </div>
    {{/if}}

    {{#if isArea}}
    <div class="form-group">
      <label>Area Effect Duration</label>
      <div class="form-fields">
        <select name="flags.neuroshima.areaDuration">
          <option value="instantaneous" {{#if (eq areaDuration "instantaneous")}}selected{{/if}}>Instantaneous</option>
          <option value="sustained"     {{#if (eq areaDuration "sustained")}}selected{{/if}}>Sustained</option>
        </select>
      </div>
      <p class="notes"><strong>Instantaneous</strong> — applies once then removes the template. <strong>Sustained</strong> — template stays until manually removed.</p>
    </div>
    {{/if}}

    <div class="form-group">
      <label>Keep</label>
      <div class="form-fields">
        <input type="checkbox" name="flags.neuroshima.auraKeep" {{#if auraKeep}}checked{{/if}}>
      </div>
      <p class="notes">Prevents removing the effect upon leaving the Area / Aura range</p>
    </div>

    <div class="form-group">
      <label>Radius</label>
      <div class="form-fields">
        <input type="text" name="flags.neuroshima.auraRadius" value="{{auraRadius}}" placeholder="Inherit">
      </div>
      <p class="notes">Radius in scene distance units. Leave empty to inherit from Item if available.</p>
    </div>

    <div class="form-group">
      <label>Template Data</label>
      <div class="form-fields">
        <button type="button" data-action="configureTemplate" style="width:auto;">
          <i class="fas fa-palette"></i> Configure Template Data
        </button>
      </div>
      <p class="notes">Configure the visual template appearance (fill colour, border colour, opacity).</p>
    </div>

    {{#if isArea}}
    <div class="form-group">
      <label>Place Template</label>
      <div class="form-fields">
        <button type="button" data-action="placeTemplate" style="width:auto;">
          <i class="fas fa-ruler-combined"></i> Place Area Template
        </button>
      </div>
      <p class="notes">Place a circle template on the canvas to define the affected area. Closes this dialog.</p>
    </div>
    {{/if}}

  </fieldset>
  {{/if}}

  {{!-- ── Pre-Apply Script (hidden for owningDocument) ── --}}
  {{#unless isDocument}}
  <div class="form-group stacked">
    <label>Pre-Apply Script</label>
    <p class="notes">This executes before an effect is applied — runs on the source, not the target. Return <strong>false</strong> to prevent application (Damage, Target, and Area/Aura only).</p>
    <code-mirror name="flags.neuroshima.preApplyScript" language="javascript" indent="4">{{preApplyScript}}</code-mirror>
  </div>
  {{/unless}}

  {{!-- ── Enable Script (always visible) ── --}}
  <div class="form-group stacked">
    <label>Enable Script</label>
    <p class="notes">Condition for whether the effect should be enabled or disabled.</p>
    <code-mirror name="flags.neuroshima.enableScript" language="javascript" indent="4">{{enableScript}}</code-mirror>
  </div>

  {{!-- ── Filter + Prompt (hidden for owningDocument) ── --}}
  {{#unless isDocument}}
  <div class="form-group stacked">
    <label>Filter</label>
    <p class="notes">Script to filter Documents to apply this Active Effect to. Should return <strong>true</strong> to prevent application.</p>
    <code-mirror name="flags.neuroshima.filterScript" language="javascript" indent="4">{{filterScript}}</code-mirror>
  </div>

  <div class="form-group">
    <label>Prompt</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.neuroshima.prompt" {{#if prompt}}checked{{/if}}>
    </div>
    <p class="notes">Provide a prompt and choose which document to apply the Active Effect to. Can be used with <strong>Filter</strong> to narrow the selection.</p>
  </div>
  {{/unless}}

  {{!-- ── Required Test Trigger (no-script path) ── --}}
  <fieldset>
    <legend>Required Test Trigger</legend>

    <div class="form-group">
      <label>Enable</label>
      <div class="form-fields">
        <input type="checkbox" name="flags.neuroshima.requiredTestTrigger.enabled"
               {{#if requiredTestTrigger.enabled}}checked{{/if}}>
      </div>
      <p class="notes">
        When checked, applying this effect to an actor automatically posts a Required Test chat card.
        No script needed — configure the test below. For complex branching logic use an
        <strong>immediate</strong> script with <code>this.postRequiredTest({…})</code> instead.
      </p>
    </div>

    {{#if requiredTestTrigger.enabled}}

    <div class="form-group">
      <label>Card Title</label>
      <div class="form-fields">
        <input type="text" name="flags.neuroshima.requiredTestTrigger.title"
               value="{{requiredTestTrigger.title}}" placeholder="(uses effect name)">
      </div>
    </div>

    <div class="form-group stacked">
      <label>Description</label>
      <textarea name="flags.neuroshima.requiredTestTrigger.description"
                rows="2">{{requiredTestTrigger.description}}</textarea>
      <p class="notes">Flavour text shown on the chat card below the title.</p>
    </div>

    <div class="form-group">
      <label>Test Type</label>
      <div class="form-fields">
        <select name="flags.neuroshima.requiredTestTrigger.testType">
          <option value="attribute" {{#if (eq requiredTestTrigger.testType "attribute")}}selected{{/if}}>Attribute</option>
          <option value="skill"     {{#if (eq requiredTestTrigger.testType "skill")}}selected{{/if}}>Skill</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Test Key</label>
      <div class="form-fields">
        {{#if (eq requiredTestTrigger.testType "attribute")}}
        <select name="flags.neuroshima.requiredTestTrigger.testKey">
          {{#each testAttributes}}
          <option value="{{@key}}" {{#if (eq @key ../requiredTestTrigger.testKey)}}selected{{/if}}>
            {{localize this}}
          </option>
          {{/each}}
        </select>
        {{else}}
        <select name="flags.neuroshima.requiredTestTrigger.testKey">
          {{#each testSkillGroups}}
          <optgroup label="{{this.attrLabel}}">
            {{#each this.skills}}
            <option value="{{this.key}}" {{#if (eq this.key ../../requiredTestTrigger.testKey)}}selected{{/if}}>
              {{this.label}}
            </option>
            {{/each}}
          </optgroup>
          {{/each}}
        </select>
        {{/if}}
      </div>
      <p class="notes">Attribute or skill key rolled against.</p>
    </div>

    {{#if (eq requiredTestTrigger.testType "skill")}}
    <div class="form-group">
      <label>Attribute Override</label>
      <div class="form-fields">
        <select name="flags.neuroshima.requiredTestTrigger.testAttributeOverride">
          <option value="" {{#unless requiredTestTrigger.testAttributeOverride}}selected{{/unless}}>(auto-detect)</option>
          {{#each testAttributes}}
          <option value="{{@key}}" {{#if (eq @key ../requiredTestTrigger.testAttributeOverride)}}selected{{/if}}>
            {{localize this}}
          </option>
          {{/each}}
        </select>
      </div>
      <p class="notes">Override the attribute used for a skill test (leave blank for auto-detection).</p>
    </div>
    {{/if}}

    <div class="form-group">
      <label>Required Successes</label>
      <div class="form-fields">
        <input type="number" name="flags.neuroshima.requiredTestTrigger.requiredSuccesses"
               value="{{requiredTestTrigger.requiredSuccesses}}" min="1" max="20" step="1" style="width:60px;">
      </div>
    </div>

    <div class="form-group">
      <label>Open Test</label>
      <div class="form-fields">
        <input type="checkbox" name="flags.neuroshima.requiredTestTrigger.isOpen"
               {{#if requiredTestTrigger.isOpen}}checked{{/if}}>
      </div>
      <p class="notes">If checked the player rolls an open test; otherwise a closed test.</p>
    </div>

    <div class="form-group">
      <label>Base Difficulty</label>
      <div class="form-fields">
        <select name="flags.neuroshima.requiredTestTrigger.baseDifficulty">
          {{#each difficulties}}
          <option value="{{@key}}" {{#if (eq @key ../requiredTestTrigger.baseDifficulty)}}selected{{/if}}>
            {{localize this.label}}
          </option>
          {{/each}}
        </select>
      </div>
      <p class="notes">Starting difficulty modifier applied to the roll dialog.</p>
    </div>

    {{#if siblingEffects.length}}
    <fieldset style="margin-top:0.5rem;">
      <legend>Effects on Resolution</legend>
      <p class="notes" style="margin-bottom:0.5rem;">
        Select which sibling effects (on the same item) are applied on <strong>Success</strong>
        or <strong>Failure</strong>. IDs are stable across copies — no UUID needed.
      </p>
      <table style="width:100%;border-collapse:collapse;font-size:0.85em;">
        <thead>
          <tr>
            <th style="text-align:left;padding:2px 4px;">Effect</th>
            <th style="text-align:center;padding:2px 4px;width:60px;">✓ Success</th>
            <th style="text-align:center;padding:2px 4px;width:60px;">✗ Failure</th>
          </tr>
        </thead>
        <tbody>
          {{#each siblingEffects}}
          <tr>
            <td style="padding:2px 4px;">{{this.name}}</td>
            <td style="text-align:center;padding:2px 4px;">
              <input type="checkbox"
                     data-rt-role="success"
                     value="{{this.id}}"
                     {{#if this.isSuccess}}checked{{/if}}>
            </td>
            <td style="text-align:center;padding:2px 4px;">
              <input type="checkbox"
                     data-rt-role="failure"
                     value="{{this.id}}"
                     {{#if this.isFailure}}checked{{/if}}>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </fieldset>
    {{else}}
    <p class="notes" style="margin-top:0.5rem;">
      <em>No sibling effects on this item. Add effects to the same item to link them here.</em>
    </p>
    {{/if}}

    {{/if}}{{!-- /requiredTestTrigger.enabled --}}

  </fieldset>

</div>
