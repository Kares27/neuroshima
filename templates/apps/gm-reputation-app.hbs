<section class="standard-form gm-rep-form">

    <div class="gm-rep-columns">

        <!-- LEFT: Actor list -->
        <div class="rep-actors-col">
            <div class="actor-list-header">
                <span class="actor-list-title">{{localize "NEUROSHIMA.GMToolkit.Reputation.Actors"}} ({{selectedCount}})</span>
                <div class="actor-list-controls">
                    <button type="button" data-action="selectAll" class="xp-ctrl-btn" title="{{localize 'NEUROSHIMA.GMToolkit.AddXP.SelectAll'}}">
                        <i class="fas fa-check-double"></i>
                    </button>
                    <button type="button" data-action="deselectAll" class="xp-ctrl-btn" title="{{localize 'NEUROSHIMA.GMToolkit.AddXP.DeselectAll'}}">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            {{#each actors}}
            <div class="actor-row {{#if selected}}selected{{/if}}" data-actor-id="{{id}}" data-action="toggleActor">
                <img class="actor-portrait" src="{{img}}" alt="{{name}}">
                <span class="actor-name">{{name}}</span>
                <div class="rep-current-values">
                    <span class="rep-chip" title="{{localize 'NEUROSHIMA.Reputation'}}"><i class="fas fa-handshake"></i> {{reputation}}</span>
                    <span class="rep-chip" title="{{localize 'NEUROSHIMA.Fame'}}"><i class="fas fa-star"></i> {{fame}}</span>
                </div>
                <i class="fas {{#if selected}}fa-check-square{{else}}fa-square{{/if}} actor-checkbox"></i>
            </div>
            {{else}}
            <p class="no-actors">—</p>
            {{/each}}
        </div>

        <!-- RIGHT: Reputation options -->
        <div class="rep-options-col">
            <div class="rep-options-header">{{localize "NEUROSHIMA.GMToolkit.Reputation.OptionsHeader"}}</div>

            <div class="rep-global-section">
                <div class="rep-global-row">
                    <i class="fas fa-handshake rep-icon"></i>
                    <span class="rep-global-label">{{localize "NEUROSHIMA.GMToolkit.Reputation.RepDelta"}}</span>
                    <input type="number" class="rep-global-delta rep-number-input" value="{{repDelta}}" step="1" placeholder="0">
                </div>
                <div class="rep-global-row">
                    <i class="fas fa-star fame-icon"></i>
                    <span class="rep-global-label">{{localize "NEUROSHIMA.GMToolkit.Reputation.FameDelta"}}</span>
                    <input type="number" class="fame-global-delta rep-number-input" value="{{fameDelta}}" step="1" placeholder="0">
                </div>
            </div>

            {{#if hasSelection}}
            {{#if hasRepItems}}
            <hr class="rep-options-hr">
            <div class="rep-items-header">{{localize "NEUROSHIMA.GMToolkit.Reputation.FactionHeader"}}</div>
            {{#each repItems}}
            <div class="rep-item-row">
                <img class="rep-item-img" src="{{img}}" alt="{{name}}" width="20" height="20">
                <span class="rep-item-name">{{name}}</span>
                <input type="number" class="rep-item-delta rep-number-input" data-rep-key="{{key}}" value="{{delta}}" step="1" placeholder="0">
            </div>
            {{/each}}
            {{/if}}
            {{/if}}
        </div>

    </div>

    <footer class="gm-toolkit-footer">
        <button type="button" data-action="applyChanges" class="gm-apply-btn" {{#unless hasSelection}}disabled{{/unless}}>
            <i class="fas fa-award"></i> {{localize "NEUROSHIMA.GMToolkit.Reputation.Apply"}}
        </button>
    </footer>

</section>
