<section class="tab effect-details {{tabs.details.cssClass}}" data-group="primary" data-tab="details" data-application-part="details">
    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Effects.Icon"}}</label>
        <input type="text" name="icon" value="{{effect.icon}}" placeholder="icons/svg/aura.svg">
    </div>
    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Effects.Label"}}</label>
        <input type="text" name="label" value="{{effect.label}}" placeholder="{{localize 'Name'}}">
    </div>
    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Effects.Origin"}}</label>
        <input type="text" name="origin" value="{{effect.origin}}" readonly>
    </div>
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Effects.Disabled"}}</label>
        <input type="checkbox" name="disabled" {{#if effect.disabled}}checked{{/if}}>
    </div>
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Effects.Transfer"}}</label>
        <input type="checkbox" name="transfer" {{#if effect.transfer}}checked{{/if}}>
    </div>
    <div class="form-group">
        <label>{{localize "Duration"}}</label>
        <div class="grid grid-3col">
            <div class="form-group row-group">
                <label>{{localize "NEUROSHIMA.Effects.Duration.Rounds"}}</label>
                <input type="number" name="duration.rounds" value="{{effect.duration.rounds}}" min="0">
            </div>
            <div class="form-group row-group">
                <label>{{localize "NEUROSHIMA.Effects.Duration.Turns"}}</label>
                <input type="number" name="duration.turns" value="{{effect.duration.turns}}" min="0">
            </div>
            <div class="form-group row-group">
                <label>{{localize "NEUROSHIMA.Effects.Duration.Seconds"}}</label>
                <input type="number" name="duration.seconds" value="{{effect.duration.seconds}}" min="0">
            </div>
        </div>
    </div>
    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Effects.Description"}}</label>
        <textarea name="description" rows="4">{{effect.description}}</textarea>
    </div>
</section>
