
<div class="ns-script-editor-body">
    <div class="ns-editor-fields ns-actiondef-fields">

        <div class="form-group">
            <label>Nazwa</label>
            <div class="form-fields">
                <input type="text" name="name" value="{{actionDef.name}}" placeholder="np. Boa – Pochwycenie">
            </div>
        </div>

        <div class="form-group">
            <label data-tooltip="Typ i liczba ran zadawanych przy trafieniu. Wybierz — (brak) gdy sztuczka nie zadaje obrażeń, a jedynie uruchamia onHitScript.">Obrażenia</label>
            <div class="form-fields" style="gap:4px">
                <input type="number" name="damageCount" value="{{actionDef.damageCount}}" min="1" max="9" step="1" style="width:52px" {{#if (eq actionDef.damageType "—")}}disabled{{/if}}>
                <select name="damageType">
                    <option value="—" {{#if (eq actionDef.damageType "—")}}selected{{/if}}>— (brak)</option>
                    {{#each damageTypeOptions}}
                    <option value="{{this.value}}" {{#if (eq ../actionDef.damageType this.value)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>
        </div>

        <div class="form-group">
            <label data-tooltip="Minimalna liczba sukcesów wymagana do aktywacji tej akcji w kolejce. Przy wartości 0 akcja pojawia się jako samodzielny przycisk ataku, nie jako kolejka.">Koszt suk.</label>
            <div class="form-fields">
                <input type="number" name="successCost" value="{{actionDef.successCost}}" min="0" step="1" style="width:80px">
            </div>
        </div>

        <div class="form-group">
            <label data-tooltip="Minimalna liczba zadeklarowanych kości wymagana do pojawienia się przycisku tej akcji.">Min kości</label>
            <div class="form-fields">
                <input type="number" name="minDice" value="{{actionDef.minDice}}" min="0" step="1" style="width:80px">
            </div>
        </div>

        <div class="form-group">
            <label data-tooltip="Maksymalna liczba zadeklarowanych kości, przy której przycisk tej akcji jest jeszcze aktywny.">Maks kości</label>
            <div class="form-fields">
                <input type="number" name="maxDice" value="{{actionDef.maxDice}}" min="0" step="1" style="width:80px">
            </div>
        </div>

        <div class="form-group">
            <label data-tooltip="Gdy zaznaczone: onHitScript odpala się natychmiast po trafieniu — w trakcie trwania duela, zanim gracz kliknie &quot;Nałóż obrażenia&quot;. Przydatne do efektów aktywnych przez resztę walki (np. Pochwycenie Boa).">Natychmiastowy</label>
            <div class="form-fields">
                <input type="checkbox" name="immediateOnHit" {{#if actionDef.immediateOnHit}}checked{{/if}}>
            </div>
        </div>

    </div>

    <div class="ns-editor-scroll-area">

        {{#if actionDef.id}}
        <div class="form-group ns-actiondef-snippet-group">
            <label data-tooltip="Wklej ten kod w skrypcie getMeleeActions aby dodać tę akcję. Przycisk kopiuje snippet do schowka.">Push snippet</label>
            <div class="form-fields" style="gap:4px">
                <input type="text" readonly value='args.actions.push("{{actionDef.id}}");' style="font-family:monospace;font-size:11px;flex:1">
                <button type="button" class="ns-copy-snippet-btn" data-tooltip="Kopiuj snippet do schowka" style="flex:0 0 auto">
                    <i class="fa-solid fa-copy"></i>
                </button>
            </div>
        </div>
        {{/if}}

        <div class="form-group stacked ns-script-code-group">
            <label>onHitScript</label>
            <code-mirror name="onHitScript" language="javascript" indent="4">{{actionDef.onHitScript}}</code-mirror>
        </div>

    </div>

    <footer class="form-footer">
        <button type="button" class="ns-se-save-btn">
            <i class="fa-solid fa-floppy-disk"></i> Zapisz i zamknij
        </button>
    </footer>
</div>
