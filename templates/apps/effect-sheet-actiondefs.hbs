<section class="tab scrollable" data-group="sheet" data-tab="actiondefs" data-application-part="actiondefs">
    <div class="neuroshima-script-list">
        <p class="hint ns-actiondefs-hint">
            Definicje „Walka wręcz” zachowują dotychczasową obsługę sztuczek.
            Definicje „Wynik rzutu” są automatycznie zbierane na wskazanych kartach.
        </p>
        {{#each actionDefs}}
        <div class="ns-script-row ns-actiondef-row" data-index="{{@index}}">
            <label class="ns-script-label">
                <a data-action="editActionDef" data-index="{{@index}}">
                    <i class="{{#if (eq this.type "result")}}fa-solid fa-bolt{{else}}fa-solid fa-swords{{/if}}"></i>
                    {{#if this.name}}{{this.name}}{{else}}<em>Bez nazwy</em>{{/if}}
                </a>
            </label>
            <code class="ns-actiondef-uuid" data-action="copyActionDefId" data-index="{{@index}}">{{this.id}}</code>
            <span class="ns-script-trigger">
                {{#if (eq this.type "result")}}wynik rzutu{{else}}{{this.damage}} / {{this.successCost}}suk.{{/if}}
            </span>
            <a class="ns-script-action" data-action="removeActionDef" data-index="{{@index}}" data-tooltip="{{localize 'DOCUMENT.Delete'}}">
                <i class="fa-solid fa-xmark"></i>
            </a>
        </div>
        {{/each}}
        {{#unless actionDefs.length}}
        <p class="ns-scripts-empty hint">Brak definicji. Nowa akcja powstaje jako zgodna wstecznie sztuczka walki wręcz; typ można zmienić w edytorze.</p>
        {{/unless}}
        <div class="ns-script-add">
            <button type="button" data-action="addActionDef">
                <i class="fa-solid fa-plus"></i> Dodaj akcję
            </button>
        </div>
    </div>
</section>
