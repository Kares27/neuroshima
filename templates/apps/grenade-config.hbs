<section class="neuroshima-config">
    <div class="config-section">
        <h3>{{localize "NEUROSHIMA.Settings.GrenadeConfig.ThrowParams"}}</h3>
        <div class="flexrow" style="gap: 12px; margin-bottom: 12px;">
            <div class="form-group" style="flex: 1;">
                <label>{{localize "NEUROSHIMA.Settings.GrenadeConfig.BaseRange"}}</label>
                <input type="number" name="baseRange" value="{{baseRange}}" min="1" step="1"/>
            </div>
            <div class="form-group" style="flex: 1;">
                <label>{{localize "NEUROSHIMA.Settings.GrenadeConfig.DistanceMultiplier"}}</label>
                <input type="number" name="distanceMultiplier" value="{{distanceMultiplier}}" min="1" step="1"/>
            </div>
        </div>
    </div>
    <div class="config-section">
        <div class="grenade-config-header-row">
            <h3>{{localize "NEUROSHIMA.Settings.GrenadeConfig.BonusTiers"}}</h3>
            <button type="button" class="add-tier grenade-add-tier-btn">
                <i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Settings.GrenadeConfig.AddTier"}}
            </button>
        </div>
        <div class="grenade-tiers-header flexrow" style="font-weight:bold; margin-bottom:4px;">
            <span style="flex:1;">{{localize "NEUROSHIMA.Settings.GrenadeConfig.MinBuild"}}</span>
            <span style="flex:1;">{{localize "NEUROSHIMA.Settings.GrenadeConfig.MaxBuild"}}</span>
            <span style="flex:1;">{{localize "NEUROSHIMA.Settings.GrenadeConfig.Bonus"}}</span>
            <span style="width:30px;"></span>
        </div>
        <div class="grenade-tiers-scroll">
            <div class="grenade-tiers-list">
                {{#each tiers as |tier index|}}
                <div class="grenade-tier-row flexrow" data-index="{{@index}}" style="gap:8px; margin-bottom:4px; align-items:center;">
                    <input type="number" name="tiers.{{@index}}.minBuild" value="{{tier.minBuild}}" min="0" style="flex:1;">
                    <input type="number" name="tiers.{{@index}}.maxBuild" value="{{tier.maxBuild}}" min="0" style="flex:1;">
                    <input type="number" name="tiers.{{@index}}.bonus" value="{{tier.bonus}}" min="0" style="flex:1;">
                    <a class="item-control remove-tier" data-index="{{@index}}" title="{{localize 'NEUROSHIMA.Settings.GrenadeConfig.RemoveTier'}}" style="width:30px; text-align:center;">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    <footer class="sheet-footer flexrow">
        <button type="submit" name="submit">
            <i class="fas fa-save"></i> {{localize "SETTINGS.Save"}}
        </button>
    </footer>
</section>
