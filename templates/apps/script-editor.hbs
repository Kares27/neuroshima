<form class="standard-form">
    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Scripts.Label"}}</label>
        <div class="form-fields">
            <input type="text" name="label" value="{{scriptData.label}}" placeholder="{{localize 'NEUROSHIMA.Scripts.LabelPlaceholder'}}">
        </div>
    </div>

    <div class="form-group">
        <label>{{localize "NEUROSHIMA.Scripts.Trigger.Label"}}</label>
        <div class="form-fields">
            <select name="trigger">
                {{#each triggers}}
                <option value="{{@key}}" {{#if (eq @key ../scriptData.trigger)}}selected{{/if}}>{{localize this}}</option>
                {{/each}}
            </select>
        </div>
    </div>

    <div class="form-group stacked ns-script-code-group">
        <label>{{localize "NEUROSHIMA.Scripts.Code"}}</label>
        <div class="form-fields">
            <textarea name="code" class="ns-code-editor" placeholder="// {{localize 'NEUROSHIMA.Scripts.CodePlaceholder'}}
// this.actor, this.item, this.effect, args">{{scriptData.code}}</textarea>
        </div>
        <p class="hint">
            <code>this.actor</code> · <code>this.item</code> · <code>this.effect</code> · <code>args</code> · <code>this.notification(msg)</code>
        </p>
    </div>

    <footer class="form-footer">
        <button type="submit">
            <i class="fa-solid fa-floppy-disk"></i> {{localize "NEUROSHIMA.Sheet.SaveAndFinish"}}
        </button>
    </footer>
</form>
