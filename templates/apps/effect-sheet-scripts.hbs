<section class="tab effect-scripts {{tabs.scripts.cssClass}}" data-group="primary" data-tab="scripts" data-application-part="scripts">
    <div class="effect-scripts-info">
        <p class="hint">{{localize "NEUROSHIMA.Scripts.Hint"}}</p>
    </div>

    <div class="effect-scripts-header">
        <button type="button" data-action="addScript" class="neuroshima-btn small">
            <i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Scripts.Add"}}
        </button>
    </div>

    {{#if scripts.length}}
    <div class="effect-scripts-list">
        {{#each scripts}}
        <div class="script-entry" data-index="{{@index}}">
            <div class="script-header">
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.Scripts.Label"}}</label>
                    <input type="text" name="scripts.{{@index}}.label" value="{{this.label}}" placeholder="{{localize 'NEUROSHIMA.Scripts.LabelPlaceholder'}}">
                </div>
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.Scripts.Trigger.Label"}}</label>
                    <select name="scripts.{{@index}}.trigger">
                        {{#each ../triggers}}
                        <option value="{{@key}}" {{#if (eq @key ../this.trigger)}}selected{{/if}}>{{localize this}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="script-actions">
                    {{#if (eq this.trigger "manual")}}
                    <button type="button" data-action="runManualScript" data-index="{{@index}}" class="neuroshima-btn small" title="{{localize 'NEUROSHIMA.Scripts.Run'}}">
                        <i class="fas fa-play"></i>
                    </button>
                    {{/if}}
                    <button type="button" data-action="removeScript" data-index="{{@index}}" class="neuroshima-btn small danger" title="{{localize 'DOCUMENT.Delete'}}">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
            <div class="script-code">
                <label>{{localize "NEUROSHIMA.Scripts.Code"}}</label>
                <textarea name="scripts.{{@index}}.code" rows="8" class="code-editor" placeholder="// {{localize 'NEUROSHIMA.Scripts.CodePlaceholder'}}&#10;// Available: this.actor, this.item, this.effect, args&#10;// Example: this.actor.update({'system.hp.value': 10});">{{this.code}}</textarea>
            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="scripts-empty">
        <p class="empty-list">{{localize "NEUROSHIMA.Scripts.Empty"}}</p>
        <div class="scripts-help">
            <p>{{localize "NEUROSHIMA.Scripts.HelpText"}}</p>
            <ul>
                <li><code>this.actor</code> - {{localize "NEUROSHIMA.Scripts.Help.Actor"}}</li>
                <li><code>this.item</code> - {{localize "NEUROSHIMA.Scripts.Help.Item"}}</li>
                <li><code>this.effect</code> - {{localize "NEUROSHIMA.Scripts.Help.Effect"}}</li>
                <li><code>this.notification(msg)</code> - {{localize "NEUROSHIMA.Scripts.Help.Notification"}}</li>
                <li><code>args</code> - {{localize "NEUROSHIMA.Scripts.Help.Args"}}</li>
            </ul>
        </div>
    </div>
    {{/if}}
</section>
