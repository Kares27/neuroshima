<div class="vehicle-damage-details grid grid-2col">
    {{!-- Lokalizacja --}}
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Items.Fields.Location"}}</label>
        <select name="system.location">
            {{selectOptions vehicleLocations selected=system.location localize=true}}
        </select>
    </div>

    {{!-- Typ Uszkodzenia --}}
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Items.Fields.DamageType"}}</label>
        <select name="system.damageType">
            {{selectOptions vehicleDamageTypes selected=system.damageType localize=true}}
        </select>
    </div>

    {{!-- Utrata Sprawności --}}
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Vehicle.Damage.EffLoss"}}</label>
        <input type="number" name="system.efficiencyLoss" value="{{system.efficiencyLoss}}" min="0">
    </div>

    {{!-- Kara Zwrotności --}}
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Vehicle.AgilityPenalty"}} (%)</label>
        <input type="number" name="system.agilityPenalty" value="{{system.agilityPenalty}}" min="0">
    </div>

    {{!-- Aktywne --}}
    <div class="form-group row-group">
        <label>{{localize "NEUROSHIMA.Items.Fields.IsActive"}}</label>
        <input type="checkbox" name="system.isActive" {{#if system.isActive}}checked{{/if}}>
    </div>
</div>
