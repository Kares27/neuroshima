<div class="flexrow weapon-stats-container">
    {{!-- Lewa strona: Atrybuty, Umiejętności i Bonusy (2 kolumny, 2 wiersze) --}}
    <div class="stats-left grid grid-2col">
        <div class="form-group row-group">
            <label>{{localize "NEUROSHIMA.Items.Fields.Attribute"}}</label>
            <select name="system.attribute">
                {{selectOptions attributes selected=system.attribute labelAttr="label" localize=true}}
            </select>
        </div>

        <div class="form-group row-group">
            <label title="{{localize 'NEUROSHIMA.Items.Fields.DefenseBonus'}}">{{localize "NEUROSHIMA.Items.Fields.DefenseBonusAbbr"}}</label>
            <input type="number" name="system.defenseBonus" value="{{system.defenseBonus}}" data-dtype="Number" {{#if isModded}}disabled{{/if}}/>
        </div>

        <div class="form-group row-group">
            <label>{{localize "NEUROSHIMA.Items.Fields.Skill"}}</label>
            <select name="system.skill">
                {{selectOptions availableSkills selected=selectedSkill localize=true}}
            </select>
        </div>

        <div class="form-group row-group">
            <label title="{{localize 'NEUROSHIMA.Items.Fields.AttackBonus'}}">{{localize "NEUROSHIMA.Items.Fields.AttackBonusAbbr"}}</label>
            <input type="number" name="system.attackBonus" value="{{system.attackBonus}}" data-dtype="Number" {{#if isModded}}disabled{{/if}}/>
        </div>
    </div>

    {{!-- Prawa strona: Budowa, PP i Obrażenia (1 kolumna, 2 wiersze, 2. wiersz ma 3 kolumny) --}}
    <div class="stats-right flexcol">
        <div class="flexrow" style="gap:6px;">
            <div class="form-group row-group" style="flex:1;">
                <label>{{localize "NEUROSHIMA.Items.Fields.RequiredBuild"}}</label>
                <input type="number" name="system.requiredBuild" value="{{system.requiredBuild}}" data-dtype="Number" min="0"/>
            </div>
            <div class="form-group row-group" style="flex:0 0 60px; text-align:center;">
                <label title="{{localize 'NEUROSHIMA.Items.Fields.Piercing'}}">{{localize "NEUROSHIMA.Items.Fields.PiercingAbbr"}}</label>
                <input type="number" name="system.piercing" value="{{system.piercing}}" data-dtype="Number" min="0" style="text-align:center;" {{#if isModded}}disabled{{/if}}/>
            </div>
        </div>
        
        <div class="form-group row-group">
            <label>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
            <div class="damage-horizontal-grid">
                <div class="damage-col">
                    <span class="damage-number">1</span>
                    <select name="system.damageMelee1" {{#if isModded}}disabled{{/if}}>
                        {{selectOptions damageTypes selected=system.damageMelee1 localize=true}}
                    </select>
                </div>
                <div class="damage-col">
                    <span class="damage-number">2</span>
                    <select name="system.damageMelee2" {{#if isModded}}disabled{{/if}}>
                        {{selectOptions damageTypes selected=system.damageMelee2 localize=true}}
                    </select>
                </div>
                <div class="damage-col">
                    <span class="damage-number">3</span>
                    <select name="system.damageMelee3" {{#if isModded}}disabled{{/if}}>
                        {{selectOptions damageTypes selected=system.damageMelee3 localize=true}}
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>
