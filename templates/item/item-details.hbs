<section class="tab tab-stats {{tabs.stats.cssClass}}" data-group="primary" data-tab="stats">
    {{#if (eq item.type "armor")}}
        <div class="stats-grid flexrow">
            {{!-- Left: Armor Ratings (2 cols, 3 rows) --}}
            <div class="armor-ratings-table flex2">
                <label class="section-label">{{localize "NEUROSHIMA.Items.Fields.Rating"}}</label>
                <div class="grid grid-2col">
                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.Head"}}</label>
                        <input type="number" name="system.armor.ratings.head" value="{{system.armor.ratings.head}}" data-dtype="Number" min="0"/>
                    </div>
                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.Torso"}}</label>
                        <input type="number" name="system.armor.ratings.torso" value="{{system.armor.ratings.torso}}" data-dtype="Number" min="0"/>
                    </div>
                    
                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.LeftArm"}}</label>
                        <input type="number" name="system.armor.ratings.leftArm" value="{{system.armor.ratings.leftArm}}" data-dtype="Number" min="0"/>
                    </div>
                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.RightArm"}}</label>
                        <input type="number" name="system.armor.ratings.rightArm" value="{{system.armor.ratings.rightArm}}" data-dtype="Number" min="0"/>
                    </div>

                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.LeftLeg"}}</label>
                        <input type="number" name="system.armor.ratings.leftLeg" value="{{system.armor.ratings.leftLeg}}" data-dtype="Number" min="0"/>
                    </div>
                    <div class="form-group row-group">
                        <label>{{localize "NEUROSHIMA.Items.Fields.RightLeg"}}</label>
                        <input type="number" name="system.armor.ratings.rightLeg" value="{{system.armor.ratings.rightLeg}}" data-dtype="Number" min="0"/>
                    </div>
                </div>
            </div>

            {{!-- Right: Durability and Penalty (Single Box) --}}
            <div class="armor-secondary-stats flex1 flexcol">
                <div class="item-features secondary-box">
                    <label class="section-label">{{localize "NEUROSHIMA.Tabs.Stats"}}</label>
                    <div class="grid grid-1col">
                        <div class="form-group row-group">
                            <label>{{localize "NEUROSHIMA.Items.Fields.RequiredBuild"}}</label>
                            <input type="number" name="system.armor.requiredBuild" value="{{system.armor.requiredBuild}}" data-dtype="Number" min="0"/>
                        </div>
                        <div class="form-group row-group">
                            <label title="{{localize 'NEUROSHIMA.Items.Fields.Durability'}}">{{localize "NEUROSHIMA.Items.Fields.DurabilityAbbr"}}</label>
                            <input type="number" name="system.armor.durability" value="{{system.armor.durability}}" data-dtype="Number" min="0"/>
                        </div>
                        <div class="form-group row-group">
                            <label>{{localize "NEUROSHIMA.Items.Fields.ArmorPenalty"}}</label>
                            <input type="number" name="system.armor.penalty" value="{{system.armor.penalty}}" data-dtype="Number" min="0"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {{/if}}

    {{#if (eq item.type "weapon")}}
        <div class="item-features weapon-stats secondary-box">
             {{#if (eq system.weaponType "melee")}}
                {{> "systems/neuroshima/templates/item/parts/weapon-melee.hbs"}}
             {{/if}}

             {{#if (eq system.weaponType "ranged")}}
                {{> "systems/neuroshima/templates/item/parts/weapon-ranged.hbs"}}
             {{/if}}

             {{#if (eq system.weaponType "thrown")}}
                {{> "systems/neuroshima/templates/item/parts/weapon-thrown.hbs"}}
             {{/if}}
        </div>
    {{/if}}

    {{#if (eq item.type "wound")}}
        <div class="item-features wound-stats secondary-box">
            {{> "systems/neuroshima/templates/item/parts/wound-details.hbs"}}
        </div>
    {{/if}}

    {{#if (eq item.type "vehicle-damage")}}
        <div class="item-features wound-stats secondary-box">
            {{> "systems/neuroshima/templates/item/parts/vehicle-damage-details.hbs"}}
        </div>
    {{/if}}

    {{#if (eq item.type "vehicle-mod")}}
        <div class="item-features vehicle-mod-stats secondary-box">
            {{> "systems/neuroshima/templates/item/parts/vehicle-mod-details.hbs"}}
        </div>
    {{/if}}

    {{#if (eq item.type "ammo")}}
        <div class="item-features ammo-stats secondary-box">
            {{> "systems/neuroshima/templates/item/parts/ammo-details.hbs"}}
        </div>
    {{/if}}

    {{#if (eq item.type "magazine")}}
        <div class="item-features magazine-stats secondary-box">
            {{> "systems/neuroshima/templates/item/parts/magazine-details.hbs"}}
        </div>
    {{/if}}

    {{#if (eq item.type "beast-action")}}
        <div class="item-features beast-action-stats secondary-box">
            <div class="grid grid-3col">
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.BeastAction.TypeLabel"}}</label>
                    <input type="text" name="system.actionType" value="{{system.actionType}}"/>
                </div>
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.BeastAction.CostTypeLabel"}}</label>
                    <select name="system.costType">
                        <option value="segment" {{#if (eq system.costType "segment")}}selected{{/if}}>{{localize "NEUROSHIMA.BeastAction.CostType.Segment"}}</option>
                        <option value="success" {{#if (eq system.costType "success")}}selected{{/if}}>{{localize "NEUROSHIMA.BeastAction.CostType.Success"}}</option>
                    </select>
                </div>
                {{#if (eq system.costType "segment")}}
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.BeastAction.SegmentCost"}}</label>
                    <input type="number" name="system.segmentCost" value="{{system.segmentCost}}" min="1" max="3"/>
                </div>
                {{else}}
                <div class="form-group row-group">
                    <label>{{localize "NEUROSHIMA.BeastAction.SuccessCost"}}</label>
                    <input type="number" name="system.successCost" value="{{system.successCost}}" min="0" max="3"/>
                </div>
                {{/if}}
            </div>

            <hr class="dotted-hr" style="margin: 6px 0;">
            <div class="flexrow" style="gap: 12px; align-items: flex-end; justify-content: center;">
                <div class="form-group row-group" style="flex: 1;">
                    <label>{{localize "NEUROSHIMA.Items.Fields.Attribute"}}</label>
                    <select name="system.attribute">
                        {{selectOptions attributes selected=system.attribute labelAttr="label" localize=true}}
                    </select>
                </div>
                <div class="form-group row-group" style="flex: 0 0 60px; text-align: center;">
                    <label title="Punkty Przebicia">PP</label>
                    <input type="number" name="system.piercing" value="{{system.piercing}}" min="0" max="10" style="text-align: center;"/>
                </div>
                <div class="form-group row-group" style="flex: 0 0 80px; text-align: center;">
                    <label>{{localize "NEUROSHIMA.Items.Fields.Damage"}}</label>
                    <select name="system.damage" style="text-align: center;">
                        {{selectOptions damageTypes selected=system.damage localize=true}}
                    </select>
                </div>
            </div>
        </div>
    {{/if}}

</section>
