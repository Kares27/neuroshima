    {{!-- Combat Tab --}}
    <div class="tab combat" data-group="primary" data-tab="combat">
      <div class="combat-container">
        <h2>{{localize "NEUROSHIMA.TabCombat"}}</h2>
        <div class="combat-content">
          
          {{!-- Left Column: Health & Wounds --}}
          <div class="combat-left-column">
            
            {{!-- Health Section --}}
            <div class="health-section">
              <h3>Zdrowie</h3>
              <div class="resource grid grid-2col">
                <div class="flex-group-center">
                  <label class="resource-label">Obrażenia (punkty)</label>
                  <div class="flexrow flex-center flex-between">
                    <input type="text" name="system.health.value" value="{{system.health.value}}" data-dtype="Number"/>
                    <span> / </span>
                    <input type="text" name="system.health.max" value="{{system.health.max}}" data-dtype="Number"/>
                  </div>
                </div>
                <div class="health-status">
                  <label class="resource-label">Status</label>
                  <div class="health-indicator">
                    {{#if (gte system.health.value 27)}}
                      <span class="wound-critical">Krytyczna</span>
                    {{else if (gte system.health.value 9)}}
                      <span class="wound-heavy">Ciężka</span>
                    {{else if (gte system.health.value 3)}}
                      <span class="wound-light">Lekka</span>
                    {{else if (gte system.health.value 1)}}
                      <span class="wound-scratch">Draśnięcie</span>
                    {{else}}
                      <span class="wound-none">Zdrowy</span>
                    {{/if}}
                  </div>
                </div>
              </div>
            </div>

            {{!-- Wounds Section --}}
            <div class="wounds-section">
              <div class="wounds-penalty-total">
                <span>Łączna kara (%): <strong>{{getTotalWoundPenalty}}%</strong></span>
              </div>
              <div class="wounds-header">
                <h3>Obrażenia</h3>
                <button type="button" class="add-wound-btn" data-action="add-wound">
                  <i class="fas fa-plus"></i> Dodaj
                </button>
              </div>
              
              <div class="wounds-list">
                {{#each system.health.wounds as |wound index|}}
                <div class="wound-entry" data-index="{{index}}">
                  <select name="system.health.wounds.{{index}}.location" data-dtype="String">
                    <option value="head" {{#if (eq wound.location "head")}}selected{{/if}}>Głowa</option>
                    <option value="torso" {{#if (eq wound.location "torso")}}selected{{/if}}>Tors</option>
                    <option value="leftArm" {{#if (eq wound.location "leftArm")}}selected{{/if}}>Lewa ręka</option>
                    <option value="rightArm" {{#if (eq wound.location "rightArm")}}selected{{/if}}>Prawa ręka</option>
                    <option value="leftLeg" {{#if (eq wound.location "leftLeg")}}selected{{/if}}>Lewa noga</option>
                    <option value="rightLeg" {{#if (eq wound.location "rightLeg")}}selected{{/if}}>Prawa noga</option>
                  </select>
                  
                  <select name="system.health.wounds.{{index}}.type" data-dtype="String">
                    <option value="scratch" {{#if (eq wound.type "scratch")}}selected{{/if}}>Draśnięcie</option>
                    <option value="light" {{#if (eq wound.type "light")}}selected{{/if}}>Lekka</option>
                    <option value="heavy" {{#if (eq wound.type "heavy")}}selected{{/if}}>Ciężka</option>
                    <option value="critical" {{#if (eq wound.type "critical")}}selected{{/if}}>Krytyczna</option>
                  </select>
                  
                  <input type="number" name="system.health.wounds.{{index}}.penalty" value="{{wound.penalty}}" data-dtype="Number" placeholder="%" min="0" max="200"/>
                  
                  <input type="text" name="system.health.wounds.{{index}}.description" value="{{wound.description}}" data-dtype="String" placeholder="Opis..."/>
                  
                  <button type="button" class="delete-wound" data-action="delete-wound" data-index="{{index}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
                {{/each}}
              </div>

              {{!-- Other Effects --}}
              <div class="other-effects">
                <div class="effects-header">
                  <h3>Inne kary i efekty</h3>
                  <button type="button" class="add-wound-btn" data-action="add-effect">
                    <i class="fas fa-plus"></i> Dodaj
                  </button>
                </div>
                
                <div class="effects-list">
                  {{#each system.health.otherEffects as |effect index|}}
                  <div class="effect-entry" data-index="{{index}}">
                    <select name="system.health.otherEffects.{{index}}.type" data-dtype="String">
                      <option value="scratch" {{#if (eq effect.type "scratch")}}selected{{/if}}>Draśnięcie</option>
                      <option value="light" {{#if (eq effect.type "light")}}selected{{/if}}>Lekka</option>
                      <option value="heavy" {{#if (eq effect.type "heavy")}}selected{{/if}}>Ciężka</option>
                      <option value="critical" {{#if (eq effect.type "critical")}}selected{{/if}}>Krytyczna</option>
                    </select>
                    
                    <input type="number" name="system.health.otherEffects.{{index}}.penalty" value="{{effect.penalty}}" data-dtype="Number" placeholder="%" min="0" max="200"/>
                    
                    <input type="text" name="system.health.otherEffects.{{index}}.name" value="{{effect.name}}" data-dtype="String" placeholder="Nazwa..."/>
                    
                    <input type="text" name="system.health.otherEffects.{{index}}.description" value="{{effect.description}}" data-dtype="String" placeholder="Opis działania..."/>
                    
                    <button type="button" class="delete-wound" data-action="delete-effect" data-index="{{index}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                  {{/each}}
                </div>
              </div>


            </div>
          </div>

          {{!-- Right Column: Equipment --}}
          <div class="combat-right-column">
            
            {{!-- Armor Section --}}
            <div class="armor-section">
              <h3>Pancerz (Redukcja)</h3>
              <div class="armor-penalty">
                <span>Łączna kara za pancerz: <strong class="penalty-value">{{getTotalArmorPenalty}}%</strong></span>
              </div>
              
              <div class="armor-content">
                {{!-- Left: Armor Values --}}
                <div class="armor-values">
                  <div class="armor-location">
                    <label class="resource-label">Głowa</label>
                    <input type="text" name="system.armor.head" value="{{system.armor.head}}" data-dtype="Number" readonly/>
                  </div>
                  <div class="armor-location">
                    <label class="resource-label">Tors</label>
                    <input type="text" name="system.armor.torso" value="{{system.armor.torso}}" data-dtype="Number" readonly/>
                  </div>
                  <div class="armor-location">
                    <label class="resource-label">Lewa Ręka</label>
                    <input type="text" name="system.armor.leftHand" value="{{system.armor.leftHand}}" data-dtype="Number" readonly/>
                  </div>
                  <div class="armor-location">
                    <label class="resource-label">Prawa Ręka</label>
                    <input type="text" name="system.armor.rightHand" value="{{system.armor.rightHand}}" data-dtype="Number" readonly/>
                  </div>
                  <div class="armor-location">
                    <label class="resource-label">Lewa Noga</label>
                    <input type="text" name="system.armor.leftLeg" value="{{system.armor.leftLeg}}" data-dtype="Number" readonly/>
                  </div>
                  <div class="armor-location">
                    <label class="resource-label">Prawa Noga</label>
                    <input type="text" name="system.armor.rightLeg" value="{{system.armor.rightLeg}}" data-dtype="Number" readonly/>
                  </div>
                </div>
                
                {{!-- Right: Equipped Armor List --}}
                <div class="armor-list">
                  <h4>Założone pancerze</h4>
                  <div class="equipment-list">
                    {{#each equippedArmor as |item|}}
                    <div class="equipment-item">
                      <img src="{{item.img}}" class="item-icon" alt="{{item.name}}"/>
                      <div class="item-info">
                        <div class="item-name">{{item.name}}</div>
                        <div class="item-stats">
                          <span class="armor-protection" title="Głowa/Tors/Lewa Ręka/Prawa Ręka/Lewa Noga/Prawa Noga">
                            G:{{item.system.protection.head}} T:{{item.system.protection.torso}} LR:{{item.system.protection.leftHand}} PR:{{item.system.protection.rightHand}} LN:{{item.system.protection.leftLeg}} PN:{{item.system.protection.rightLeg}}
                          </span>
                          <span class="penalty-display">Kara: {{item.system.penalty}}%</span>
                          <span>Wytrzymałość: {{getCurrentDurability item}}/{{item.system.durability.max}}</span>
                        </div>
                      </div>
                      <div class="item-controls">
                        <button type="button" class="item-control" data-action="edit-item" data-item-id="{{item._id}}">
                          <i class="fas fa-edit"></i>
                        </button>
                      </div>
                    </div>
                    {{/each}}
                  </div>
                </div>
              </div>
            </div>

            {{!-- Weapons Section --}}
            <div class="weapons-section">
              <h3>Bronie</h3>
              <div class="equipment-list">
                {{#each equippedWeapons as |item|}}
                <div class="equipment-item">
                  <img src="{{item.img}}" class="item-icon" alt="{{item.name}}"/>
                  <div class="item-info">
                    <div class="item-name">{{item.name}}</div>
                    <div class="item-stats">
                      {{#if (eq item.system.weaponType "Melee")}}
                        <span>Obrażenia: {{item.system.melee.damage.level1}}/{{item.system.melee.damage.level2}}/{{item.system.melee.damage.level3}}</span>
                        <span>Atak: {{#if item.system.melee.bonus.attack}}{{item.system.melee.bonus.attack}}{{else}}0{{/if}}</span>
                        <span>Obrona: {{#if item.system.melee.bonus.defense}}{{item.system.melee.bonus.defense}}{{else}}0{{/if}}</span>
                      {{else if (eq item.system.weaponType "Ranged")}}
                        <span>Obrażenia: {{item.system.ranged.damage.type}} (PP: {{item.system.ranged.damage.pp}})</span>
                        <span>Szybkostrzelność: {{item.system.ranged.fireRate}}</span>
                        <span>Amunicja: {{item.system.ranged.ammo.value}}/{{item.system.ranged.ammo.max}}</span>
                        {{#if item.system.ranged.ammo.currentMagazine}}
                        <span>Magazynek: {{item.system.ranged.ammo.currentMagazine}}</span>
                        {{/if}}
                      {{else}}
                        <span>Typ broni: {{item.system.weaponType}}</span>
                      {{/if}}
                      <span>Zacięcie: {{item.system.jamRange.min}}-{{item.system.jamRange.max}}</span>
                    </div>
                  </div>
                  <div class="item-controls">
                    <button type="button" class="item-control" data-action="edit-item" data-item-id="{{item._id}}">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button type="button" class="item-control" data-action="roll-attack" data-item-id="{{item._id}}">
                      <i class="fas fa-dice-d20"></i>
                    </button>
                  </div>
                </div>
                {{/each}}
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
    
    {{!-- Tricks Tab --}}
    <div class="tab tricks" data-group="primary" data-tab="tricks">
      <div class="grid grid-2col">
        <!-- Lewa tabela - sztuczki -->
        <div class="tricks-container">
          <h2>{{localize "NEUROSHIMA.TabTricks"}}</h2>
          <div class="items-header flexrow">
            <div class="item-name">{{localize "NEUROSHIMA.Name"}}</div>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize "NEUROSHIMA.Add"}} {{localize "NEUROSHIMA.ItemTypeTrick"}}" data-type="trick"><i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Add"}}</a>
            </div>
          </div>
          <ol class="items-list">
            {{#each tricks as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize "NEUROSHIMA.Edit"}} {{localize "NEUROSHIMA.ItemTypeTrick"}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="{{localize "NEUROSHIMA.Delete"}} {{localize "NEUROSHIMA.ItemTypeTrick"}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        
        <!-- Prawa tabela - pusta na przyszłe elementy -->
        <div class="tricks-container">
          <h2>{{localize "NEUROSHIMA.TabTricks"}}</h2>
          <div class="tricks-content">
            <!-- Tutaj będzie miejsce na dodatkowe sztuczki -->
          </div>
        </div>
      </div>
    </div>

    {{!-- Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
      <section class="grid grid-4col">
        <div class="item-list">
          <h2>{{localize "NEUROSHIMA.ItemTypeWeapon"}}</h2>
          <div class="items-header flexrow">
            <div class="item-name">{{localize "NEUROSHIMA.Name"}}</div>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'NEUROSHIMA.Add'}} Broń białą" data-type="weapon-melee"><i class="fas fa-plus"></i> Broń biała</a>
              <a class="item-control item-create" title="{{localize 'NEUROSHIMA.Add'}} Broń palną" data-type="weapon-ranged"><i class="fas fa-plus"></i> Broń palna</a>
            </div>
          </div>
          <ol class="items-list">
            {{#each weapons as |item id|}}
            <li class="item flexrow weapon-item" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
                </div>
                <div class="weapon-info">
                  <h4>{{item.name}}</h4>
                  <div class="weapon-details">
                    {{#if (eq item.type "weapon-melee")}}
                      <span class="weapon-damage">{{item.system.damage.level1}}/{{item.system.damage.level2}}/{{item.system.damage.level3}}</span>
                      <span class="weapon-type">Broń biała</span>
                    {{else if (eq item.type "weapon-ranged")}}
                      <span class="weapon-damage">{{item.system.damage.type}} (PP: {{item.system.damage.pp}})</span>
                      <span class="weapon-type">{{item.system.weaponType}} - {{item.system.ammo}}</span>
                    {{else}}
                      <span class="weapon-damage">Stary typ broni</span>
                    {{/if}}
                    {{#if item.system.equipped}}
                    <span class="weapon-equipped">Wyposażona</span>
                    {{/if}}
                  </div>
                </div>
              </div>
              <div class="item-controls">
                {{#if item.system.equipped}}
                <a class="item-control weapon-attack" title="Atakuj bronią {{item.name}}" data-weapon-id="{{item._id}}"><i class="fas fa-sword"></i></a>
                {{/if}}
                <a class="item-control item-edit" title="{{localize 'NEUROSHIMA.Edit'}} {{localize 'NEUROSHIMA.ItemTypeWeapon'}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="{{localize 'NEUROSHIMA.Delete'}} {{localize 'NEUROSHIMA.ItemTypeWeapon'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>

        <div class="item-list">
          <h2>{{localize "NEUROSHIMA.ItemTypeArmor"}}</h2>
          <div class="items-header flexrow">
            <div class="item-name">{{localize "NEUROSHIMA.Name"}}</div>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'NEUROSHIMA.Add'}} {{localize 'NEUROSHIMA.ItemTypeArmor'}}" data-type="armor"><i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Add"}}</a>
            </div>
          </div>
          <ol class="items-list">
            {{#each armors as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize 'NEUROSHIMA.Edit'}} {{localize 'NEUROSHIMA.ItemTypeArmor'}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="{{localize 'NEUROSHIMA.Delete'}} {{localize 'NEUROSHIMA.ItemTypeArmor'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>

        <div class="item-list">
          <h2>{{localize "NEUROSHIMA.ItemTypeAmmunition"}}</h2>
          <div class="items-header flexrow">
            <div class="item-name">{{localize "NEUROSHIMA.Name"}}</div>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'NEUROSHIMA.Add'}} {{localize 'NEUROSHIMA.ItemTypeAmmunition'}}" data-type="ammunition"><i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Add"}}</a>
            </div>
          </div>
          <ol class="items-list">
            {{#each ammunition as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize 'NEUROSHIMA.Edit'}} {{localize 'NEUROSHIMA.ItemTypeAmmunition'}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="{{localize 'NEUROSHIMA.Delete'}} {{localize 'NEUROSHIMA.ItemTypeAmmunition'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>

        <div class="item-list">
          <h2>{{localize "NEUROSHIMA.ItemTypeGeneral"}}</h2>
          <div class="items-header flexrow">
            <div class="item-name">{{localize "NEUROSHIMA.Name"}}</div>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'NEUROSHIMA.Add'}} {{localize 'NEUROSHIMA.ItemTypeGeneral'}}" data-type="general"><i class="fas fa-plus"></i> {{localize "NEUROSHIMA.Add"}}</a>
            </div>
          </div>
          <ol class="items-list">
            {{#each general as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="{{localize 'NEUROSHIMA.Edit'}} {{localize 'NEUROSHIMA.ItemTypeGeneral'}}"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="{{localize 'NEUROSHIMA.Delete'}} {{localize 'NEUROSHIMA.ItemTypeGeneral'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
      </section>
    </div>

    {{!-- Description Tab --}}
    <div class="tab description" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>
  </section>
</form>