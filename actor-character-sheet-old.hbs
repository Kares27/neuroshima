{{!-- Character Sheet Template --}}
<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'NEUROSHIMA.Name'}}"/></h1>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes"><i class="fas fa-user-cog"></i> {{localize "NEUROSHIMA.TabAttributes"}}</a>
    <a class="item" data-tab="skills"><i class="fas fa-brain"></i> {{localize "NEUROSHIMA.TabSkills"}}</a>
    <a class="item" data-tab="combat"><i class="fas fa-sword"></i> {{localize "NEUROSHIMA.TabCombat"}}</a>
    <a class="item" data-tab="tricks"><i class="fas fa-magic"></i> {{localize "NEUROSHIMA.TabTricks"}}</a>
    <a class="item" data-tab="items"><i class="fas fa-backpack"></i> {{localize "NEUROSHIMA.TabItems"}}</a>
    <a class="item" data-tab="description"><i class="fas fa-scroll"></i> {{localize "NEUROSHIMA.TabDescription"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Attributes Tab --}}
    <div class="tab attributes" data-group="primary" data-tab="attributes">
      <div class="grid grid-2col">
        <!-- Lewa kolumna - informacje o postaci -->
        <div class="character-info">
          <h2 class="character-info-title">{{localize "NEUROSHIMA.CharacterInfo"}}</h2>
          <div class="form-group">
            <label>{{localize "NEUROSHIMA.InfoProfession"}}</label>
            <input type="text" name="system.profession" value="{{system.profession}}" placeholder="{{localize 'NEUROSHIMA.InfoProfession'}}"/>
          </div>
          <div class="form-group">
            <label>{{localize "NEUROSHIMA.InfoSpecialization"}}</label>
            <input type="text" name="system.specialization" value="{{system.specialization}}" placeholder="{{localize 'NEUROSHIMA.InfoSpecialization'}}"/>
          </div>
          <div class="form-group">
            <label>{{localize "NEUROSHIMA.InfoOrigin"}}</label>
            <input type="text" name="system.origin" value="{{system.origin}}"/>
          </div>
          <div class="form-group">
            <label>{{localize "NEUROSHIMA.InfoDisease"}}</label>
            <input type="text" name="system.disease" value="{{system.disease}}"/>
          </div>
          <div class="form-group">
            <label>{{localize "NEUROSHIMA.InfoMedicine"}}</label>
            <input type="text" name="system.medicine" value="{{system.medicine}}"/>
          </div>
          <div class="form-group experience-group">
            <label class="experience-title">Punkty Doświadczenia</label>
            <div class="experience-fields">
              <div class="experience-horizontal-layout">
                <div class="experience-item">
                  <label>Total:</label>
                  <input type="text" name="system.experience.total" value="{{system.experience.total}}" data-dtype="Number" class="experience-total"/>
                </div>
                <div class="experience-item">
                  <label>Wydane:</label>
                  <span class="experience-spent-display">{{#if system.experience.spent}}{{system.experience.spent}}{{else}}0{{/if}}</span>
                </div>
                <div class="experience-item">
                  <label>Obecne:</label>
                  <span class="experience-current-display">{{#if system.experience.current}}{{system.experience.current}}{{else}}0{{/if}}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Prawa kolumna - atrybuty i poziomy trudności -->
        <div class="attributes-container">
          <h2 class="attributes-title">{{localize "NEUROSHIMA.TabAttributes"}}</h2>
          <div class="attributes-grid">
            <table class="attributes-table">
              <thead>
                <tr>
                  <th rowspan="2">{{localize "NEUROSHIMA.TabAttributes"}}</th>
                  <th>{{localize "NEUROSHIMA.AbilityZR"}}</th>
                  <th>{{localize "NEUROSHIMA.AbilityPC"}}</th>
                  <th>{{localize "NEUROSHIMA.AbilityCH"}}</th>
                  <th>{{localize "NEUROSHIMA.AbilitySP"}}</th>
                  <th>{{localize "NEUROSHIMA.AbilityBD"}}</th>
                </tr>
                <tr>
                  <th><input type="number" name="system.attributes.zr.value" value="{{system.attributes.zr.value}}" data-dtype="Number"/></th>
                  <th><input type="number" name="system.attributes.pc.value" value="{{system.attributes.pc.value}}" data-dtype="Number"/></th>
                  <th><input type="number" name="system.attributes.ch.value" value="{{system.attributes.ch.value}}" data-dtype="Number"/></th>
                  <th><input type="number" name="system.attributes.sp.value" value="{{system.attributes.sp.value}}" data-dtype="Number"/></th>
                  <th><input type="number" name="system.attributes.bd.value" value="{{system.attributes.bd.value}}" data-dtype="Number"/></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>{{localize "NEUROSHIMA.Modifier"}}</td>
                  <td><input type="number" name="system.attributes.zr.mod" value="{{system.attributes.zr.mod}}" data-dtype="Number"/></td>
                  <td><input type="number" name="system.attributes.pc.mod" value="{{system.attributes.pc.mod}}" data-dtype="Number"/></td>
                  <td><input type="number" name="system.attributes.ch.mod" value="{{system.attributes.ch.mod}}" data-dtype="Number"/></td>
                  <td><input type="number" name="system.attributes.sp.mod" value="{{system.attributes.sp.mod}}" data-dtype="Number"/></td>
                  <td><input type="number" name="system.attributes.bd.mod" value="{{system.attributes.bd.mod}}" data-dtype="Number"/></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyEasy"}}</td>
                  <td class="difficulty-value zr-easy"></td>
                  <td class="difficulty-value pc-easy"></td>
                  <td class="difficulty-value ch-easy"></td>
                  <td class="difficulty-value sp-easy"></td>
                  <td class="difficulty-value bd-easy"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyAverage"}}</td>
                  <td class="difficulty-value zr-average"></td>
                  <td class="difficulty-value pc-average"></td>
                  <td class="difficulty-value ch-average"></td>
                  <td class="difficulty-value sp-average"></td>
                  <td class="difficulty-value bd-average"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyProblematic"}}</td>
                  <td class="difficulty-value zr-problematic"></td>
                  <td class="difficulty-value pc-problematic"></td>
                  <td class="difficulty-value ch-problematic"></td>
                  <td class="difficulty-value sp-problematic"></td>
                  <td class="difficulty-value bd-problematic"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyHard"}}</td>
                  <td class="difficulty-value zr-hard"></td>
                  <td class="difficulty-value pc-hard"></td>
                  <td class="difficulty-value ch-hard"></td>
                  <td class="difficulty-value sp-hard"></td>
                  <td class="difficulty-value bd-hard"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyVeryHard"}}</td>
                  <td class="difficulty-value zr-very-hard"></td>
                  <td class="difficulty-value pc-very-hard"></td>
                  <td class="difficulty-value ch-very-hard"></td>
                  <td class="difficulty-value sp-very-hard"></td>
                  <td class="difficulty-value bd-very-hard"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyDamnHard"}}</td>
                  <td class="difficulty-value zr-damn-hard"></td>
                  <td class="difficulty-value pc-damn-hard"></td>
                  <td class="difficulty-value ch-damn-hard"></td>
                  <td class="difficulty-value sp-damn-hard"></td>
                  <td class="difficulty-value bd-damn-hard"></td>
                </tr>
                <tr>
                  <td class="difficulty-name">{{localize "NEUROSHIMA.DifficultyLuck"}}</td>
                  <td class="difficulty-value zr-luck"></td>
                  <td class="difficulty-value pc-luck"></td>
                  <td class="difficulty-value ch-luck"></td>
                  <td class="difficulty-value sp-luck"></td>
                  <td class="difficulty-value bd-luck"></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

